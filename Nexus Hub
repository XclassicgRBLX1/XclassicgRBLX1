            function Sec:AddListPicker(o)
                o=o or {}
                local cb=o.Callback or function()end
                local items=o.Items or {}
                local selected=o.Default or nil
                local h=math.min(#items*28+10, o.MaxHeight or 120)+36
                local f=EF(h)
                NL(f,o.Name or "List",8)
                AddTip(f,o.Tooltip)

                local scrollH=h-36
                local scroll=New("ScrollingFrame",{
                    Size=UDim2.new(1,-14,0,scrollH),
                    Position=UDim2.new(0,7,0,30),
                    BackgroundColor3=T.Input,BackgroundTransparency=0.3,
                    BorderSizePixel=0,ScrollBarThickness=2,
                    ScrollBarImageColor3=T.Scroll,
                    ScrollingDirection=Enum.ScrollingDirection.Y,
                    CanvasSize=UDim2.new(0,0,0,0),
                    ZIndex=7,Parent=f
                })
                New("UICorner",{CornerRadius=UDim.new(0,6),Parent=scroll})
                local iLayout=New("UIListLayout",{
                    SortOrder=Enum.SortOrder.LayoutOrder,
                    Padding=UDim.new(0,1),Parent=scroll
                })
                New("UIPadding",{PaddingTop=UDim.new(0,3),PaddingBottom=UDim.new(0,3),Parent=scroll})
                iLayout:GetPropertyChangedSignal("AbsoluteContentSize"):Connect(function()
                    scroll.CanvasSize=UDim2.new(0,0,0,iLayout.AbsoluteContentSize.Y+6)
                end)

                local itemBtns={}
                local function UpdateSel(val)
                    selected=val
                    for v,btn in pairs(itemBtns) do
                        TweenQ(btn,.15,{BackgroundColor3=v==val and T.AccentDim or T.Element,
                                         BackgroundTransparency=v==val and 0 or 0.7})
                        for _,c in ipairs(btn:GetChildren()) do
                            if c:IsA("TextLabel") then
                                c.TextColor3=v==val and T.Text or T.SubText
                                c.Font=v==val and Enum.Font.GothamSemibold or Enum.Font.Gotham
                            end
                        end
                    end
                    task.spawn(cb,val)
                end
                for _,item in ipairs(items) do
                    local val2=type(item)=="table" and item.Value or item
                    local lbl2=type(item)=="table" and item.Label or item
                    local ib=New("TextButton",{
                        Size=UDim2.new(1,0,0,26),
                        BackgroundColor3=val2==selected and T.AccentDim or T.Element,
                        BackgroundTransparency=val2==selected and 0 or 0.7,
                        Text="",AutoButtonColor=false,ZIndex=8,Parent=scroll
                    })
                    New("UICorner",{CornerRadius=UDim.new(0,5),Parent=ib})
                    New("TextLabel",{
                        Size=UDim2.new(1,-12,1,0),Position=UDim2.new(0,8,0,0),
                        BackgroundTransparency=1,Text=lbl2,
                        TextColor3=val2==selected and T.Text or T.SubText,
                        TextSize=11,Font=val2==selected and Enum.Font.GothamSemibold or Enum.Font.Gotham,
                        TextXAlignment=Enum.TextXAlignment.Left,ZIndex=9,Parent=ib
                    })
                    itemBtns[val2]=ib
                    ib.MouseButton1Click:Connect(function() UpdateSel(val2) end)
                end

                local Obj={Value=selected}
                function Obj:Set(v) UpdateSel(v);self.Value=v end
                function Obj:Get() return selected end
                function Obj:SetVisible(v) f.Visible=v end
                return Obj
            end

