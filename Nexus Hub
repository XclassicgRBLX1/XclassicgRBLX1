function Nexus:CreateWindow(opts)
    opts=opts or{}
    local title=opts.Title or "NexusUI"
    local subtitle=opts.Subtitle or ""
    local winSz=opts.Size or UDim2.new(0,640,0,460)
    local winPos=opts.Position or UDim2.new(.5,-320,.5,-230)
    local toggleKey=opts.ToggleKey or Enum.KeyCode.RightShift
    local autoSaveInterval=opts.AutoSave or 0  -- 0=off, seconds otherwise

    -- Current theme (live-switchable)
    local themeName=type(opts.Theme)=="string" and opts.Theme or "Dark"
    local T=(type(opts.Theme)=="table") and opts.Theme or Nexus.Themes[themeName] or Nexus.Themes.Dark

    -- ── Theme registry: every themeable instance is tracked ──
    -- format: {inst=Instance, key="bg"|"accent"|..., prop="BackgroundColor3"|...}
    local themeReg={}
    local function regT(inst,prop,key)
        if inst and key then
            table.insert(themeReg,{inst=inst,prop=prop,key=key})
        end
    end
    local function applyTheme(newT)
        T=newT
        for _,r in ipairs(themeReg) do
            pcall(function()
                if r.inst and r.inst.Parent and newT[r.key] then
                    r.inst[r.prop]=newT[r.key]
                end
            end)
        end
    end

    -- ── Undo/Redo stack ──
    local undoStack={}
    local redoStack={}
    local function pushUndo(fn,fnRev)
        table.insert(undoStack,{do_=fn,undo=fnRev})
        redoStack={}  -- clear redo on new action
        if #undoStack>50 then table.remove(undoStack,1) end
    end

    -- ── Notification ScreenGui (own layer) ──
    local notifSG=mkGui(99900)
    local notifH=N("Frame",{Size=UDim2.new(0,300,1,0),Position=UDim2.new(1,-308,0,0),
        BackgroundTransparency=1,Parent=notifSG})
    local notifLL=N("UIListLayout",{SortOrder=Enum.SortOrder.LayoutOrder,
        VerticalAlignment=Enum.VerticalAlignment.Top,Padding=UDim.new(0,6),Parent=notifH})
    N("UIPadding",{PaddingTop=UDim.new(0,12),Parent=notifH})
    local notifIndex=0
    local notifLog={}  -- history

    -- ── Main ScreenGui ──
    local sg=mkGui(100);applyScale(sg)

    -- Drop shadow wrapper
    local wrap=N("Frame",{Size=winSz,Position=winPos,BackgroundTransparency=1,Parent=sg})
    N("ImageLabel",{Size=UDim2.new(1,60,1,60),Position=UDim2.new(0,-30,0,-30),
        BackgroundTransparency=1,Image="rbxassetid://6014261993",
        ImageColor3=Color3.fromRGB(0,0,0),ImageTransparency=.55,
        ScaleType=Enum.ScaleType.Slice,SliceCenter=Rect.new(49,49,450,450),ZIndex=0,Parent=wrap})

    local main=N("Frame",{Size=UDim2.new(1,0,1,0),BackgroundColor3=T.bg,
