    local taskActiveLbl = New("TextLabel",{
        Size=UDim2.new(1,0,0,14),Position=UDim2.new(0,0,0,0),
        BackgroundTransparency=1,Text="",
        TextColor3=T.SubText,TextSize=10,Font=Enum.Font.Gotham,
        TextXAlignment=Enum.TextXAlignment.Left,
        ZIndex=5, Parent=barSection
    })
    local pctRLbl = New("TextLabel",{
        Size=UDim2.new(1,0,0,14),Position=UDim2.new(0,0,0,0),
        BackgroundTransparency=1,Text="0%",
        TextColor3=T.Accent,TextSize=10,Font=Enum.Font.GothamBold,
        TextXAlignment=Enum.TextXAlignment.Right,
        ZIndex=5,Parent=barSection
    })

    local barTrack = New("Frame",{
        Size=UDim2.new(1,0,0,5),Position=UDim2.new(0,0,0,18),
        BackgroundColor3=T.LoadBarBg,BorderSizePixel=0,
        ZIndex=5,Parent=barSection
    })
    New("UICorner",{CornerRadius=UDim.new(1,0),Parent=barTrack})
    local barFill = New("Frame",{
        Size=UDim2.new(0,0,1,0),BackgroundColor3=T.LoadBar,
        BorderSizePixel=0,ZIndex=6,Parent=barTrack
    })
    New("UICorner",{CornerRadius=UDim.new(1,0),Parent=barFill})
    local shimmer = New("Frame",{
        Size=UDim2.new(0,80,1,0),Position=UDim2.new(-0.2,0,0,0),
        BackgroundColor3=Color3.fromRGB(255,255,255),
        BackgroundTransparency=0.78,BorderSizePixel=0,
        ZIndex=7,Parent=barFill
    })
    New("UICorner",{CornerRadius=UDim.new(1,0),Parent=shimmer})

    -- Spinner dots row
    local dotRow = New("Frame",{
        Size=UDim2.new(1,0,0,14),Position=UDim2.new(0,0,0,30),
        BackgroundTransparency=1,ZIndex=5,Parent=barSection
    })
    local dots={}
    for i=1,5 do
        local d=New("Frame",{
            Size=UDim2.new(0,6,0,6),
            Position=UDim2.new(0,(i-1)*12,0,4),
            BackgroundColor3=T.Accent,
            BackgroundTransparency=0.72,
            BorderSizePixel=0,ZIndex=6,Parent=dotRow
        })
        New("UICorner",{CornerRadius=UDim.new(1,0),Parent=d})
        dots[i]=d
    end

