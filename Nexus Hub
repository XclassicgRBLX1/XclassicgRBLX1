    local titleLbl=N("TextLabel",{
        Size=UDim2.new(0,240,0,subtitle~="" and 20 or 46),
        Position=UDim2.new(0,22,0,subtitle~="" and 6 or 0),
        BackgroundTransparency=1,Text=title,TextColor3=T.text,TextSize=15,
        Font=Enum.Font.GothamBold,TextXAlignment=Enum.TextXAlignment.Left,ZIndex=7,Parent=topbar})
