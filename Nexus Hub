                N("UICorner",{CornerRadius=UDim.new(1,0),Parent=rail})
                -- Active fill between handles
                local function pctOf(v) return (v-mn)/(mx-mn) end
                local activeF=N("Frame",{Size=UDim2.new(pctOf(vHigh)-pctOf(vLow),0,1,0),
                    Position=UDim2.new(pctOf(vLow),0,0,0),BackgroundColor3=T.accent,
                    BorderSizePixel=0,ZIndex=8,Parent=rail})
                rT(activeF,"BackgroundColor3","accent")
