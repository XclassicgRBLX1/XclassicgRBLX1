            -- ══════════════════════════════════════
            function Sec:AddColorPicker(o)
                o=o or {}
                local cb=o.Callback or function()end
                local col=o.Default or Color3.fromRGB(255,255,255)
                local H2,S2,V2=Color3.toHSV(col)
                local open=false
                local f=EF(36); HE(f)
                AddTip(f,o.Tooltip)
                NL(f,o.Name or "Color",10)
                local prev=New("TextButton",{
                    Size=UDim2.new(0,48,0,26),Position=UDim2.new(1,-56,.5,-13),
                    BackgroundColor3=col,BorderSizePixel=0,
                    Text="",AutoButtonColor=false,ZIndex=7,Parent=f
                })
                New("UICorner",{CornerRadius=UDim.new(0,6),Parent=prev})
                New("UIStroke",{Color=T.Border,Thickness=1,Parent=prev})
                local popup=New("Frame",{
                    Size=UDim2.new(0,226,0,0),BackgroundColor3=T.Sidebar,
                    BorderSizePixel=0,ClipsDescendants=true,Visible=false,ZIndex=5000,Parent=sg
                })
                New("UICorner",{CornerRadius=UDim.new(0,8),Parent=popup})
                New("UIStroke",{Color=T.BorderLt,Thickness=1,Parent=popup})
                local pList2=New("UIListLayout",{
                    SortOrder=Enum.SortOrder.LayoutOrder,Padding=UDim.new(0,7),Parent=popup
                })
                New("UIPadding",{
                    PaddingTop=UDim.new(0,10),PaddingBottom=UDim.new(0,10),
                    PaddingLeft=UDim.new(0,10),PaddingRight=UDim.new(0,10),Parent=popup
                })
                local strip=New("Frame",{
                    Size=UDim2.new(1,0,0,20),BackgroundColor3=col,
                    BorderSizePixel=0,ZIndex=5001,Parent=popup
                })
                New("UICorner",{CornerRadius=UDim.new(0,5),Parent=strip})
                local refs={}
                local lnames={"H","S","V"}; local maxes={360,100,100}
                local initV={H2*360,S2*100,V2*100}
                local function Recolor()
                    local nc=Color3.fromHSV(
                        (refs[1] and refs[1].v/360 or H2),
                        (refs[2] and refs[2].v/100 or S2),
                        (refs[3] and refs[3].v/100 or V2)
                    )
                    col=nc; prev.BackgroundColor3=nc; strip.BackgroundColor3=nc
                    task.spawn(cb,nc)
                end
                for i=1,3 do
                    local row=New("Frame",{Size=UDim2.new(1,0,0,24),BackgroundTransparency=1,ZIndex=5001,Parent=popup})
                    New("TextLabel",{Size=UDim2.new(0,14,1,0),BackgroundTransparency=1,Text=lnames[i],TextColor3=T.Accent,TextSize=10,Font=Enum.Font.GothamBold,ZIndex=5002,Parent=row})
                    local vL=New("TextLabel",{Size=UDim2.new(0,26,1,0),Position=UDim2.new(1,-26,0,0),BackgroundTransparency=1,Text=tostring(math.floor(initV[i])),TextColor3=T.SubText,TextSize=10,Font=Enum.Font.Gotham,TextXAlignment=Enum.TextXAlignment.Right,ZIndex=5002,Parent=row})
                    local tr=New("Frame",{Size=UDim2.new(1,-46,0,5),Position=UDim2.new(0,18,.5,-2.5),BackgroundColor3=T.SliderTr,BorderSizePixel=0,ZIndex=5002,Parent=row})
                    New("UICorner",{CornerRadius=UDim.new(1,0),Parent=tr})
                    local p0=initV[i]/maxes[i]
                    local fi=New("Frame",{Size=UDim2.new(p0,0,1,0),BackgroundColor3=T.Accent,BorderSizePixel=0,ZIndex=5003,Parent=tr})
                    New("UICorner",{CornerRadius=UDim.new(1,0),Parent=fi})
                    local dk=New("Frame",{Size=UDim2.new(0,10,0,10),AnchorPoint=Vector2.new(.5,.5),Position=UDim2.new(p0,0,.5,0),BackgroundColor3=Color3.fromRGB(255,255,255),BorderSizePixel=0,ZIndex=5004,Parent=tr})
                    New("UICorner",{CornerRadius=UDim.new(1,0),Parent=dk})
                    New("UIStroke",{Color=T.Accent,Thickness=1.5,Parent=dk})
                    local ref={v=initV[i]}; refs[i]=ref
                    local dg=false
                    local function Ap(inp)
                        local ap2=tr.AbsolutePosition; local as2=tr.AbsoluteSize
                        local r=Clamp((inp.Position.X-ap2.X)/as2.X,0,1)
                        local nv=math.floor(Lerp(0,maxes[i],r)+.5)
                        ref.v=nv; local np2=nv/maxes[i]
                        TweenQ(fi,.05,{Size=UDim2.new(np2,0,1,0)})
                        TweenQ(dk,.05,{Position=UDim2.new(np2,0,.5,0)})
                        vL.Text=tostring(nv); Recolor()
                    end
                    tr.InputBegan:Connect(function(inp) if inp.UserInputType==Enum.UserInputType.MouseButton1 then dg=true;Ap(inp) end end)
                    local cx=UserInputService.InputChanged:Connect(function(inp) if dg and inp.UserInputType==Enum.UserInputType.MouseMovement then Ap(inp) end end)
                    local cy=UserInputService.InputEnded:Connect(function(inp) if inp.UserInputType==Enum.UserInputType.MouseButton1 then dg=false end end)
                    table.insert(W._conns,cx); table.insert(W._conns,cy)
                end
                -- Hex
                local hexBg=New("Frame",{Size=UDim2.new(1,0,0,26),BackgroundColor3=T.Input,BorderSizePixel=0,ZIndex=5001,Parent=popup})
                New("UICorner",{CornerRadius=UDim.new(0,5),Parent=hexBg})
                New("TextLabel",{Size=UDim2.new(0,20,1,0),Position=UDim2.new(0,6,0,0),BackgroundTransparency=1,Text="#",TextColor3=T.Muted,TextSize=12,Font=Enum.Font.GothamBold,ZIndex=5002,Parent=hexBg})
                local hexTb=New("TextBox",{
                    Size=UDim2.new(1,-24,1,0),Position=UDim2.new(0,20,0,0),
                    BackgroundTransparency=1,Text=Hex(col),
                    PlaceholderText="RRGGBB",PlaceholderColor3=T.Muted,
                    TextColor3=T.Text,TextSize=11,Font=Enum.Font.GothamBold,
                    TextXAlignment=Enum.TextXAlignment.Left,ZIndex=5002,Parent=hexBg
                })
                hexTb.FocusLost:Connect(function()
                    local hex=hexTb.Text:gsub("#","")
                    if #hex==6 then
                        local r2=tonumber(hex:sub(1,2),16)
                        local g2=tonumber(hex:sub(3,4),16)
                        local b2=tonumber(hex:sub(5,6),16)
                        if r2 and g2 and b2 then
                            local nc=Color3.fromRGB(r2,g2,b2)
                            col=nc; prev.BackgroundColor3=nc; strip.BackgroundColor3=nc
                            local nh,ns,nv3=Color3.toHSV(nc)
                            refs[1].v=nh*360; refs[2].v=ns*100; refs[3].v=nv3*100
                            task.spawn(cb,nc)
                        end
                    end
                end)
                prev.MouseButton1Click:Connect(function()
                    open=not open
                    if open then
                        local ap=prev.AbsolutePosition; local as2=prev.AbsoluteSize
                        popup.Position=UDim2.new(0,ap.X-174,0,ap.Y+as2.Y+4)
                        popup.Visible=true; popup.Size=UDim2.new(0,226,0,0)
                        task.defer(function()
                            TweenQ(popup,.2,{Size=UDim2.new(0,226,0,pList2.AbsoluteContentSize.Y+20)})
                        end)
                    else
                        TweenQ(popup,.18,{Size=UDim2.new(0,226,0,0)})
                        task.delay(.2,function() if not open then popup.Visible=false end end)
                    end
                end)
                local Obj={Value=col}
                function Obj:Set(c)
                    col=c; prev.BackgroundColor3=c; strip.BackgroundColor3=c
                    local nh,ns,nv3=Color3.toHSV(c)
                    refs[1].v=nh*360; refs[2].v=ns*100; refs[3].v=nv3*100
                    hexTb.Text=Hex(c); self.Value=c
                end
                function Obj:Get() return col end
                function Obj:SetVisible(v) f.Visible=v end
                return Obj
            end

