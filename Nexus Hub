        BackgroundTransparency=1, Text=title, TextColor3=T.text, TextSize=22,
        Font=Enum.Font.GothamBold, ZIndex=4, Parent=card}); y=y+34
    local subLbl = N("TextLabel",{Size=UDim2.new(1,-32,0,16), Position=UDim2.new(0,16,0,y),
        BackgroundTransparency=1, Text=sub, TextColor3=T.sub, TextSize=12,
        Font=Enum.Font.Gotham, ZIndex=4, Parent=card}); y=y+24

    local checks = {}
    for i,tk in ipairs(tasks) do
        local row = N("Frame",{Size=UDim2.new(1,-32,0,22), Position=UDim2.new(0,16,0,y),
            BackgroundTransparency=1, ZIndex=4, Parent=card})
        local dot = N("Frame",{Size=UDim2.new(0,6,0,6), AnchorPoint=Vector2.new(0,.5),
            Position=UDim2.new(0,0,.5,0), BackgroundColor3=T.muted, BorderSizePixel=0, ZIndex=5, Parent=row})
        N("UICorner",{CornerRadius=UDim.new(1,0), Parent=dot})
        local tl = N("TextLabel",{Size=UDim2.new(1,-14,1,0), Position=UDim2.new(0,14,0,0),
            BackgroundTransparency=1, Text=tk.Name or ("Task "..i), TextColor3=T.muted,
            TextSize=12, Font=Enum.Font.Gotham, TextXAlignment=Enum.TextXAlignment.Left, ZIndex=5, Parent=row})
        checks[i]={dot=dot,lbl=tl}; y=y+24
    end
    y=y+8

    local track = N("Frame",{Size=UDim2.new(1,-32,0,4), Position=UDim2.new(0,16,0,y),
        BackgroundColor3=T.border, BorderSizePixel=0, ZIndex=4, Parent=card})
    N("UICorner",{CornerRadius=UDim.new(1,0), Parent=track})
    local barFill = N("Frame",{Size=UDim2.new(0,0,1,0), BackgroundColor3=T.accent,
        BorderSizePixel=0, ZIndex=5, Parent=track})
    N("UICorner",{CornerRadius=UDim.new(1,0), Parent=barFill}); y=y+12

    local pctL = N("TextLabel",{Size=UDim2.new(.5,0,0,16), Position=UDim2.new(.5,0,0,y),
        BackgroundTransparency=1, Text="0%", TextColor3=T.accent, TextSize=11,
        Font=Enum.Font.GothamBold, TextXAlignment=Enum.TextXAlignment.Right, ZIndex=4, Parent=card})
    local curL = N("TextLabel",{Size=UDim2.new(.5,0,0,16), Position=UDim2.new(0,16,0,y),
        BackgroundTransparency=1, Text="", TextColor3=T.sub, TextSize=11,
        Font=Enum.Font.Gotham, TextXAlignment=Enum.TextXAlignment.Left, ZIndex=4, Parent=card}); y=y+22

    local dF = N("Frame",{Size=UDim2.new(0,58,0,10), AnchorPoint=Vector2.new(.5,0),
        Position=UDim2.new(.5,0,0,y), BackgroundTransparency=1, ZIndex=4, Parent=card})
    local ldots = {}
    for i=1,4 do
        local d = N("Frame",{Size=UDim2.new(0,7,0,7), Position=UDim2.new(0,(i-1)*15,0,1),
            BackgroundColor3=T.accent, BackgroundTransparency=.7, BorderSizePixel=0, ZIndex=5, Parent=dF})
        N("UICorner",{CornerRadius=UDim.new(1,0), Parent=d}); ldots[i]=d
    end
    N("TextLabel",{Size=UDim2.new(1,-32,0,14), Position=UDim2.new(0,16,1,-20),
        BackgroundTransparency=1, Text="NexusUI v6.1-BM", TextColor3=T.muted, TextSize=10,
        Font=Enum.Font.Gotham, ZIndex=4, Parent=card})

    -- Animate dots + shimmer
    local phase = 0
    local sc2 = RunService.Heartbeat:Connect(function(dt)
        phase = phase+dt*3
        for i,d in ipairs(ldots) do
            local t2=(math.sin(phase+(i-1)*1.57)+1)*.5
            d.BackgroundTransparency=lerp(.1,.85,1-t2)
            local s=lerp(4,9,t2); d.Size=UDim2.new(0,s,0,s)
        end
        -- shimmer slide
        local sp = ((phase*0.18) % 1.3) - 0.3
        shimmer.Position = UDim2.new(sp,0,0,0)
    end)

    local Loader={}
    local function setP(f2,lbl)
        tw(barFill,.3,{Size=UDim2.new(clamp(f2,0,1),0,1,0)})
        tw(topStripe,.3,{Size=UDim2.new(clamp(f2,0,1),0,0,2)})
        pctL.Text=math.floor(clamp(f2,0,1)*100).."%"
        if lbl then curL.Text=lbl end
    end
    function Loader:Run(cb)
        task.wait(.35)
        if #tasks==0 then
            for i=0,10 do setP(i/10,"Loading..."); task.wait(.07) end
        else
            for i,tk in ipairs(tasks) do
                setP((i-1)/#tasks, tk.Name or "...")
                if checks[i] then tw(checks[i].dot,.2,{BackgroundColor3=T.accent}); tw(checks[i].lbl,.2,{TextColor3=T.text}) end
                task.wait(tk.Duration or .5)
                setP(i/#tasks)
                if checks[i] then
                    checks[i].dot.BackgroundColor3=T.success
                    checks[i].lbl.Text="✓  "..(tk.Name or "")
                    checks[i].lbl.TextColor3=T.sub
                end
            end
        end
        setP(1,"Ready!"); curL.TextColor3=T.success
        task.wait(.45); sc2:Disconnect()
        twI(card,.32,{BackgroundTransparency=1, Position=UDim2.new(.5,0,.45,0)})
        twI(bg,.42,{BackgroundTransparency=1}); task.wait(.48)
        pcall(function()sg:Destroy()end)
        if cb then task.spawn(cb) end
    end
    function Loader:SetStatus(t) subLbl.Text=t end
    function Loader:SetTask(t)   curL.Text=t end
    function Loader:SetProgress(f2) setP(f2) end
    return Loader
end

