local function tw(o, t, p, s, d)
    if not (o and o.Parent) then return end
    TweenService:Create(o, TweenInfo.new(t or .18,
        s or Enum.EasingStyle.Quart, d or Enum.EasingDirection.Out), p):Play()
end
local function twI(o, t, p) tw(o, t, p, Enum.EasingStyle.Quart, Enum.EasingDirection.In) end
local function twL(o, t, p) tw(o, t, p, Enum.EasingStyle.Linear) end

-- ‚ĒÄ‚ĒÄ Spring tween (elastic bounce-settle)
local function twSpring(o, t, p)
    if not (o and o.Parent) then return end
    TweenService:Create(o, TweenInfo.new(t or .4,
        Enum.EasingStyle.Spring, Enum.EasingDirection.Out), p):Play()
end
-- ‚ĒÄ‚ĒÄ Bounce tween
local function twBounce(o, t, p)
    if not (o and o.Parent) then return end
    TweenService:Create(o, TweenInfo.new(t or .3,
        Enum.EasingStyle.Bounce, Enum.EasingDirection.Out), p):Play()
end
-- ‚ĒÄ‚ĒÄ Staggered cascade: animates a list of objects with a delay between each
local function twCascade(objs, t, propsFn, delay)
    delay = delay or .04
    for i, o in ipairs(objs) do
        task.delay((i-1)*delay, function()
            if o and o.Parent then tw(o, t, propsFn(i, o)) end
        end)
    end
end
-- ‚ĒÄ‚ĒÄ Elastic scale-pop (used for notification icon)
local function twPop(o)
    if not (o and o.Parent) then return end
    tw(o, .12, {Size = UDim2.new(0, o.Size.X.Offset*1.22, 0, o.Size.Y.Offset*1.22)})
    task.delay(.13, function() twSpring(o, .28, {Size = UDim2.new(0, o.Size.X.Offset/1.22, 0, o.Size.Y.Offset/1.22)}) end)
end

-- ‚ĒÄ‚ĒÄ Ripple effect (spawns an expanding circle from click position)
local function mkRipple(parent, x, y, color)
    local r = Instance.new("Frame")
    r.Size = UDim2.new(0, 0, 0, 0)
    r.Position = UDim2.new(0, x, 0, y)
    r.AnchorPoint = Vector2.new(.5, .5)
    r.BackgroundColor3 = color or Color3.fromRGB(255,255,255)
    r.BackgroundTransparency = .72
    r.BorderSizePixel = 0
    r.ZIndex = 30
    Instance.new("UICorner", r).CornerRadius = UDim.new(1, 0)
    r.Parent = parent
    local sz = math.max(parent.AbsoluteSize.X, parent.AbsoluteSize.Y) * 2.2
    tw(r, .45, {Size = UDim2.new(0, sz, 0, sz), BackgroundTransparency = 1})
    task.delay(.48, function() pcall(function() r:Destroy() end) end)
end

-- ‚ĒÄ‚ĒÄ Utility helpers
local function N(c, p)
    local o = Instance.new(c)
    for k, v in pairs(p) do if k ~= "Parent" then o[k] = v end end
    if p.Parent then o.Parent = p.Parent end
    return o
end
local function clamp(v, a, b) return math.max(a, math.min(b, v)) end
local function lerp(a, b, t)  return a + (b-a)*t end
local function round(v, s)    s = s or 1; return math.floor(v/s+.5)*s end
local function hexc(c)        return string.format("%02X%02X%02X", c.R*255, c.G*255, c.B*255) end
local function getVP()
    return (workspace.CurrentCamera and workspace.CurrentCamera.ViewportSize) or Vector2.new(1280, 720)
end
local function mkGui(order)
    local sg = Instance.new("ScreenGui")
    sg.Name           = "_nx"..tostring(math.random(1e5, 9e5))
    sg.ResetOnSpawn   = false
    sg.ZIndexBehavior = Enum.ZIndexBehavior.Sibling
    sg.DisplayOrder   = order or 100
    sg.IgnoreGuiInset = true
    if not pcall(function()
        if syn and syn.protect_gui then syn.protect_gui(sg) end
        if gethui          then sg.Parent = gethui();          return end
        if get_hidden_gui  then sg.Parent = get_hidden_gui();  return end
        sg.Parent = CoreGui
    end) or not sg.Parent then sg.Parent = LP:WaitForChild("PlayerGui") end
    return sg
end

