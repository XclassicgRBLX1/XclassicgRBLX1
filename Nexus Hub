                local stroke=New("UIStroke",{Color=T.Accent,Thickness=1.5,Transparency=1,Parent=bg})
                local tb=New("TextBox",{
                    Size=UDim2.new(1,-28,1,0),Position=UDim2.new(0,6,0,0),
                    BackgroundTransparency=1,
                    Text=o.Default or "",
                    PlaceholderText=o.Placeholder or "Enter...",
                    PlaceholderColor3=T.Muted,
                    TextColor3=T.Text,TextSize=12,Font=Enum.Font.Gotham,
                    TextXAlignment=Enum.TextXAlignment.Left,
                    ClearTextOnFocus=o.ClearOnFocus~=false,
                    ZIndex=8,Parent=bg
                })
                local statusDot=New("Frame",{
                    Size=UDim2.new(0,7,0,7),AnchorPoint=Vector2.new(1,.5),
                    Position=UDim2.new(1,-6,.5,0),
                    BackgroundColor3=T.Muted,BackgroundTransparency=0.4,
                    BorderSizePixel=0,ZIndex=9,Parent=bg
                })
                New("UICorner",{CornerRadius=UDim.new(1,0),Parent=statusDot})

                local errLbl=New("TextLabel",{
                    Size=UDim2.new(0,140,0,12),
                    Position=UDim2.new(1,-150,1,2),
                    BackgroundTransparency=1,Text="",
                    TextColor3=T.Error,TextSize=9,Font=Enum.Font.Gotham,
                    TextXAlignment=Enum.TextXAlignment.Right,
                    ZIndex=7,Visible=false,Parent=f
                })

                tb.Focused:Connect(function()
                    TweenQ(bg,.14,{BackgroundColor3=T.TabSel})
                    TweenQ(stroke,.14,{Transparency=0})
                end)
                tb.FocusLost:Connect(function(enter)
                    TweenQ(bg,.14,{BackgroundColor3=T.Input})
                    TweenQ(stroke,.14,{Transparency=1})
                    if validate then
                        local ok,msg=validate(tb.Text)
                        if ok then
                            TweenQ(statusDot,.2,{BackgroundColor3=T.Success,BackgroundTransparency=0})
                            errLbl.Visible=false
                        else
                            TweenQ(statusDot,.2,{BackgroundColor3=T.Error,BackgroundTransparency=0})
                            errLbl.Text=msg or "Invalid"
                            errLbl.Visible=true
                            TweenQ(stroke,.1,{Color=T.Error,Transparency=0})
                            task.delay(.1,function() TweenQ(stroke,.1,{Transparency=1}) end)
                        end
                    else
                        TweenQ(statusDot,.2,{BackgroundColor3=T.Success,BackgroundTransparency=0})
                    end
                    task.spawn(cb,tb.Text,enter)
                end)
                local lockOv
                local Obj={Value=o.Default or ""}
                function Obj:Set(v) tb.Text=v;self.Value=v end
                function Obj:Get() return tb.Text end
                function Obj:SetVisible(v) f.Visible=v end
                function Obj:Lock()   if not lockOv then lockOv=LockOverlay(f) end end
                function Obj:Unlock() if lockOv then lockOv:Destroy();lockOv=nil end end
                return Obj
            end

