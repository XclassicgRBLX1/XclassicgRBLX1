                        if i.UserInputType==Enum.UserInputType.MouseButton1 then drg=true end
                    end)
                    table.insert(W._conns,UserInputService.InputChanged:Connect(function(i)
                        if drg and i.UserInputType==Enum.UserInputType.MouseMovement then
                            local ap=rail.AbsolutePosition; local as2=rail.AbsoluteSize
                            local r=clamp((i.Position.X-ap.X)/as2.X,0,1)
                            local nv=lerp(mn,mx,r); nv=step and round(nv,step) or math.floor(nv+.5); nv=clamp(nv,mn,mx)
                            if isHigh then vHigh=math.max(vLow,nv) else vLow=math.min(vHigh,nv) end
                            syncFill()
                        end
                    end))
                    table.insert(W._conns,UserInputService.InputEnded:Connect(function(i)
                        if i.UserInputType==Enum.UserInputType.MouseButton1 then drg=false end
                    end))
                end
                makeDrag(false); makeDrag(true)
                local Obj={_frame=f}
                function Obj:Get()return vLow,vHigh end
                function Obj:Set(lo,hi)vLow=clamp(lo,mn,mx);vHigh=clamp(hi,mn,mx);syncFill()end
                function Obj:SetVisible(v)f.Visible=v end
                return regE(o.Id,Obj,o.Name,f)
            end

