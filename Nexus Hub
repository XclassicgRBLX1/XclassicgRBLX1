function Nexus:CreateWindow(opts)
    opts=opts or{}
    local title=opts.Title or "NexusUI"
    local subtitle=opts.Subtitle or ""
    local winSz=opts.Size or UDim2.new(0,640,0,460)
    local toggleKey=opts.ToggleKey or Enum.KeyCode.RightShift
    local winPos=opts.Position or UDim2.new(.5,-320,.5,-230)
    local themeName=type(opts.Theme)=="string" and opts.Theme or "Dark"
    local T=(type(opts.Theme)=="table") and opts.Theme or Nexus.Themes[themeName] or Nexus.Themes.Dark

    -- Theme registry
    local themeReg={}
    local function regT(inst,prop,key) if inst and key then table.insert(themeReg,{inst=inst,prop=prop,key=key}) end end
    local function applyTheme(newT)
        T=newT
        for _,r in ipairs(themeReg) do pcall(function()
            if r.inst and r.inst.Parent and newT[r.key] then r.inst[r.prop]=newT[r.key] end
        end) end
    end

    -- Undo stack
    local undoStack,redoStack={},{}
    local function pushUndo(doFn,undoFn)
        table.insert(undoStack,{do_=doFn,undo=undoFn})
        redoStack={}
        if #undoStack>50 then table.remove(undoStack,1) end
    end

    -- ── NOTIFICATIONS — own ScreenGui, clean design ──
    local notifSG=mkGui(99900)
    local notifHolder=N("Frame",{Size=UDim2.new(0,280,1,0),Position=UDim2.new(1,-288,0,0),BackgroundTransparency=1,Parent=notifSG})
    local notifLL=N("UIListLayout",{SortOrder=Enum.SortOrder.LayoutOrder,VerticalAlignment=Enum.VerticalAlignment.Top,Padding=UDim.new(0,5),Parent=notifHolder})
    N("UIPadding",{PaddingTop=UDim.new(0,14),Parent=notifHolder})
    local notifIdx=0
    local notifLog={}

    -- Notification history panel
    local histSG=mkGui(99800)
    local histPanel=N("Frame",{Size=UDim2.new(0,268,0,0),Position=UDim2.new(1,-276,0,0),
        BackgroundColor3=T.section,BorderSizePixel=0,ClipsDescendants=true,Visible=false,ZIndex=1,Parent=histSG})
    N("UICorner",{CornerRadius=UDim.new(0,10),Parent=histPanel})
    N("UIStroke",{Color=T.border,Thickness=1,Parent=histPanel})
    regT(histPanel,"BackgroundColor3","section")
    N("TextLabel",{Size=UDim2.new(1,-24,0,20),Position=UDim2.new(0,12,0,10),BackgroundTransparency=1,
        Text="🔔  Recent Notifications",TextColor3=T.text,TextSize=12,Font=Enum.Font.GothamBold,
        TextXAlignment=Enum.TextXAlignment.Left,ZIndex=2,Parent=histPanel})
    local histScroll=N("ScrollingFrame",{Size=UDim2.new(1,-8,1,-38),Position=UDim2.new(0,4,0,36),
