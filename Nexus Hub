--  LOADING SCREEN
-- ════════════════════════════════════════════════════════════════
function Nexus:LoadingScreen(opts)
    opts = opts or {}
    local title = opts.Title or "NexusUI"
    local sub = opts.Subtitle or "Loading..."
    local tasks = opts.Tasks or {}
    local T = (type(opts.Theme) == "table") and opts.Theme or Nexus.Themes[opts.Theme] or Nexus.Themes.BlackModern
    local sg = mkGui(99999)
    local bg = N("Frame", {Size = UDim2.new(1, 0, 1, 0), BackgroundColor3 = T.bg, BorderSizePixel = 0, ZIndex = 1, Parent = sg})
    if T.glass then applyGlassEffect(bg, T) end
    local vp = getVP()
    local CW = math.min(400, vp.X - 60)
    local CH = 232 + #tasks * 26
    local card = N("Frame", {
        Size = UDim2.new(0, CW, 0, CH),
        AnchorPoint = Vector2.new(0.5, 0.5),
        Position = UDim2.new(0.5, 0, 0.54, 0),
        BackgroundColor3 = T.section,
        BackgroundTransparency = 1,
        BorderSizePixel = 0,
        ZIndex = 3,
        Parent = bg
    })
    N("UICorner", {CornerRadius = UDim.new(0, 10), Parent = card})
    if T.glass then
        applyGlassEffect(card, T)
    elseif T.neo then
        applyNeumorphismEffect(card, T, false, bg)
    else
        N("UIStroke", {Color = T.border, Thickness = 1, Transparency = 0.2, Parent = card})
    end
    local topStripe = N("Frame", {Size = UDim2.new(0, 0, 0, 2), BackgroundColor3 = T.accent, BorderSizePixel = 0, ZIndex = 4, Parent = card})
    N("UICorner", {CornerRadius = UDim.new(0, 2), Parent = topStripe})
    local shimmer = N("Frame", {
        Size = UDim2.new(0, 80, 1, 0),
        Position = UDim2.new(-0.3, 0, 0, 0),
        BackgroundColor3 = T.accentH,
        BackgroundTransparency = 0.4,
        BorderSizePixel = 0,
        ZIndex = 5,
        Parent = topStripe
    })
    N("UIGradient", {
        Transparency = NumberSequence.new({
            NumberSequenceKeypoint.new(0, 1),
            NumberSequenceKeypoint.new(0.4, 0.3),
            NumberSequenceKeypoint.new(0.6, 0.3),
            NumberSequenceKeypoint.new(1, 1)
        }),
        Rotation = 0,
        Parent = shimmer
    })
    tw(card, 0.45, {BackgroundTransparency = 0, Position = UDim2.new(0.5, 0, 0.5, 0)})
    local y = 26
    N("TextLabel", {
        Size = UDim2.new(1, -32, 0, 28),
        Position = UDim2.new(0, 16, 0, y),
        BackgroundTransparency = 1,
        Text = title,
        TextColor3 = T.text,
        TextSize = 22,
        Font = Enum.Font.GothamBold,
        ZIndex = 4,
        Parent = card
    }); y = y + 34
    local subLbl = N("TextLabel", {
        Size = UDim2.new(1, -32, 0, 16),
        Position = UDim2.new(0, 16, 0, y),
        BackgroundTransparency = 1,
        Text = sub,
        TextColor3 = T.sub,
        TextSize = 12,
        Font = Enum.Font.Gotham,
        ZIndex = 4,
        Parent = card
    }); y = y + 24
    local checks = {}
