        })
        rT(page,"ScrollBarImageColor3","scroll")
        local pageLL = N("UIListLayout",{SortOrder=Enum.SortOrder.LayoutOrder,
            Padding=UDim.new(0,9), Parent=page})
        N("UIPadding",{PaddingTop=UDim.new(0,10), PaddingLeft=UDim.new(0,11),
            PaddingRight=UDim.new(0,13), PaddingBottom=UDim.new(0,16), Parent=page})

        -- *** CRITICAL: Always sync canvas after any layout change ***
        local function syncCanvas()
            page.CanvasSize = UDim2.new(0,0,0, pageLL.AbsoluteContentSize.Y + 28)
        end
        pageLL:GetPropertyChangedSignal("AbsoluteContentSize"):Connect(syncCanvas)
        pageOuter:GetPropertyChangedSignal("Visible"):Connect(function()
            if pageOuter.Visible then task.defer(syncCanvas) end
        end)

        -- Per-tab element list (for in-page search)
        local pageSections = {}
        psBox:GetPropertyChangedSignal("Text"):Connect(function()
            local q = psBox.Text:lower()
            for _,sec in ipairs(pageSections) do
                for _,el in ipairs(sec._elems) do
                    if el._frame and el._sn then
                        el._frame.Visible = q=="" or el._sn:lower():find(q,1,true)~=nil
                    end
                end
