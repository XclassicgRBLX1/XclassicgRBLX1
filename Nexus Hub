                    Font=Enum.Font.GothamBold,ZIndex=9,Parent=bg}); rT(ntb,"TextColor3","text")
                local function sv(v)
                    val=clamp(v,mn,mx); ntb.Text=tostring(val)
                    if o.Callback then task.spawn(o.Callback,val) end
                end
                mb.MouseButton1Click:Connect(function()sv(val-step)end)
                pb.MouseButton1Click:Connect(function()sv(val+step)end)
                ntb.FocusLost:Connect(function()local n=tonumber(ntb.Text);if n then sv(n) else ntb.Text=tostring(val) end end)
