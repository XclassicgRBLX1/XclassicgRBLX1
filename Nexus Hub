                        BorderSizePixel=0,ZIndex=9,Parent=rail})
                    N("UICorner",{CornerRadius=UDim.new(1,0),Parent=kn})
                    N("UIStroke",{Color=T.accent,Thickness=2,Parent=kn})
                    return kn
                end
                local knL=mkKnob(pctOf(vLow)); local knH=mkKnob(pctOf(vHigh))
                local function syncFill()
                    local pl=pctOf(vLow); local ph=pctOf(vHigh)
                    tw(activeF,.04,{Position=UDim2.new(pl,0,0,0),Size=UDim2.new(ph-pl,0,1,0)})
                    tw(knL,.04,{Position=UDim2.new(pl,0,.5,0)})
                    tw(knH,.04,{Position=UDim2.new(ph,0,.5,0)})
                    rangeLbl.Text=tostring(vLow)..suf.." ‚Äď "..tostring(vHigh)..suf
                    if o.Callback then task.spawn(o.Callback,vLow,vHigh) end
                end
                local function makeDrag(isHigh)
                    local drg=false
