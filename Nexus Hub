            -- ═══ v7.0: GRAPH ══════════════════════════════════════
            -- sec:AddGraph({Name, Type="Line"|"Bar", Height=80,
            --   Data={}, Max=100, Min=0, Color, MaxPoints=40})
            -- Returns: :Push(v) :SetData(t) :Clear() :Get()
            function Sec:AddGraph(o)
                o = o or {}
                local gType  = o.Type      or "Line"
                local gH     = o.Height    or 80
                local gColor = o.Color     or T.accent
                local gMax   = o.Max       or 100
                local gMin   = o.Min       or 0
                local maxPts = o.MaxPoints or 40
                local gFill  = o.Fill ~= false
                local data   = {}
                for _,v in ipairs(o.Data or {}) do table.insert(data,v) end

                local f = ef(gH + 26)
                mL(f, o.Name or "Graph", 8)

                -- Value pill
                local vPill = N("Frame",{Size=UDim2.new(0,52,0,18),
                    Position=UDim2.new(1,-56,0,5),BackgroundColor3=gColor,
                    BackgroundTransparency=.82,BorderSizePixel=0,ZIndex=7,Parent=f})
                N("UICorner",{CornerRadius=UDim.new(1,0),Parent=vPill})
                N("UIStroke",{Color=gColor,Thickness=1,Transparency=.5,Parent=vPill})
                local vLbl = N("TextLabel",{Size=UDim2.new(1,0,1,0),BackgroundTransparency=1,
                    Text="",TextColor3=gColor,TextSize=10,Font=Enum.Font.GothamBold,ZIndex=8,Parent=vPill})

                -- Graph area
                local area = N("Frame",{Size=UDim2.new(1,-14,0,gH),Position=UDim2.new(0,7,0,24),
                    BackgroundColor3=T.border,BackgroundTransparency=.75,BorderSizePixel=0,
                    ClipsDescendants=true,ZIndex=6,Parent=f})
                N("UICorner",{CornerRadius=UDim.new(0,5),Parent=area})
                N("UIStroke",{Color=T.border,Thickness=1,Transparency=.4,Parent=area})

                -- Pool for segment/bar frames
                local segPool  = sharedPool("Frame")
                local segments = {}

                local function redraw()
                    for _,s in ipairs(segments) do segPool:release(s) end
                    segments = {}
                    if #data == 0 then vLbl.Text = "—"; return end
                    local range = math.max(gMax - gMin, 0.001)
                    local n     = #data
                    vLbl.Text   = tostring(math.floor(data[n]))

                    if gType == "Bar" then
                        local bw = 1 / n
                        for i,v in ipairs(data) do
                            local pct = clamp((v - gMin) / range, 0, 1)
                            local bar = segPool:get({
                                AnchorPoint        = Vector2.new(0,1),
                                Size               = UDim2.new(bw,-2,0,math.max(1,math.floor(pct*(gH-4)))),
                                Position           = UDim2.new((i-1)*bw,1,1,0),
                                BackgroundColor3   = gColor,
                                BackgroundTransparency = 0,
                                BorderSizePixel    = 0,
                                ZIndex             = 7,
                                Parent             = area,
                            })
                            N("UICorner",{CornerRadius=UDim.new(0,2),Parent=bar})
                            table.insert(segments, bar)
                        end
                    else -- Line
                        if n < 2 then return end
                        local aW = math.max(area.AbsoluteSize.X, 1)
                        local aH = math.max(gH, 1)
                        for i = 1, n-1 do
                            local p1x = (i-1)/(n-1)
                            local p1y = 1 - clamp((data[i]   - gMin)/range, 0, 1)
                            local p2x =  i  /(n-1)
                            local p2y = 1 - clamp((data[i+1] - gMin)/range, 0, 1)
                            local dx  = (p2x - p1x)*aW
                            local dy  = (p2y - p1y)*aH
                            local len = math.sqrt(dx*dx + dy*dy)
                            if len < 0.5 then continue end
                            local ang = math.deg(math.atan2(dy, dx))
                            local seg = segPool:get({
                                AnchorPoint        = Vector2.new(0,.5),
                                Size               = UDim2.new(0,len,0,2),
                                Position           = UDim2.new(p1x,0,p1y,0),
                                BackgroundColor3   = gColor,
                                BackgroundTransparency = 0,
                                BorderSizePixel    = 0,
                                Rotation           = ang,
                                ZIndex             = 7,
                                Parent             = area,
                            })
                            table.insert(segments, seg)
                            if gFill and dy > 0 then
                                local fh = math.max(1, math.floor(math.abs(dy)))
                                local fseg = segPool:get({
                                    AnchorPoint        = Vector2.new(0,0),
                                    Size               = UDim2.new(0,math.max(1,math.floor(math.abs(dx))),0,fh),
                                    Position           = UDim2.new(p1x,0,math.max(p1y,p2y),0),
                                    BackgroundColor3   = gColor,
                                    BackgroundTransparency = .72,
                                    BorderSizePixel    = 0,
                                    ZIndex             = 6,
                                    Parent             = area,
                                })
                                table.insert(segments, fseg)
                            end
                        end
                    end
                end

                task.defer(redraw)
                area:GetPropertyChangedSignal("AbsoluteSize"):Connect(redraw)

                local Obj = {_frame = f}
                function Obj:Push(v)
                    table.insert(data, v)
                    while #data > maxPts do table.remove(data,1) end
                    redraw()
                end
                function Obj:SetData(t)
                    data = {}
                    for _,v in ipairs(t) do table.insert(data,v) end
                    redraw()
                end
                function Obj:Clear()  data = {}; redraw() end
                function Obj:Get()    return data end
                function Obj:SetVisible(v) f.Visible = v end
                function Obj:DependsOn(other,cond) depFn(self,other,cond) end
                return regE(o.Id, Obj, o.Name, f)
            end

            -- ═══ v7.0: VIRTUALIZED LIST ═══════════════════════════
            -- sec:AddList({Name, Items={}, MaxVisible=6, ItemHeight=28,
            --   MultiSelect, Callback, SearchPlaceholder})
            -- Returns: :Set(items) :Get() :Refresh() :Clear()
            function Sec:AddList(o)
                o = o or {}
                local items      = o.Items     or {}
                local maxVis     = o.MaxVisible or 6
                local iH         = o.ItemHeight or 28
                local multiSel   = o.MultiSelect == true
                local selected   = {}
                local scrollTop  = 0
                local filtered   = {}
                local nameOffset = o.Name and 22 or 0
                local totalH     = maxVis * iH + 32 + nameOffset

                local f = ef(totalH)
                if o.Name then mL(f, o.Name, 8) end
                addTip(f, o.Tooltip)

                -- Search bar
                local sBg = N("Frame",{
                    Size=UDim2.new(1,-14,0,24),
                    Position=UDim2.new(0,7,0,nameOffset+4),
                    BackgroundColor3=T.input,BackgroundTransparency=.2,
                    BorderSizePixel=0,ZIndex=7,Parent=f})
                N("UICorner",{CornerRadius=UDim.new(0,5),Parent=sBg})
                N("UIStroke",{Color=T.border,Thickness=1,Parent=sBg}); rT(sBg,"BackgroundColor3","input")
                N("TextLabel",{Size=UDim2.new(0,14,1,0),Position=UDim2.new(0,6,0,0),
                    BackgroundTransparency=1,Text="⌕",TextColor3=T.muted,TextSize=11,
                    Font=Enum.Font.GothamBold,ZIndex=8,Parent=sBg})
                local sBox = N("TextBox",{Size=UDim2.new(1,-20,1,0),Position=UDim2.new(0,18,0,0),
                    BackgroundTransparency=1,Text="",
                    PlaceholderText=o.SearchPlaceholder or "Filter...",
                    PlaceholderColor3=T.muted,TextColor3=T.text,TextSize=11,Font=Enum.Font.Gotham,
                    TextXAlignment=Enum.TextXAlignment.Left,ClearTextOnFocus=false,ZIndex=9,Parent=sBg})
                rT(sBox,"TextColor3","text")

                -- Viewport (clips rows)
                local viewport = N("Frame",{
                    Size=UDim2.new(1,-14,0,maxVis*iH),
                    Position=UDim2.new(0,7,0,nameOffset+32),
                    BackgroundTransparency=1,ClipsDescendants=true,ZIndex=6,Parent=f})

                -- Row pool (shared)
                local rowPool = sharedPool("TextButton")
                local rows    = {}

                local function rebuild()
                    for _,r in ipairs(rows) do rowPool:release(r) end
                    rows = {}
                    local visN = math.min(maxVis, math.max(0, #filtered - scrollTop))
                    for i = 1, visN do
                        local idx  = scrollTop + i
                        local item = filtered[idx]; if not item then break end
                        local sel  = table.find(selected, item) ~= nil
                        local row  = rowPool:get({
                            Size               = UDim2.new(1,0,0,iH-2),
                            Position           = UDim2.new(0,0,0,(i-1)*iH),
                            BackgroundColor3   = sel and T.accentD or T.elem,
                            BackgroundTransparency = sel and .2 or .55,
                            Text               = "",
                            AutoButtonColor    = false,
                            ZIndex             = 7,
                            Parent             = viewport,
                        })
                        N("UICorner",{CornerRadius=UDim.new(0,4),Parent=row})
                        if sel then
                            N("TextLabel",{Size=UDim2.new(0,14,1,0),Position=UDim2.new(0,5,0,0),
                                BackgroundTransparency=1,Text="✓",TextColor3=T.accent,
                                TextSize=10,Font=Enum.Font.GothamBold,ZIndex=8,Parent=row})
                        end
                        N("TextLabel",{
                            Size=UDim2.new(1,sel and -20 or -10,1,0),
                            Position=UDim2.new(0,sel and 20 or 9,0,0),
                            BackgroundTransparency=1,Text=tostring(item),
                            TextColor3=sel and T.text or T.sub,TextSize=11,
                            Font=sel and Enum.Font.GothamSemibold or Enum.Font.Gotham,
                            TextXAlignment=Enum.TextXAlignment.Left,ZIndex=8,Parent=row})
                        row.MouseEnter:Connect(function()
                            if not table.find(selected,item) then tw(row,.07,{BackgroundTransparency=.3}) end
                        end)
                        row.MouseLeave:Connect(function()
                            tw(row,.07,{BackgroundTransparency=table.find(selected,item) and .2 or .55})
                        end)
                        row.MouseButton1Click:Connect(function()
                            if multiSel then
                                local si = table.find(selected,item)
                                if si then table.remove(selected,si) else table.insert(selected,item) end
                            else
                                selected = {item}
                            end
                            rebuild()
                            if o.Callback then
                                task.spawn(o.Callback, multiSel and selected or selected[1], idx)
                            end
                        end)
                        table.insert(rows, row)
                    end
                end

                -- Scroll controls
                local ctrlY = nameOffset + 32 + maxVis*iH + 2
                local ctrl  = N("Frame",{Size=UDim2.new(1,-14,0,20),Position=UDim2.new(0,7,0,ctrlY),
                    BackgroundTransparency=1,ZIndex=6,Parent=f})
                local upBtn = N("TextButton",{Size=UDim2.new(0,26,0,20),BackgroundColor3=T.elem,
                    BackgroundTransparency=.4,Text="▲",TextColor3=T.sub,TextSize=10,
                    Font=Enum.Font.GothamBold,AutoButtonColor=false,ZIndex=7,Parent=ctrl})
                N("UICorner",{CornerRadius=UDim.new(0,4),Parent=upBtn})
                local dnBtn = N("TextButton",{Size=UDim2.new(0,26,0,20),Position=UDim2.new(0,30,0,0),
                    BackgroundColor3=T.elem,BackgroundTransparency=.4,Text="▼",TextColor3=T.sub,
                    TextSize=10,Font=Enum.Font.GothamBold,AutoButtonColor=false,ZIndex=7,Parent=ctrl})
                N("UICorner",{CornerRadius=UDim.new(0,4),Parent=dnBtn})
                local cntLbl = N("TextLabel",{Size=UDim2.new(1,-62,0,20),Position=UDim2.new(0,60,0,0),
                    BackgroundTransparency=1,Text="",TextColor3=T.muted,TextSize=10,
                    Font=Enum.Font.Gotham,TextXAlignment=Enum.TextXAlignment.Left,ZIndex=7,Parent=ctrl})

                local function applyFilter()
                    local q = sBox.Text:lower()
                    filtered = {}
                    for _,it in ipairs(items) do
                        if q == "" or tostring(it):lower():find(q,1,true) then
                            table.insert(filtered, it)
                        end
                    end
                    scrollTop = 0; rebuild()
                    cntLbl.Text = #filtered .. " / " .. #items
                end

                upBtn.MouseButton1Click:Connect(function()
                    if scrollTop > 0 then scrollTop -= 1; rebuild() end
                end)
                dnBtn.MouseButton1Click:Connect(function()
                    if scrollTop + maxVis < #filtered then scrollTop += 1; rebuild() end
                end)
                sBox:GetPropertyChangedSignal("Text"):Connect(applyFilter)
                applyFilter()

                local Obj = {_frame = f}
                function Obj:Set(t)  items = t; applyFilter() end
                function Obj:Get()   return multiSel and selected or selected[1] end
                function Obj:Refresh() applyFilter() end
                function Obj:Clear() selected = {}; rebuild() end
                function Obj:SetVisible(v) f.Visible = v end
                function Obj:DependsOn(other,cond) depFn(self,other,cond) end
                return regE(o.Id, Obj, o.Name, f)
            end

            -- Section lock
            function Sec:Lock(message)
                local lock=N("Frame",{Size=UDim2.new(1,0,1,0),BackgroundColor3=Color3.fromRGB(0,0,0),
                    BackgroundTransparency=.48,BorderSizePixel=0,ZIndex=50,Parent=secContent})
                N("UICorner",{CornerRadius=UDim.new(0,CR_EL),Parent=lock})
                N("TextLabel",{Size=UDim2.new(1,0,1,0),BackgroundTransparency=1,
                    Text="🔒  "..(message or "Locked"),TextColor3=Color3.fromRGB(255,255,255),
                    TextSize=13,Font=Enum.Font.GothamBold,ZIndex=51,Parent=lock})
                return function()pcall(function()lock:Destroy()end)end
            end

            return Sec
        end -- AddSection
        return Tab
    end -- AddTab

