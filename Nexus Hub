--  GUI MOUNT
-- ────────────────────────────────────────────────────────
local function mkGui(order)
    local sg=Instance.new("ScreenGui")
    sg.Name="_nx"..tostring(math.random(1e5,9e5))
    sg.ResetOnSpawn=false
    sg.ZIndexBehavior=Enum.ZIndexBehavior.Sibling
    sg.DisplayOrder=order or 100
    sg.IgnoreGuiInset=true
    local function mount()
        if syn and syn.protect_gui then syn.protect_gui(sg) end
        if gethui then sg.Parent=gethui();return end
        if get_hidden_gui then sg.Parent=get_hidden_gui();return end
        sg.Parent=CoreGui
    end
    if not pcall(mount) or not sg.Parent then
        sg.Parent=LP:WaitForChild("PlayerGui")
    end
    return sg
end

-- ────────────────────────────────────────────────────────
--  RESPONSIVE UISCALE
-- ────────────────────────────────────────────────────────
local function applyScale(sg)
    local sc=N("UIScale",{Scale=1,Parent=sg})
    local conn
    local function upd()
        local cam=workspace.CurrentCamera
        local vp=(cam and cam.ViewportSize) or Vector2.new(1280,720)
        sc.Scale=clamp(math.min(vp.X/1280,vp.Y/720),0.45,1.0)
    end
    local function watch()
        if conn then pcall(function()conn:Disconnect()end) end
        if workspace.CurrentCamera then
            conn=workspace.CurrentCamera:GetPropertyChangedSignal("ViewportSize"):Connect(upd)
        end
    end
    watch();upd()
    workspace:GetPropertyChangedSignal("CurrentCamera"):Connect(function() watch();upd() end)
    return sc
end

