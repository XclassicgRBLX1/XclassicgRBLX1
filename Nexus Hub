        local ind = N("Frame",{Size=UDim2.new(0,3,0,18), Position=UDim2.new(0,1,.5,-9),
            BackgroundColor3=T.accent, BackgroundTransparency=1, BorderSizePixel=0, ZIndex=7, Parent=tabBtn})
        N("UICorner",{CornerRadius=UDim.new(0,2), Parent=ind}); rT(ind,"BackgroundColor3","accent")
