local SoundManager = {enabled = true, volume = 0.3}

function SoundManager:Play(soundType)
    if not self.enabled then return end
    local sounds = {
        Hover = "rbxassetid://9113760607",
        Click = "rbxassetid://9113760438",
        Success = "rbxassetid://9113759898",
        Error = "rbxassetid://9113759560",
        Open = "rbxassetid://9114120044",
        Close = "rbxassetid://9114119736",
        Notification = "rbxassetid://9113973884",
        ToggleOn = "rbxassetid://9113981552",
        ToggleOff = "rbxassetid://9113981151",
    }
    local id = sounds[soundType]
    if id then
        local sound = Instance.new("Sound")
        sound.SoundId = id
        sound.Volume = self.volume
        sound.Parent = game:GetService("SoundService")
        sound:Play()
        game:GetService("Debris"):AddItem(sound, sound.TimeLength + 0.1)
    end
end

