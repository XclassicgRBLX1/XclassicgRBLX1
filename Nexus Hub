        rT(valLbl,"TextColor3","accent")

        -- Track
        local slY=32
        local slTrack=N("Frame",{Size=UDim2.new(1,-24,0,4),Position=UDim2.new(0,12,0,slY),BackgroundColor3=T.border,BorderSizePixel=0,ZIndex=4,Parent=el})
        N("UICorner",{CornerRadius=UDim.new(1,0),Parent=slTrack})
        rT(slTrack,"BackgroundColor3","border")
        local slFill=N("Frame",{Size=UDim2.new(0,0,1,0),BackgroundColor3=T.accent,BorderSizePixel=0,ZIndex=5,Parent=slTrack})
        N("UICorner",{CornerRadius=UDim.new(1,0),Parent=slFill})
        rT(slFill,"BackgroundColor3","accent")
        -- Knob
        local slKnob=N("Frame",{Size=UDim2.new(0,14,0,14),AnchorPoint=Vector2.new(.5,.5),BackgroundColor3=Color3.fromRGB(255,255,255),BorderSizePixel=0,ZIndex=6,Parent=slTrack})
        N("UICorner",{CornerRadius=UDim.new(1,0),Parent=slKnob})
        -- Knob glow
        local knobGlow=N("ImageLabel",{Size=UDim2.new(0,26,0,26),AnchorPoint=Vector2.new(.5,.5),BackgroundTransparency=1,Image="rbxassetid://317956639",ImageColor3=T.accent,ImageTransparency=.7,ZIndex=5,Parent=slKnob})
        rT(knobGlow,"ImageColor3","accent")

        local sliding=false
        local function setVal(v)
            v=clamp(v,min,max)
            local pct=(v-min)/(max-min)
            tw(slFill,.1,{Size=UDim2.new(pct,0,1,0)})
            slKnob.Position=UDim2.new(pct,0,.5,0)
            valLbl.Text=fmt(v)
            return v
        end
        setVal(def)

        slTrack.InputBegan:Connect(function(i)
            if i.UserInputType==Enum.UserInputType.MouseButton1 or i.UserInputType==Enum.UserInputType.Touch then sliding=true end
        end)
        table.insert(W._conns,UserInputService.InputEnded:Connect(function(i)
            if i.UserInputType==Enum.UserInputType.MouseButton1 or i.UserInputType==Enum.UserInputType.Touch then
                if sliding then sliding=false end
            end
        end))
        table.insert(W._conns,UserInputService.InputChanged:Connect(function(i)
            if not sliding then return end
            if i.UserInputType==Enum.UserInputType.MouseMovement or i.UserInputType==Enum.UserInputType.Touch then
                local relX=clamp((i.Position.X-slTrack.AbsolutePosition.X)/slTrack.AbsoluteSize.X,0,1)
                local v=min+relX*(max-min)
                setVal(v)
                cb(v)
            end
        end))

        el.MouseEnter:Connect(function() tw(el,.08,{BackgroundColor3=T.elemHov}) end)
        el.MouseLeave:Connect(function() tw(el,.08,{BackgroundColor3=T.elem}) end)
        if tip then el.MouseEnter:Connect(function() showTip(tip) end); el.MouseLeave:Connect(hideTip) end

        return {Set=function(v) setVal(v);cb(v) end,Get=function() return clamp(def,min,max) end,Frame=el}
    end

