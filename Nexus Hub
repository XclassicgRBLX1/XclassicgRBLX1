        local hexLbl=N("TextLabel",{Size=UDim2.new(0,36,1,0),Position=UDim2.new(1,-10,0,0),BackgroundTransparency=1,Text=hexc(def),TextColor3=T.sub,TextSize=9,Font=Enum.Font.Code,TextXAlignment=Enum.TextXAlignment.Right,ZIndex=4,Parent=el})
        rT(hexLbl,"TextColor3","sub")

        -- Picker overlay
        local pickerOv=N("Frame",{Size=UDim2.new(1,0,1,0),BackgroundColor3=Color3.fromRGB(0,0,0),BackgroundTransparency=.6,BorderSizePixel=0,Visible=false,ZIndex=100,Parent=sg})
        local pickerCard=N("Frame",{Size=UDim2.new(0,260,0,0),AnchorPoint=Vector2.new(.5,.5),Position=UDim2.new(.5,0,.5,0),BackgroundColor3=T.section,BorderSizePixel=0,ClipsDescendants=true,ZIndex=101,Parent=pickerOv})
        N("UICorner",{CornerRadius=UDim.new(0,CR_S),Parent=pickerCard})
        N("UIStroke",{Color=T.border,Thickness=1,Parent=pickerCard})
        rT(pickerCard,"BackgroundColor3","section")
        N("Frame",{Size=UDim2.new(1,0,0,2),BackgroundColor3=T.accent,BorderSizePixel=0,ZIndex=102,Parent=pickerCard})

        -- SV Box (200x120)
        local svBox=N("Frame",{Size=UDim2.new(0,200,0,120),Position=UDim2.new(0,12,0,14),BackgroundColor3=def,BorderSizePixel=0,ClipsDescendants=true,ZIndex=103,Parent=pickerCard})
        N("UICorner",{CornerRadius=UDim.new(0,4),Parent=svBox})
        -- White gradient (left to right)
        N("Frame",{Size=UDim2.new(1,0,1,0),BackgroundColor3=Color3.fromRGB(255,255,255),BackgroundTransparency=0,BorderSizePixel=0,ZIndex=104,Parent=svBox})
        N("UIGradient",{Color=ColorSequence.new(Color3.fromRGB(255,255,255),Color3.new(0,0,0)),Rotation=0,Parent=svBox:FindFirstChildOfClass("Frame")})
        -- Black gradient (top to bottom)
        N("Frame",{Size=UDim2.new(1,0,1,0),BackgroundColor3=Color3.fromRGB(0,0,0),BackgroundTransparency=0,BorderSizePixel=0,ZIndex=105,Parent=svBox})
        N("UIGradient",{Color=ColorSequence.new(Color3.fromRGB(0,0,0),Color3.new(0,0,0)),Rotation=90,Transparency=NumberSequence.new{NumberSequenceKeypoint.new(0,1),NumberSequenceKeypoint.new(1,0)},Parent=svBox:FindFirstChildOfClass("Frame",true)})

        -- SV cursor
        local svCur=N("Frame",{Size=UDim2.new(0,10,0,10),AnchorPoint=Vector2.new(.5,.5),Position=UDim2.new(.5,0,.5,0),BackgroundColor3=Color3.fromRGB(255,255,255),BorderSizePixel=0,ZIndex=108,Parent=svBox})
        N("UICorner",{CornerRadius=UDim.new(1,0),Parent=svCur})
        N("UIStroke",{Color=Color3.fromRGB(0,0,0),Thickness=1,Parent=svCur})

        -- Hue bar
        local hueBar=N("Frame",{Size=UDim2.new(0,200,0,14),Position=UDim2.new(0,12,0,142),BackgroundColor3=Color3.fromRGB(255,0,0),BorderSizePixel=0,ClipsDescendants=true,ZIndex=103,Parent=pickerCard})
        N("UICorner",{CornerRadius=UDim.new(0,4),Parent=hueBar})
        N("UIGradient",{Color=ColorSequence.new{ColorSequenceKeypoint.new(0,Color3.fromRGB(255,0,0)),ColorSequenceKeypoint.new(.167,Color3.fromRGB(255,255,0)),ColorSequenceKeypoint.new(.333,Color3.fromRGB(0,255,0)),ColorSequenceKeypoint.new(.5,Color3.fromRGB(0,255,255)),ColorSequenceKeypoint.new(.667,Color3.fromRGB(0,0,255)),ColorSequenceKeypoint.new(.833,Color3.fromRGB(255,0,255)),ColorSequenceKeypoint.new(1,Color3.fromRGB(255,0,0))},Parent=hueBar})
        local hueCur=N("Frame",{Size=UDim2.new(0,6,0,18),AnchorPoint=Vector2.new(.5,.5),Position=UDim2.new(0,0,.5,0),BackgroundColor3=Color3.fromRGB(255,255,255),BorderSizePixel=0,ZIndex=106,Parent=hueBar})
        N("UICorner",{CornerRadius=UDim.new(0,2),Parent=hueCur})
        N("UIStroke",{Color=Color3.fromRGB(0,0,0),Thickness=1,Parent=hueCur})

        -- Hex input
        local hexIn=N("TextBox",{Size=UDim2.new(0,100,0,24),Position=UDim2.new(0,12,0,164),BackgroundColor3=T.input,BorderSizePixel=0,Text=hexc(def),PlaceholderText="#FFFFFF",PlaceholderColor3=T.muted,TextColor3=T.text,TextSize=11,Font=Enum.Font.Code,ClearTextOnFocus=false,ZIndex=104,Parent=pickerCard})
        N("UICorner",{CornerRadius=UDim.new(0,4),Parent=hexIn})
        N("UIStroke",{Color=T.border,Thickness=1,Parent=hexIn})
        rT(hexIn,"BackgroundColor3","input"); rT(hexIn,"TextColor3","text")

        -- Close btn
        N("TextButton",{Size=UDim2.new(0,20,0,20),Position=UDim2.new(1,-24,0,12),BackgroundTransparency=1,Text="‚úē",TextColor3=T.sub,TextSize=11,Font=Enum.Font.GothamBold,ZIndex=105,Parent=pickerCard}).MouseButton1Click:Connect(function()
            pickerOv.Visible=false
        end)

        local curH,curS,curV=rgb2hsv(def)
        local svDragging,hueDragging=false

        local function updateColor()
            local c=hsv2rgb(curH,curS,curV)
            preview.BackgroundColor3=c
            hexLbl.Text=hexc(c)
            hexIn.Text=hexc(c)
            svBox.BackgroundColor3=hsv2rgb(curH,1,1)
            cb(c)
        end

        local function updateSVCursor()
            svCur.Position=UDim2.new(curS,0,1-curV,0)
        end
        local function updateHueCursor()
            hueCur.Position=UDim2.new(curH,0,.5,0)
        end

        svBox.InputBegan:Connect(function(i)
            if i.UserInputType==Enum.UserInputType.MouseButton1 then svDragging=true end
        end)
        hueBar.InputBegan:Connect(function(i)
            if i.UserInputType==Enum.UserInputType.MouseButton1 then hueDragging=true end
        end)
        table.insert(W._conns,UserInputService.InputEnded:Connect(function(i)
            if i.UserInputType==Enum.UserInputType.MouseButton1 then svDragging=false; hueDragging=false end
        end))
        table.insert(W._conns,UserInputService.InputChanged:Connect(function(i)
            if svDragging and (i.UserInputType==Enum.UserInputType.MouseMovement or i.UserInputType==Enum.UserInputType.Touch) then
                local rx=clamp((i.Position.X-svBox.AbsolutePosition.X)/svBox.AbsoluteSize.X,0,1)
                local ry=clamp((i.Position.Y-svBox.AbsolutePosition.Y)/svBox.AbsoluteSize.Y,0,1)
                curS=rx; curV=1-ry
                updateSVCursor()
                updateColor()
            end
            if hueDragging and (i.UserInputType==Enum.UserInputType.MouseMovement or i.UserInputType==Enum.UserInputType.Touch) then
                local rx=clamp((i.Position.X-hueBar.AbsolutePosition.X)/hueBar.AbsoluteSize.X,0,1)
                curH=rx
                updateHueCursor()
                updateColor()
            end
        end))

        hexIn.FocusLost:Connect(function()
            local txt=hexIn.Text:gsub("#","")
            if #txt==6 then
                local r=tonumber(txt:sub(1,2),16) or 255
                local g=tonumber(txt:sub(3,4),16) or 255
                local b=tonumber(txt:sub(5,6),16) or 255
                curH,curS,curV=rgb2hsv(Color3.fromRGB(r,g,b))
                updateSVCursor()
                updateHueCursor()
                updateColor()
            end
        end)

        el.InputBegan:Connect(function(i)
            if i.UserInputType==Enum.UserInputType.MouseButton1 then
                pickerOv.Visible=true
                pickerCard.Size=UDim2.new(0,224,0,0)
                tw(pickerCard,.15,{Size=UDim2.new(0,224,0,196)})
                updateSVCursor()
                updateHueCursor()
                updateColor()
            end
        end)
        pickerOv.InputBegan:Connect(function(i)
if i.UserInputType==Enum.UserInputType.MouseButton1 and i.Target~=svBox and i.Target~=hueBar and i.Target~=hexIn and i.Target~=pickerCard and not pickerCard:IsAncestorOf(i.Target) then
                pickerOv.Visible=false
            end
        end)

        el.MouseEnter:Connect(function() tw(el,.08,{BackgroundColor3=T.elemHov}) end)
        el.MouseLeave:Connect(function() tw(el,.08,{BackgroundColor3=T.elem}) end)
        if tip then el.MouseEnter:Connect(function() showTip(tip) end); el.MouseLeave:Connect(hideTip) end

        return {Set=function(c3) curH,curS,curV=rgb2hsv(c3); updateSVCursor(); updateHueCursor(); updateColor() end,Get=function() return hsv2rgb(curH,curS,curV) end,Frame=el}
    end

    -- PROGRESS RING
    function W:ProgressRing(opts,sec)
        opts=opts or {}
        local label=opts.Title or opts.Text or "Progress"
        local def=opts.Default or 0
        local maxV=opts.Max or 100
        local color=opts.Color or T.accent
        local tip=opts.Tooltip
        local parent=(sec and sec._content) or (W.ActiveTab and W.ActiveTab._scroll)
        if not parent then return {} end

        local el=N("Frame",{Size=UDim2.new(1,0,0,EH),BackgroundColor3=T.elem,BorderSizePixel=0,ZIndex=2,Parent=parent})
        el:SetAttribute("TargetH",EH)
        N("UICorner",{CornerRadius=UDim.new(0,CR_E),Parent=el})
        rT(el,"BackgroundColor3","elem")
        staggerIn(el)

        N("TextLabel",{Size=UDim2.new(0,100,1,0),Position=UDim2.new(0,10,0,0),BackgroundTransparency=1,Text=label,TextColor3=T.text,TextSize=12,Font=Enum.Font.Gotham,TextXAlignment=Enum.TextXAlignment.Left,ZIndex=3,Parent=el})
        rT(el:FindFirstChildOfClass("TextLabel"),"TextColor3","text")

        -- Ring using circular frames
        local ringSize=26
        local ringOuter=N("Frame",{Size=UDim2.new(0,ringSize,0,ringSize),AnchorPoint=Vector2.new(1,.5),Position=UDim2.new(1,-50,.5,0),BackgroundColor3=T.border,BorderSizePixel=0,ZIndex=4,Parent=el})
        N("UICorner",{CornerRadius=UDim.new(1,0),Parent=ringOuter})
        rT(ringOuter,"BackgroundColor3","border")
        local ringInner=N("Frame",{Size=UDim2.new(0,ringSize-6,0,ringSize-6),AnchorPoint=Vector2.new(.5,.5),Position=UDim2.new(.5,0,.5,0),BackgroundColor3=T.elem,BorderSizePixel=0,ZIndex=5,Parent=ringOuter})
        N("UICorner",{CornerRadius=UDim.new(1,0),Parent=ringInner})
        rT(ringInner,"BackgroundColor3","elem")
        local ringPct=N("TextLabel",{Size=UDim2.new(1,0,1,0),BackgroundTransparency=1,Text=math.floor(def/maxV*100).."%",TextColor3=color,TextSize=8,Font=Enum.Font.GothamBold,ZIndex=6,Parent=ringOuter})

        -- Percentage label on right
        local pctLbl=N("TextLabel",{Size=UDim2.new(0,40,1,0),Position=UDim2.new(1,-10,0,0),BackgroundTransparency=1,Text=math.floor(def/maxV*100).."%",TextColor3=T.sub,TextSize=10,Font=Enum.Font.GothamBold,TextXAlignment=Enum.TextXAlignment.Right,ZIndex=4,Parent=el})
        rT(pctLbl,"TextColor3","sub")

        local function update(v)
            v=clamp(v,0,maxV)
            local pct=v/maxV
            local thick=math.floor(pct*ringSize/2)
            ringOuter.BackgroundColor3=color
            ringInner.Size=UDim2.new(0,math.max(2,ringSize-6-thick*2),0,math.max(2,ringSize-6-thick*2))
            ringPct.Text=math.floor(pct*100).."%"
            ringPct.TextColor3=color
            pctLbl.Text=math.floor(pct*100).."%"
        end
        update(def)

        el.MouseEnter:Connect(function() tw(el,.08,{BackgroundColor3=T.elemHov}) end)
        el.MouseLeave:Connect(function() tw(el,.08,{BackgroundColor3=T.elem}) end)
        if tip then el.MouseEnter:Connect(function() showTip(tip) end); el.MouseLeave:Connect(hideTip) end

        return {Set=function(v) update(v) end,Get=function() return def end,Frame=el}
    end

    -- SEPARATOR
    function W:Separator(sec)
        local parent=(sec and sec._content) or (W.ActiveTab and W.ActiveTab._scroll)
        if not parent then return {} end
        local el=N("Frame",{Size=UDim2.new(1,0,0,8),BackgroundColor3=Color3.fromRGB(0,0,0),BackgroundTransparency=1,BorderSizePixel=0,ZIndex=2,Parent=parent})
        el:SetAttribute("TargetH",8)
        staggerIn(el)
        N("Frame",{Size=UDim2.new(1,-20,0,1),Position=UDim2.new(0,10,.5,0),BackgroundColor3=T.border,BackgroundTransparency=.3,BorderSizePixel=0,ZIndex=3,Parent=el})
        return {Frame=el}
    end

    -- CHIP (small inline tag)
    function W:Chip(opts,sec)
        opts=opts or {}
        local text=opts.Title or opts.Text or "Chip"
        local color=opts.Color or T.accentD
        local parent=(sec and sec._content) or (W.ActiveTab and W.ActiveTab._scroll)
        if not parent then return {} end
        local el=N("Frame",{Size=UDim2.new(0,0,0,20),BackgroundColor3=color,BorderSizePixel=0,ZIndex=2,Parent=parent})
