    -- Sidebar
    local sidebar=N("Frame",{Size=UDim2.new(0,144,1,-46),Position=UDim2.new(0,0,0,46),
        BackgroundColor3=T.sidebar,BorderSizePixel=0,ZIndex=4,Parent=main})
    regT(sidebar,"BackgroundColor3","sidebar")
    N("Frame",{Size=UDim2.new(0,1,1,0),Position=UDim2.new(1,0,0,0),
