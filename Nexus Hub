                N("UIStroke",{Color=T.border,Thickness=1,Parent=bg}); rT(bg,"BackgroundColor3","input")
                local mb=N("TextButton",{Size=UDim2.new(0,28,1,0),BackgroundColor3=T.elem,BackgroundTransparency=.3,
                    Text="─",TextColor3=T.sub,TextSize=13,Font=Enum.Font.GothamBold,AutoButtonColor=false,ZIndex=8,Parent=bg})
                N("UICorner",{CornerRadius=UDim.new(0,CR_EL),Parent=mb})
                local pb=N("TextButton",{Size=UDim2.new(0,28,1,0),Position=UDim2.new(1,-28,0,0),
                    BackgroundColor3=T.elem,BackgroundTransparency=.3,Text="+",TextColor3=T.sub,TextSize=14,
