        tw(barFill,.3,{Size=UDim2.new(clamp(f,0,1),0,1,0)})
        tw(topS,.3,{Size=UDim2.new(clamp(f,0,1),0,0,2)})
        pctL.Text=math.floor(clamp(f,0,1)*100).."%"
        if l then curL.Text=l end
    end
    function Loader:Run(cb)
        task.wait(.35)
        if #tasks==0 then
            for i=0,10 do setP(i/10,"Initializing...");task.wait(.05) end
        else
            for i,tk in ipairs(tasks) do
                setP((i-1)/#tasks,tk.Name or "...")
                if checks[i] then
                    tw(checks[i].dot,.15,{BackgroundColor3=T.accent})
                    tw(checks[i].lbl,.15,{TextColor3=T.text})
                end
                task.wait(tk.Duration or .35)
                setP(i/#tasks)
                if checks[i] then
                    checks[i].dot.BackgroundColor3=T.success
                    checks[i].lbl.Text="‚úď  "..(tk.Name or "")
                    checks[i].lbl.TextColor3=T.sub
                end
            end
        end
        setP(1,"Ready!")
        curL.TextColor3=T.success
        task.wait(.35)
        sc2:Disconnect()
        twI(card,.28,{BackgroundTransparency=1,Position=UDim2.new(.5,0,.45,0)})
        twI(bg,.38,{BackgroundTransparency=1})
        task.wait(.4)
        pcall(function() sg:Destroy() end)
        if cb then task.spawn(cb) end
    end
    function Loader:SetStatus(t) subLbl.Text=t end
    function Loader:SetTask(t) curL.Text=t end
    function Loader:SetProgress(f) setP(f) end
    return Loader
end

