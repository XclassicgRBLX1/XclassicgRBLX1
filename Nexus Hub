        T=nT
        isGlass=T._glass==true; isNeu=T._neu==true
        glassBG=T._glassBG or .28; glassSec=T._glassSec or .38; glassEl=T._glassElem or .48
        for _,r in ipairs(reg) do pcall(function()
            if r.i and r.i.Parent and nT[r.k] then r.i[r.p]=nT[r.k] end
        end) end
    end

    local uStk,rStk={},{}
