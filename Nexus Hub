        local hdr=N("Frame",{Size=UDim2.new(1,0,0,28),BackgroundColor3=Color3.fromRGB(0,0,0),BackgroundTransparency=1,BorderSizePixel=0,ZIndex=3,Parent=sec})
        -- Accent left pill
        N("Frame",{Size=UDim2.new(0,3,0,14),Position=UDim2.new(0,8,.5,-7),BackgroundColor3=T.accent,BorderSizePixel=0,ZIndex=4,Parent=hdr})
        rT(hdr:FindFirstChildOfClass("Frame"),"BackgroundColor3","accent")
        -- Title
        N("TextLabel",{Size=UDim2.new(0,200,1,0),Position=UDim2.new(0,16,0,0),BackgroundTransparency=1,Text=(icon~="" and icon.."  " or "")..title,TextColor3=T.text,TextSize=11,Font=Enum.Font.GothamBold,TextXAlignment=Enum.TextXAlignment.Left,ZIndex=5,Parent=hdr})
        rT(hdr:FindFirstChildOfClass("TextLabel"),"TextColor3","text")
        -- Arrow
        local arrow=N("TextLabel",{Size=UDim2.new(0,16,1,0),Position=UDim2.new(1,-20,0,0),BackgroundTransparency=1,Text="‚Ėľ",TextColor3=T.muted,TextSize=8,Font=Enum.Font.GothamBold,ZIndex=5,Parent=hdr})
        rT(arrow,"TextColor3","muted")

        -- Content container
        local content=N("Frame",{Size=UDim2.new(1,0,0,0),BackgroundColor3=Color3.fromRGB(0,0,0),BackgroundTransparency=1,ClipsDescendants=true,ZIndex=2,Parent=sec})
        local cLL=N("UIListLayout",{SortOrder=Enum.SortOrder.LayoutOrder,Padding=UDim.new(0,3),Parent=content})
