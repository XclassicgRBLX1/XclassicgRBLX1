        rT(kbLbl,"TextColor3","accent")

        local binding=false
        local currentKey=def

        el.InputBegan:Connect(function(i)
            if i.UserInputType==Enum.UserInputType.MouseButton1 or i.UserInputType==Enum.UserInputType.Touch then
                binding=true
                kbLbl.Text="..."
                tw(kbBg,.1,{BackgroundColor3=T.accentD})
                tw(kbLbl,.1,{TextColor3=Color3.fromRGB(255,255,255)})
            end
        end)

        local kbConn
        kbConn=UserInputService.InputBegan:Connect(function(i,processed)
            if not binding then return end
            if processed then return end
            if i.KeyCode==Enum.KeyCode.Escape then
                binding=false
                kbLbl.Text=currentKey and currentKey.Name or "None"
                tw(kbBg,.1,{BackgroundColor3=T.input})
                tw(kbLbl,.1,{TextColor3=T.accent})
                return
            end
            if i.KeyCode and i.KeyCode~=Enum.KeyCode.Unknown then
