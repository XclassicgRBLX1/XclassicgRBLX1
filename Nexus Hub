    -- HOTBAR BUTTON
    function W:HotbarButton(opts)
        opts=opts or {}
        local label=opts.Title or opts.Text or "Btn"
        local cb=opts.Callback or function() end
        local icon=opts.Icon or ""
        local b=N("TextButton",{Size=UDim2.new(0,0,0,26),BackgroundColor3=T.elem,BackgroundTransparency=.4,Text=(icon~="" and icon.." " or "")..label,TextColor3=T.sub,TextSize=10,Font=Enum.Font.GothamSemibold,AutoButtonColor=false,ZIndex=12,Parent=hotbarF})
        N("UICorner",{CornerRadius=UDim.new(0,5),Parent=b})
        N("UIStroke",{Color=T.border,Thickness=1,Transparency=.3,Parent=b})
        rT(b,"BackgroundColor3","elem"); rT(b,"TextColor3","sub")
        task.defer(function()
            local w=TextService:GetTextSize(b.Text,10,Enum.Font.GothamSemibold,Vector2.new(9999,9999)).X+20
            tw(b,.12,{Size=UDim2.new(0,w,0,26)})
        end)
        b.MouseEnter:Connect(function() tw(b,.08,{BackgroundTransparency=0,BackgroundColor3=T.accent,TextColor3=Color3.fromRGB(0,0,0)}) end)
        b.MouseLeave:Connect(function() tw(b,.08,{BackgroundTransparency=.4,BackgroundColor3=T.elem,TextColor3=T.sub}) end)
        b.MouseButton1Click:Connect(cb)
        hotbarF.Visible=true
        return {Frame=b}
    end

    -- REGISTER KEYBIND
    function W:RegisterKeybind(keyName,keyCode,action)
        table.insert(W._keybinds,{name=keyName,key=keyCode,action=action})
        -- Add to keybind overlay
        local row=N("Frame",{Size=UDim2.new(1,0,0,20),BackgroundColor3=Color3.fromRGB(0,0,0),BackgroundTransparency=1,ZIndex=3,Parent=kbList})
        N("TextLabel",{Size=UDim2.new(.6,0,1,0),Position=UDim2.new(0,0,0,0),BackgroundTransparency=1,Text=keyName,TextColor3=T.sub,TextSize=10,Font=Enum.Font.Gotham,TextXAlignment=Enum.TextXAlignment.Left,ZIndex=4,Parent=row})
        N("TextLabel",{Size=UDim2.new(.4,0,1,0),Position=UDim2.new(.6,0,0,0),BackgroundTransparency=1,Text=keyCode.Name,TextColor3=T.accent,TextSize=10,Font=Enum.Font.GothamBold,TextXAlignment=Enum.TextXAlignment.Right,ZIndex=4,Parent=row})
        table.insert(W._conns,UserInputService.InputBegan:Connect(function(i,processed)
            if processed then return end
            if i.KeyCode==keyCode then action() end
        end))
        -- Resize overlay
        task.defer(function()
            local h=kbLL.AbsoluteContentSize.Y+60
            tw(kbCard,.15,{Size=UDim2.new(0,380,0,h)})
        end)
    end

    -- AUTO-EXEC SECTION BUILDER
    function W:AutoExec(opts,tab)
        opts=opts or {}
        local cb=opts.Callback or function() end
        local interval=opts.Interval or 0
        if interval>0 then
            local conn
            conn=RunService.Heartbeat:Connect(function()
                cb()
                task.wait(interval)
            end)
            table.insert(W._conns,conn)
        else
            task.spawn(cb)
        end
    end

    -- DESTROY
    function W:Destroy()
        for _,c in ipairs(W._conns) do pcall(function() c:Disconnect() end) end
        if statConn then pcall(function() statConn:Disconnect() end) end
        pcall(function() sg:Destroy() end)
        pcall(function() notifSG:Destroy() end)
        pcall(function() histSG:Destroy() end)
        pcall(function() ctxSG:Destroy() end)
        pcall(function() cmdSG:Destroy() end)
        pcall(function() tipSG:Destroy() end)
    end

    return W
end

return Nexus
