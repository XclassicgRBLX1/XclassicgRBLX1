                return regE(o.Id,Obj,o.Name or o.Text,f)
            end

            -- DIVIDER
            function Sec:Divider(label)
                local f=N("Frame",{Size=UDim2.new(1,-12,0,label and 16 or 1),BackgroundTransparency=1,ZIndex=5,Parent=secContent})
                N("Frame",{Size=UDim2.new(1,0,0,1),Position=UDim2.new(0,0,.5,0),BackgroundColor3=T.border,BackgroundTransparency=.25,BorderSizePixel=0,ZIndex=6,Parent=f})
                if label then
                    local w2=TextService:GetTextSize(label,9,Enum.Font.Gotham,Vector2.new(9999,9999)).X+10
                    local bg2=N("Frame",{Size=UDim2.new(0,w2,1,0),AnchorPoint=Vector2.new(.5,.5),Position=UDim2.new(.5,0,.5,0),BackgroundColor3=T.section,BorderSizePixel=0,ZIndex=7,Parent=f})
                    rT(bg2,"BackgroundColor3","section")
                    N("TextLabel",{Size=UDim2.new(1,0,1,0),BackgroundTransparency=1,Text=label,TextColor3=T.muted,TextSize=9,Font=Enum.Font.GothamBold,ZIndex=8,Parent=bg2})
                end
            end

            -- Section lock
            function Sec:Lock(message)
                local lock=N("Frame",{Size=UDim2.new(1,0,1,0),BackgroundColor3=Color3.fromRGB(0,0,0),
                    BackgroundTransparency=.48,BorderSizePixel=0,ZIndex=50,Parent=secContent})
                N("UICorner",{CornerRadius=UDim.new(0,CR_EL),Parent=lock})
                N("TextLabel",{Size=UDim2.new(1,0,1,0),BackgroundTransparency=1,
                    Text="ūüĒí "..(message or "Locked"),TextColor3=Color3.fromRGB(255,255,255),
                    TextSize=13,Font=Enum.Font.GothamBold,ZIndex=51,Parent=lock})
                return function()pcall(function()lock:Destroy()end)end
            end

            return Sec
        end
        return Tab
    end

    -- Console Tab
    function W:AddConsoleTab()
        local tab=self:AddTab({Name="Console",Icon=">"})
        local sec=tab:AddSection({Name="LOG OUTPUT"})
        local logs={}
        local function addLog(msg,col)
            local lbl=sec:AddLabel({Text=msg,Color=col or T.sub})
            table.insert(logs,lbl)
            if #logs>50 then logs[1]:SetVisible(false);table.remove(logs,1) end
        end
        local old=print
        print=function(...)
            old(...)
            local parts={};for _,v in ipairs({...}) do table.insert(parts,tostring(v)) end
            pcall(function()addLog("‚Äļ "..table.concat(parts,"  "),T.sub)end)
        end
        local cs=tab:AddSection({})
        cs:AddButton({Name="Clear Console",Callback=function()for _,l in ipairs(logs)do l:SetVisible(false)end;logs={}end})
        cs:AddButton({Name="Test Log",Callback=function()print("NexusUI v7.0 | "..os.date("%X"))end})
        return tab
    end

    -- Binds Tab
    function W:AddBindsTab()
        local bt=self:AddTab({Name="Keybinds",Icon="‚Ć®"})
        local bs=bt:AddSection({Name="KEYBINDS"})
        if #W._keybinds==0 then bs:AddLabel({Text="No keybinds registered.",Color=T.muted})
        else for _,b in ipairs(W._keybinds) do bs:AddLabel({Text="‚Äļ "..b.Name.." ‚ÄĒ "..(b.Ref.key==Enum.KeyCode.Unknown and "None" or b.Ref.key.Name),Color=T.sub})end end
        bs:Divider("Window Controls")
        bs:AddLabel({Text="‚Äļ Toggle UI ‚ÄĒ "..togKey.Name,Color=T.muted})
        bs:AddLabel({Text="‚Äļ Ctrl+Z ‚ÄĒ Undo ¬∑ Ctrl+Y ‚ÄĒ Redo",Color=T.muted})
        bs:AddButton({Name="Show Keybind Overlay",Callback=function()W:ShowBinds()end})
        return bt
    end

    return W
end

