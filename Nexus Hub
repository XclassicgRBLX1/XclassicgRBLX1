    function W:AddConsoleTab()
        local tab=self:AddTab({Name="Console",Icon=">"})
        local sec=tab:AddSection({Name="LOG OUTPUT"})
        local logs={}
        local function addLog(msg,col)
            local lbl=sec:AddLabel({Text=msg,Color=col or T.sub})
            table.insert(logs,lbl)
            if #logs>50 then logs[1]:SetVisible(false);table.remove(logs,1) end
        end
        local old=print
        print=function(...)
            old(...)
            local parts={};for _,v in ipairs({...}) do table.insert(parts,tostring(v)) end
            pcall(function()addLog("‚Äļ "..table.concat(parts,"  "),T.sub)end)
        end
        local cs=tab:AddSection({})
        cs:AddButtonRow({Buttons={
            {Name="Clear",Callback=function()for _,l in ipairs(logs)do l:SetVisible(false)end;logs={}end},
            {Name="Test",Callback=function()print("NexusUI v6.1-BM",math.random(1000))end},
        }})
        return tab
    end

