--  SPRING PHYSICS ENGINE
--  handle = Nexus:Spring(obj, targetProps, cfg)
--  cfg: {k=200, d=20, mass=1, precision=0.005, onSettle, onUpdate}
--  handle: :SetTarget(props)  :Stop()  :Pause()  :Resume()
-- ════════════════════════════════════════════════════════════════
local _springs   = {}
local _springHB  = nil
local function _ensureSpringLoop()
    if _springHB then return end
    _springHB = RunService.Heartbeat:Connect(function(dt)
        dt = math.min(dt, 0.05)
        local done = {}
        for id, s in pairs(_springs) do
            if s.paused then continue end
            local settled = true
            for _, state in pairs(s.states) do
                local a = (-s.k*(state.pos-state.target) - s.d*state.vel) / s.mass
                state.vel = state.vel + a*dt
                state.pos = state.pos + state.vel*dt
                if math.abs(state.vel) > s.prec or math.abs(state.pos-state.target) > s.prec then
                    settled = false
                else
                    state.pos = state.target; state.vel = 0
                end
            end
            if s.obj and s.obj.Parent then
                for prop, state in pairs(s.states) do
                    pcall(function() s.obj[prop] = state.pos end)
                end
                if s.onUpdate then pcall(s.onUpdate, s.obj) end
            end
            if settled then
                table.insert(done, id)
                if s.onSettle then pcall(s.onSettle, s.obj) end
            end
        end
        for _,id in ipairs(done) do _springs[id] = nil end
    end)
end

function Nexus:Spring(obj, targetProps, cfg)
    cfg = cfg or {}
    local id = tostring(obj) .. tostring(tick())
    local states = {}
    for prop, target in pairs(targetProps) do
        local cur = 0; pcall(function() cur = obj[prop] end)
        states[prop] = {pos=cur, vel=0, target=target}
    end
    _springs[id] = {
        obj=obj, states=states,
        k    = cfg.k     or 220,
        d    = cfg.d     or 22,
        mass = cfg.mass  or 1,
        prec = cfg.precision or 0.005,
        paused   = false,
        onSettle = cfg.onSettle,
        onUpdate = cfg.onUpdate,
    }
    _ensureSpringLoop()
    local handle = {}
    function handle:SetTarget(p)
        if not _springs[id] then return end
        for prop, v in pairs(p) do
            if _springs[id].states[prop] then
                _springs[id].states[prop].target = v
            else
                local cur = 0; pcall(function() cur = obj[prop] end)
                _springs[id].states[prop] = {pos=cur, vel=0, target=v}
            end
        end
    end
    function handle:Stop()   _springs[id] = nil end
    function handle:Pause()  if _springs[id] then _springs[id].paused = true  end end
    function handle:Resume() if _springs[id] then _springs[id].paused = false end end
    function handle:IsActive() return _springs[id] ~= nil end
    return handle
end

-- ════════════════════════════════════════════════════════════════
--  TWEEN SEQUENCER  — chain tweens with callbacks
--  W:Sequence({{obj,time,props,style?,dir?},...}, onDone?)
-- ════════════════════════════════════════════════════════════════
local function _runSeq(steps, idx, onDone)
    if not steps[idx] then if onDone then task.spawn(onDone) end return end
    local s = steps[idx]
    if not (s.obj and s.obj.Parent) then _runSeq(steps, idx+1, onDone); return end
    local t = TweenService:Create(s.obj,
        TweenInfo.new(s.time or .25,
            s.style or Enum.EasingStyle.Quart,
            s.dir   or Enum.EasingDirection.Out), s.props)
    t.Completed:Connect(function() _runSeq(steps, idx+1, onDone) end)
    t:Play()
end

