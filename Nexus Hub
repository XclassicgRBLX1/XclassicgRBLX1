        N("UICorner",{CornerRadius=UDim.new(1,0),Parent=el})
        local lbl=N("TextLabel",{Size=UDim2.new(1,0,1,0),BackgroundTransparency=1,Text=text,TextColor3=T.text,TextSize=9,Font=Enum.Font.GothamSemibold,ZIndex=3,Parent=el})
