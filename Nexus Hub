local function tw(obj, time, props, opts)
    opts = opts or {}
    if not (obj and obj.Parent) then return nil end
    local style = opts.style or Enum.EasingStyle.Quart
    local dir = opts.dir or Enum.EasingDirection.Out
    local spring = opts.spring
    if spring then
        local info = TweenInfo.new(
            time,
            Enum.EasingStyle.Linear,
            Enum.EasingDirection.Out,
            opts.repeats or 0,
            opts.reverses or false,
            spring.damping or 0.7,
            spring.speed or 10
        )
        local tween = TweenService:Create(obj, info, props)
        if opts.onComplete then tween.Completed:Connect(opts.onComplete) end
        tween:Play()
        return tween
    else
        local tween = TweenService:Create(
            obj,
            TweenInfo.new(time, style, dir, opts.repeats or 0, opts.reverses or false),
            props
        )
        if opts.onComplete then tween.Completed:Connect(opts.onComplete) end
        if opts.onProgress then
            local conn
            conn = RunService.Heartbeat:Connect(function()
                if opts.onProgress(tween.TimePosition / time) == false then
                    conn:Disconnect()
                    tween:Cancel()
                end
            end)
            tween.Completed:Connect(function() conn:Disconnect() end)
        end
        tween:Play()
        return tween
    end
end

local function twI(o, t, p) tw(o, t, p, {style = Enum.EasingStyle.Quart, dir = Enum.EasingDirection.In}) end
local function twL(o, t, p) tw(o, t, p, {style = Enum.EasingStyle.Linear}) end
local function twSpring(o, t, p, damping, speed)
    tw(o, t, p, {spring = {damping = damping or 0.7, speed = speed or 10}})
end

local function N(c, p)
    local o = Instance.new(c)
    for k, v in pairs(p) do
        if k ~= "Parent" then o[k] = v end
    end
    if p.Parent then o.Parent = p.Parent end
    return o
end

local function clamp(v, a, b) return math.max(a, math.min(b, v)) end
local function lerp(a, b, t) return a + (b - a) * t end
local function round(v, s) s = s or 1; return math.floor(v / s + 0.5) * s end
local function hexc(c) return string.format("%02X%02X%02X", c.R * 255, c.G * 255, c.B * 255) end
local function getVP()
    return (workspace.CurrentCamera and workspace.CurrentCamera.ViewportSize) or Vector2.new(1280, 720)
end

local function mkGui(order)
    local sg = Instance.new("ScreenGui")
    sg.Name = "_nx" .. tostring(math.random(1e5, 9e5))
    sg.ResetOnSpawn = false
    sg.ZIndexBehavior = Enum.ZIndexBehavior.Sibling
    sg.DisplayOrder = order or 100
    sg.IgnoreGuiInset = true
    pcall(function()
        if syn and syn.protect_gui then syn.protect_gui(sg) end
        if gethui then sg.Parent = gethui(); return end
        if get_hidden_gui then sg.Parent = get_hidden_gui(); return end
        sg.Parent = CoreGui
    end)
    if not sg.Parent then sg.Parent = LP:WaitForChild("PlayerGui") end
    return sg
end

