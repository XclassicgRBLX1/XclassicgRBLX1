        local badge = N("Frame",{Size=UDim2.new(0,17,0,17), Position=UDim2.new(1,-21,.5,-8.5),
            BackgroundColor3=T.error, BorderSizePixel=0, Visible=false, ZIndex=8, Parent=tabBtn})
        N("UICorner",{CornerRadius=UDim.new(1,0), Parent=badge}); rT(badge,"BackgroundColor3","error")
        local badgeLbl = N("TextLabel",{Size=UDim2.new(1,0,1,0), BackgroundTransparency=1, Text="0",
            TextColor3=Color3.fromRGB(255,255,255), TextSize=9, Font=Enum.Font.GothamBold, ZIndex=9, Parent=badge})

        -- ── PAGE SETUP ─────────────────────────────────────────────
        local pageOuter = N("Frame",{Size=UDim2.new(1,0,1,0), BackgroundTransparency=1,
            Visible=false, ZIndex=3, Parent=pageCon})

        -- In-page search bar (at top)
        local psBg = N("Frame",{Size=UDim2.new(1,-22,0,32), Position=UDim2.new(0,11,0,8),
            BackgroundColor3=T.input, BackgroundTransparency=.35, BorderSizePixel=0, ZIndex=4, Parent=pageOuter})
        N("UICorner",{CornerRadius=UDim.new(0,9), Parent=psBg})
        N("UIStroke",{Color=T.border, Thickness=1, Parent=psBg}); rT(psBg,"BackgroundColor3","input")
        N("TextLabel",{Size=UDim2.new(0,18,1,0), Position=UDim2.new(0,8,0,0), BackgroundTransparency=1,
