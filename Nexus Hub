function Nexus:LoadingScreen(opts)
    opts = opts or {}
    local title    = opts.Title    or "NexusUI"
    local sub      = opts.Subtitle or "Loading, please wait..."
    local logo     = opts.Logo     -- rbxassetid string, optional
    local tasks    = opts.Tasks    or {}
    local T        = (type(opts.Theme)=="table") and opts.Theme
                     or Nexus.Themes[opts.Theme] or Nexus.Themes.Dark
    local showList = opts.ShowTaskList ~= false  -- show task checklist by default

    local sg = MakeGui(99999)

    -- ── Full backdrop ──────────────────────────
    local bg = New("Frame",{
        Size=UDim2.new(1,0,1,0), BackgroundColor3=T.LoadBg,
        BorderSizePixel=0, ZIndex=1, Parent=sg
    })

    -- ── Scanlines overlay ──────────────────────
    local scanHolder = New("Frame",{
        Size=UDim2.new(1,0,1,0), BackgroundTransparency=1,
        ZIndex=2, Parent=bg
    })
    for i=1, 60 do
        New("Frame",{
            Size=UDim2.new(1,0,0,1),
            Position=UDim2.new(0,0,0,(i-1)*17),
            BackgroundColor3=Color3.fromRGB(255,255,255),
            BackgroundTransparency=0.97,
            BorderSizePixel=0, ZIndex=2, Parent=scanHolder
        })
    end

    -- ── Ambient glow orbs ─────────────────────
    local function Orb(x,y,size,color,alpha)
        New("ImageLabel",{
            Size=UDim2.new(0,size,0,size),
            Position=UDim2.new(x,-size/2,y,-size/2),
            BackgroundTransparency=1,
            Image="rbxassetid://6014261993",
            ImageColor3=color, ImageTransparency=alpha or 0.88,
            ZIndex=2, Parent=bg
        })
    end
    Orb(0.25,0.35, 600, T.Accent, 0.90)
    Orb(0.78,0.65, 500, T.AccentGlow, 0.92)
    Orb(0.10,0.80, 350, T.Success, 0.95)

    -- ── Animated grid dots ────────────────────
    local gridH = New("Frame",{
        Size=UDim2.new(1,0,1,0),BackgroundTransparency=1,ZIndex=2,Parent=bg
    })
    local gridDots = {}
    for row=0,12 do
        for col=0,20 do
            local d = New("Frame",{
                Size=UDim2.new(0,2,0,2),
                Position=UDim2.new(col/20,0,row/12,0),
                BackgroundColor3=T.Accent,
                BackgroundTransparency=0.92,
                BorderSizePixel=0, ZIndex=2, Parent=gridH
            })
            New("UICorner",{CornerRadius=UDim.new(1,0),Parent=d})
            table.insert(gridDots,d)
        end
    end

    -- ── Center card ────────────────────────────
    local cardW = showList and (#tasks > 0) and 400 or 360
    local card = New("Frame",{
        Size=UDim2.new(0,cardW,0,10),
        AnchorPoint=Vector2.new(.5,.5),
        Position=UDim2.new(.5,0,.5,.03),
        BackgroundColor3=T.Section,
        BackgroundTransparency=0.04,
        BorderSizePixel=0, ZIndex=3, Parent=bg
    })
    New("UICorner",{CornerRadius=UDim.new(0,16),Parent=card})
    New("UIStroke",{Color=T.Accent,Thickness=1,Transparency=0.55,Parent=card})

    -- Gradient shimmer border
    local gradFrame = New("ImageLabel",{
        Size=UDim2.new(1,0,1,0),
        BackgroundTransparency=1,
        Image="rbxassetid://5028857084",
        ImageColor3=T.Accent,
        ImageTransparency=0.7,
        ZIndex=2, Parent=card
    })

    local cardLayout = New("UIListLayout",{
        SortOrder=Enum.SortOrder.LayoutOrder,
        HorizontalAlignment=Enum.HorizontalAlignment.Center,
        Padding=UDim.new(0,0), Parent=card
    })
    New("UIPadding",{
        PaddingTop=UDim.new(0,28),PaddingBottom=UDim.new(0,22),
        PaddingLeft=UDim.new(0,24),PaddingRight=UDim.new(0,24),
        Parent=card
    })

    -- Logo
    if logo then
        local logoF = New("Frame",{
            Size=UDim2.new(1,0,0,64),BackgroundTransparency=1,
            LayoutOrder=0, ZIndex=4, Parent=card
        })
        local logoImg = New("ImageLabel",{
            Size=UDim2.new(0,56,0,56),AnchorPoint=Vector2.new(.5,.5),
            Position=UDim2.new(.5,0,.5,0),
            BackgroundTransparency=1,Image=logo,
            ZIndex=5,Parent=logoF
        })
        -- Logo glow pulse
        task.spawn(function()
            while logoImg and logoImg.Parent do
                TweenQ(logoImg,.9,{ImageTransparency=0.15})
                task.wait(.95)
                TweenQ(logoImg,.9,{ImageTransparency=0})
                task.wait(.95)
            end
        end)
    end

    -- Title
    local titleF = New("Frame",{
        Size=UDim2.new(1,0,0,30),BackgroundTransparency=1,
        LayoutOrder=1, ZIndex=4, Parent=card
    })
    local titleLbl = New("TextLabel",{
        Size=UDim2.new(1,0,1,0),BackgroundTransparency=1,
        Text=title, TextColor3=T.Text,
        TextSize=24, Font=Enum.Font.GothamBold,
        TextTransparency=1, ZIndex=5, Parent=titleF
    })

    -- Subtitle
    local subF = New("Frame",{
        Size=UDim2.new(1,0,0,16),BackgroundTransparency=1,
        LayoutOrder=2,ZIndex=4,Parent=card
    })
    local subLbl = New("TextLabel",{
        Size=UDim2.new(1,0,1,0),BackgroundTransparency=1,
        Text=sub,TextColor3=T.SubText,TextSize=12,
        Font=Enum.Font.Gotham,TextTransparency=1,
        ZIndex=5,Parent=subF
    })

    -- Spacer
    New("Frame",{Size=UDim2.new(1,0,0,14),BackgroundTransparency=1,LayoutOrder=3,Parent=card})

    -- Task checklist (shown before progress bar if tasks provided)
    local taskChecks = {}
    if showList and #tasks > 0 then
        local listF = New("Frame",{
            Size=UDim2.new(1,0,0,#tasks*22+4),
            BackgroundTransparency=1, LayoutOrder=4, ZIndex=4, Parent=card
        })
        for i,tk in ipairs(tasks) do
            local row = New("Frame",{
                Size=UDim2.new(1,0,0,20),
                Position=UDim2.new(0,0,0,(i-1)*22),
                BackgroundTransparency=1, ZIndex=4, Parent=listF
            })
            local dot = New("Frame",{
                Size=UDim2.new(0,7,0,7),AnchorPoint=Vector2.new(0,.5),
                Position=UDim2.new(0,0,.5,0),
                BackgroundColor3=T.Muted,BorderSizePixel=0,
                ZIndex=5, Parent=row
            })
            New("UICorner",{CornerRadius=UDim.new(1,0),Parent=dot})
            local rowLbl = New("TextLabel",{
                Size=UDim2.new(1,-22,1,0),Position=UDim2.new(0,16,0,0),
                BackgroundTransparency=1,
                Text=tk.Name or ("Task "..i),
                TextColor3=T.Muted, TextSize=11, Font=Enum.Font.Gotham,
                TextXAlignment=Enum.TextXAlignment.Left,
                ZIndex=5, Parent=row
