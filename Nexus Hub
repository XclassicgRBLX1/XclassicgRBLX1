            -- ‚ēź‚ēź NEW: CODE BLOCK ‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź
            function Sec:AddCodeBlock(o)
                o=o or{}
                local code=o.Code or "-- Your code here"
                local lines=#code:split("\n")
                local h=math.min(lines*14+20,140)
                local f=N("Frame",{Size=UDim2.new(1,0,0,h),BackgroundColor3=Color3.fromRGB(5,5,8),
                    BackgroundTransparency=.1,BorderSizePixel=0,ZIndex=5,Parent=secContent})
                N("UICorner",{CornerRadius=UDim.new(0,CR_EL),Parent=f})
                N("UIStroke",{Color=T.border,Thickness=1,Transparency=.2,Parent=f})
                -- Language label
                if o.Language then
                    local langLbl=N("TextLabel",{Size=UDim2.new(0,0,0,16),AnchorPoint=Vector2.new(1,0),
                        Position=UDim2.new(1,-6,0,4),BackgroundTransparency=1,
                        Text=o.Language:upper(),TextColor3=T.accent,TextSize=8,
                        Font=Enum.Font.GothamBold,TextXAlignment=Enum.TextXAlignment.Right,ZIndex=7,Parent=f})
                    local lw=TextService:GetTextSize(o.Language:upper(),8,Enum.Font.GothamBold,Vector2.new(999,999)).X
                    langLbl.Size=UDim2.new(0,lw,0,16)
                end
                -- Copy button
                local copyBtn=N("TextButton",{Size=UDim2.new(0,40,0,16),AnchorPoint=Vector2.new(1,0),
                    Position=UDim2.new(1,-6,1,-20),BackgroundColor3=T.elem,BackgroundTransparency=.3,
                    Text="Copy",TextColor3=T.sub,TextSize=9,Font=Enum.Font.GothamSemibold,
                    AutoButtonColor=false,ZIndex=7,Parent=f})
                N("UICorner",{CornerRadius=UDim.new(0,4),Parent=copyBtn})
                copyBtn.MouseButton1Click:Connect(function()
                    if setclipboard then setclipboard(code) end
                    copyBtn.Text="‚úď"; task.delay(1.5,function()copyBtn.Text="Copy"end)
                end)
                local sc2=N("ScrollingFrame",{Size=UDim2.new(1,-8,1,-8),Position=UDim2.new(0,4,0,4),
                    BackgroundTransparency=1,BorderSizePixel=0,ScrollBarThickness=2,
                    ScrollBarImageColor3=T.muted,CanvasSize=UDim2.new(0,0,0,0),ZIndex=6,Parent=f})
                local codeLbl=N("TextLabel",{Size=UDim2.new(1,0,0,0),BackgroundTransparency=1,
                    Text=code,TextColor3=Color3.fromRGB(180,230,180),TextSize=11,Font=Enum.Font.Code,
                    TextXAlignment=Enum.TextXAlignment.Left,TextYAlignment=Enum.TextYAlignment.Top,
                    TextWrapped=false,ZIndex=7,Parent=sc2})
                codeLbl:GetPropertyChangedSignal("TextBounds"):Connect(function()
                    codeLbl.Size=UDim2.new(1,0,0,codeLbl.TextBounds.Y)
                    sc2.CanvasSize=UDim2.new(0,codeLbl.TextBounds.X+8,0,codeLbl.TextBounds.Y+8)
                end)
                local Obj={_frame=f}
                function Obj:Set(v)codeLbl.Text=v;code=v end
                function Obj:Get()return code end; function Obj:SetVisible(v)f.Visible=v end
                return regE(o.Id,Obj,o.Name,f)
            end

            -- ‚ēź‚ēź Section Lock ‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź
            function Sec:Lock(message)
                local lock=N("Frame",{Size=UDim2.new(1,0,1,0),BackgroundColor3=Color3.fromRGB(0,0,0),
                    BackgroundTransparency=.46,BorderSizePixel=0,ZIndex=50,Parent=secContent})
                N("UICorner",{CornerRadius=UDim.new(0,CR_EL),Parent=lock})
                N("TextLabel",{Size=UDim2.new(1,0,1,0),BackgroundTransparency=1,
                    Text="ūüĒí  "..(message or "Locked"),TextColor3=Color3.fromRGB(255,255,255),
                    TextSize=13,Font=Enum.Font.GothamBold,ZIndex=51,Parent=lock})
                return function()pcall(function()lock:Destroy()end)end
            end

            return Sec
        end -- AddSection
        return Tab
    end -- AddTab

    -- ‚ĒÄ‚ĒÄ Console tab ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ
    function W:AddConsoleTab()
        local tab=self:AddTab({Name="Console",Icon=">"})
        local sec=tab:AddSection({Name="LOG OUTPUT"})
        local logs={}
        local function addLog(msg,col)
            local lbl=sec:AddLabel({Text=msg,Color=col or T.sub})
            table.insert(logs,lbl)
            if #logs>60 then logs[1]:SetVisible(false);table.remove(logs,1) end
        end
        local old=print
        print=function(...)
            old(...)
            local parts={};for _,v in ipairs({...}) do table.insert(parts,tostring(v)) end
            pcall(function()addLog("‚Äļ "..table.concat(parts,"  "),T.sub)end)
        end
        local cs=tab:AddSection({})
        cs:AddButtonRow({Buttons={
            {Name="Clear",Callback=function()for _,l in ipairs(logs)do l:SetVisible(false)end;logs={}end},
            {Name="Test",Callback=function()print("NexusUI v7.0 ‚ÄĒ Obsidian",math.random(1000))end},
            {Name="Info",Callback=function()addLog("‚ĄĻ  NexusUI v7.0-Obsidian",T.info)end},
        }})
        return tab
    end

    -- ‚ĒÄ‚ĒÄ Binds tab ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ
    function W:AddBindsTab()
        local bt=self:AddTab({Name="Keybinds",Icon="‚Ć®"})
        local bs=bt:AddSection({Name="KEYBINDS"})
        if #W._keybinds==0 then bs:AddLabel({Text="No keybinds registered.",Color=T.muted})
        else for _,b in ipairs(W._keybinds) do
            bs:AddLabel({Text="‚Äļ  "..b.Name.."  ‚ÄĒ  "..(b.Ref.key==Enum.KeyCode.Unknown and "None" or b.Ref.key.Name),Color=T.sub})
        end end
        bs:AddDivider("Window")
        bs:AddLabel({Text="‚Äļ  Toggle UI  ‚ÄĒ  "..togKey.Name,Color=T.muted})
        bs:AddLabel({Text="‚Äļ  Ctrl+Z ‚ÄĒ Undo  ¬∑  Ctrl+Y ‚ÄĒ Redo",Color=T.muted})
        bs:AddButton({Name="Show Keybind Overlay",Callback=function()W:ShowBinds()end})
        return bt
    end

    -- ‚ĒÄ‚ĒÄ Stats tab (live FPS / ping / memory) ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ
    function W:AddStatsTab()
        local st=self:AddTab({Name="Stats",Icon="ūüďä"})
        local ss=st:AddSection({Name="PERFORMANCE"})
        local fpsBar=ss:AddProgressBar({Name="FPS",Id="stats_fps"})
        local pingBar=ss:AddProgressBar({Name="Ping",Id="stats_ping",Color=T.info})
        local memBar=ss:AddProgressBar({Name="Memory",Id="stats_mem",Color=T.warning})
        local fpsLbl=ss:AddLabel({Text="FPS: --",Id="stats_fps_lbl"})
        local pingLbl=ss:AddLabel({Text="Ping: --",Id="stats_ping_lbl"})
        local memLbl=ss:AddLabel({Text="Memory: --",Id="stats_mem_lbl"})
        -- Update loop
        local sT=0
        table.insert(W._conns,RunService.Heartbeat:Connect(function(dt)
            sT=sT+dt; if sT<0.5 then return end; sT=0
            local fps=math.floor(1/dt)
            local ping=math.floor(pcall(function()
                return Stats.Network.ServerStatsItem["Data Ping"].Value end) and
                Stats.Network.ServerStatsItem["Data Ping"].Value or 0)
            local mem=math.floor(pcall(function()return Stats:GetTotalMemoryUsageMb()end) and Stats:GetTotalMemoryUsageMb() or 0)
            fpsBar:Set(clamp(fps/144,0,1))
            pingBar:Set(clamp(1-(ping/300),0,1))
            memBar:Set(clamp(mem/512,0,1))
            fpsLbl:Set("FPS: "..fps.." / 144")
            pingLbl:Set("Ping: "..ping.."ms")
            memLbl:Set("Memory: "..mem.."mb")
        end))
        return st
    end

    return W
end -- CreateWindow

return Nexus
