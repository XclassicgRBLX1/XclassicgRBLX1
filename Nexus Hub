    function W:EnableAutoSave(interval,name)
        interval=interval or 30; name=name or "nexus_auto"
        if W._autoConn then W._autoConn:Disconnect() end
        local e=0
        W._autoConn=RunService.Heartbeat:Connect(function(dt)
            e=e+dt; if e>=interval then e=0; W:SaveConfig(name) end
        end)
    end
    function W:SaveConfig(name)
        name=name or "nexus"
        local data={_theme=tname,_elems={}}
        for id,elem in pairs(W._elems) do pcall(function()data._elems[id]=elem:Get()end) end
        if not writefile then return false,"writefile unavailable" end
        local ok,err=pcall(writefile,name..".json",HttpService:JSONEncode(data))
        return ok,err
    end
    function W:LoadConfig(name)
        name=name or "nexus"
        if not readfile then return nil,"readfile unavailable" end
        local ok,raw=pcall(readfile,name..".json")
        if not ok then return nil,"file not found" end
        local ok2,data=pcall(function()return HttpService:JSONDecode(raw)end)
        if not ok2 or not data then return nil,"invalid JSON" end
        if data._theme and Nexus.Themes[data._theme] then W:SetTheme(data._theme) end
