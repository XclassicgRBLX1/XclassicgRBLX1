            end
            local function hfx(f)
                f.MouseEnter:Connect(function()tw(f,.1,{BackgroundTransparency=.10,BackgroundColor3=T.elemHov})end)
                f.MouseLeave:Connect(function()tw(f,.1,{BackgroundTransparency=.42,BackgroundColor3=T.elem})end)
            end
            local function mL(p,txt,y)
                local l=N("TextLabel",{Size=UDim2.new(1,-90,0,17), Position=UDim2.new(0,12,0,y),
                    BackgroundTransparency=1, Text=txt, TextColor3=T.text, TextSize=TSZ,
                    Font=Enum.Font.GothamSemibold, TextXAlignment=Enum.TextXAlignment.Left,
                    TextTruncate=Enum.TextTruncate.AtEnd, ZIndex=7, Parent=p})
                rT(l,"TextColor3","text"); return l
            end
            local function sL(p,txt,y)
                local l=N("TextLabel",{Size=UDim2.new(1,-90,0,13), Position=UDim2.new(0,12,0,y),
                    BackgroundTransparency=1, Text=txt, TextColor3=T.sub, TextSize=SSZ,
                    Font=Enum.Font.Gotham, TextXAlignment=Enum.TextXAlignment.Left, ZIndex=7, Parent=p})
                rT(l,"TextColor3","sub"); return l
            end
            local function addTip(f,text)
                if not text or text=="" then return end
                f.MouseEnter:Connect(function()showTip(text)end)
                f.MouseLeave:Connect(hideTip)
            end
            local function depFn(obj,other,cond)
                local function chk()
                    local ok=cond and cond(other:Get()) or other:Get()==true
                    obj._frame.Visible=ok
                end
                chk()
                table.insert(W._conns,RunService.Heartbeat:Connect(function()pcall(chk)end))
            end
            local function regE(id,obj,sn,frame)
                if id then W._elems[id]=obj; obj._id=id end
                obj._sn=sn; obj._frame=frame
                table.insert(Sec._elems,obj)
                return obj
            end

            -- ‚ēź‚ēź‚ēź BUTTON ‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź
            function Sec:AddButton(o)
                o=o or{}
                local desc=o.Description or ""
                local f=ef(desc~="" and EHS or EH); hfx(f)
                mL(f,o.Name or "Button",desc~="" and 8 or 12)
                if desc~="" then sL(f,desc,26) end
                addTip(f,o.Tooltip)
                local arr=N("TextLabel",{Size=UDim2.new(0,22,1,0),Position=UDim2.new(1,-26,0,0),
                    BackgroundTransparency=1,Text="‚Äļ",TextColor3=T.accent,TextSize=22,Font=Enum.Font.GothamBold,ZIndex=7,Parent=f})
                rT(arr,"TextColor3","accent")
                local btn=N("TextButton",{Size=UDim2.new(1,0,1,0),BackgroundTransparency=1,Text="",AutoButtonColor=false,ZIndex=9,Parent=f})
                btn.MouseButton1Down:Connect(function()tw(f,.05,{BackgroundTransparency=0,BackgroundColor3=T.elemAct})end)
                btn.MouseButton1Up:Connect(function()
                    tw(f,.12,{BackgroundTransparency=.42,BackgroundColor3=T.elem})
                    if o.Callback then task.spawn(o.Callback) end
                end)
                local Obj={_frame=f}
                function Obj:SetVisible(v)f.Visible=v end; function Obj:Get()return nil end; function Obj:Set()end
                function Obj:DependsOn(other,cond)depFn(self,other,cond)end
                return regE(o.Id,Obj,o.Name,f)
            end

            -- ‚ēź‚ēź‚ēź TOGGLE  (v6.1: glow stroke when ON) ‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź
            function Sec:AddToggle(o)
                o=o or{}
                local desc=o.Description or ""
                local f=ef(desc~="" and EHS or EH); hfx(f)
                local val=o.Default==true
                mL(f,o.Name or "Toggle",desc~="" and 8 or 12)
                if desc~="" then sL(f,desc,28) end
                addTip(f,o.Tooltip)
                local track=N("Frame",{Size=UDim2.new(0,44,0,24),Position=UDim2.new(1,-52,.5,-12),
                    BackgroundColor3=val and T.accent or T.muted,BorderSizePixel=0,ZIndex=7,Parent=f})
                N("UICorner",{CornerRadius=UDim.new(1,0),Parent=track})
                -- v6.1: glow stroke ‚ÄĒ visible only when ON
                local trkStroke=N("UIStroke",{Color=T.accent,Thickness=2,Transparency=val and .55 or 1,Parent=track})
                rT(trkStroke,"Color","accent")
                local knob=N("Frame",{Size=UDim2.new(0,18,0,18),
                    Position=val and UDim2.new(1,-21,.5,-9) or UDim2.new(0,3,.5,-9),
                    BackgroundColor3=Color3.fromRGB(255,255,255),BorderSizePixel=0,ZIndex=8,Parent=track})
                N("UICorner",{CornerRadius=UDim.new(1,0),Parent=knob})
                local function setV(v,fire)
                    local prev=val; val=v
                    tw(track,.2,{BackgroundColor3=v and T.accent or T.muted})
                    tw(trkStroke,.2,{Transparency=v and .55 or 1})
                    tw(knob,.2,{Position=v and UDim2.new(1,-21,.5,-9) or UDim2.new(0,3,.5,-9)})
                    if fire~=false then
                        if o.Id then push(function()setV(v,true)end,function()setV(prev,true)end) end
                        if o.Callback then task.spawn(o.Callback,v) end
                    end
                end
                N("TextButton",{Size=UDim2.new(1,0,1,0),BackgroundTransparency=1,Text="",ZIndex=9,Parent=f}).MouseButton1Click:Connect(function()setV(not val)end)
                local Obj={Value=val,_frame=f}
                function Obj:Set(v,s)setV(v,s~=false);self.Value=v end
                function Obj:Get()return val end; function Obj:SetVisible(v)f.Visible=v end
                function Obj:DependsOn(other,cond)depFn(self,other,cond)end
                return regE(o.Id,Obj,o.Name,f)
            end

            -- ‚ēź‚ēź‚ēź SLIDER  (v6.1: value in accent pill capsule) ‚ēź‚ēź‚ēź‚ēź
            function Sec:AddSlider(o)
                o=o or{}
                local mn=o.Min or 0; local mx=o.Max or 100
                local suf=o.Suffix or ""; local step=o.Step
                local val=clamp(o.Default or mn,mn,mx)
                local f=ef(54)
                mL(f,o.Name or "Slider",9); addTip(f,o.Tooltip)

                -- v6.1: value shown in a small accent pill instead of plain text
                local valPill=N("Frame",{Size=UDim2.new(0,56,0,20),Position=UDim2.new(1,-62,0,7),
                    BackgroundColor3=T.accent,BackgroundTransparency=.82,BorderSizePixel=0,ZIndex=7,Parent=f})
                N("UICorner",{CornerRadius=UDim.new(1,0),Parent=valPill})
                N("UIStroke",{Color=T.accent,Thickness=1,Transparency=.5,Parent=valPill})
                rT(valPill,"BackgroundColor3","accent")
                local vLbl=N("TextLabel",{Size=UDim2.new(1,0,1,0),BackgroundTransparency=1,
                    Text=tostring(val)..suf,TextColor3=T.accent,TextSize=11,
                    Font=Enum.Font.GothamBold,ZIndex=8,Parent=valPill})
                rT(vLbl,"TextColor3","accent")

                local rail=N("Frame",{Size=UDim2.new(1,-18,0,5),Position=UDim2.new(0,9,1,-16),
                    BackgroundColor3=T.border,BorderSizePixel=0,ZIndex=7,Parent=f})
                N("UICorner",{CornerRadius=UDim.new(1,0),Parent=rail})
                local pct=(val-mn)/(mx-mn)
                local fillR=N("Frame",{Size=UDim2.new(pct,0,1,0),BackgroundColor3=T.accent,BorderSizePixel=0,ZIndex=8,Parent=rail})
                N("UICorner",{CornerRadius=UDim.new(1,0),Parent=fillR}); rT(fillR,"BackgroundColor3","accent")
                local kn=N("Frame",{Size=UDim2.new(0,16,0,16),AnchorPoint=Vector2.new(.5,.5),
                    Position=UDim2.new(pct,0,.5,0),BackgroundColor3=Color3.fromRGB(255,255,255),
                    BorderSizePixel=0,ZIndex=9,Parent=rail})
                N("UICorner",{CornerRadius=UDim.new(1,0),Parent=kn})
                N("UIStroke",{Color=T.accent,Thickness=2,Parent=kn})
                local drg=false
                local function apply(i)
                    local ap=rail.AbsolutePosition; local as2=rail.AbsoluteSize
                    local r=clamp((i.Position.X-ap.X)/as2.X,0,1)
                    local nv=lerp(mn,mx,r); nv=step and round(nv,step) or math.floor(nv+.5); nv=clamp(nv,mn,mx)
                    val=nv; local np=(nv-mn)/(mx-mn)
                    tw(fillR,.04,{Size=UDim2.new(np,0,1,0)}); tw(kn,.04,{Position=UDim2.new(np,0,.5,0)})
                    vLbl.Text=tostring(nv)..suf
                    if o.Callback then task.spawn(o.Callback,nv) end
                end
                rail.InputBegan:Connect(function(i)
                    if i.UserInputType==Enum.UserInputType.MouseButton1 or i.UserInputType==Enum.UserInputType.Touch then drg=true;apply(i) end
                end)
                table.insert(W._conns,UserInputService.InputChanged:Connect(function(i)
                    if drg and(i.UserInputType==Enum.UserInputType.MouseMovement or i.UserInputType==Enum.UserInputType.Touch)then apply(i) end
                end))
                table.insert(W._conns,UserInputService.InputEnded:Connect(function(i)
                    if i.UserInputType==Enum.UserInputType.MouseButton1 or i.UserInputType==Enum.UserInputType.Touch then drg=false end
                end))
                local Obj={Value=val,_frame=f}
                function Obj:Set(v)
                    val=clamp(v,mn,mx); local np=(val-mn)/(mx-mn)
                    fillR.Size=UDim2.new(np,0,1,0); kn.Position=UDim2.new(np,0,.5,0)
                    vLbl.Text=tostring(val)..suf; self.Value=val
                end
                function Obj:Get()return val end; function Obj:SetVisible(v)f.Visible=v end
                function Obj:DependsOn(other,cond)depFn(self,other,cond)end
                return regE(o.Id,Obj,o.Name,f)
            end

            -- ‚ēź‚ēź‚ēź NUMBER INPUT ‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź
