    N("UICorner",{CornerRadius=UDim.new(0,10),Parent=main})
    N("UIStroke",{Color=T.border,Thickness=1,Transparency=.15,Parent=main})
    regT(main,"BackgroundColor3","bg")

    -- ── Topbar ──
    local topbar=N("Frame",{Size=UDim2.new(1,0,0,46),BackgroundColor3=T.topbar,
        BorderSizePixel=0,ZIndex=5,Parent=main})
    regT(topbar,"BackgroundColor3","topbar")
    N("Frame",{Size=UDim2.new(1,0,0,12),Position=UDim2.new(0,0,1,-12),
        BackgroundColor3=T.topbar,BorderSizePixel=0,ZIndex=5,Parent=topbar})
    local acLine=N("Frame",{Size=UDim2.new(1,0,0,1),Position=UDim2.new(0,0,1,-1),
        BackgroundColor3=T.accent,BackgroundTransparency=.55,BorderSizePixel=0,ZIndex=6,Parent=topbar})
    regT(acLine,"BackgroundColor3","accent")
    local pill=N("Frame",{Size=UDim2.new(0,3,0,24),Position=UDim2.new(0,10,.5,-12),
        BackgroundColor3=T.accent,BorderSizePixel=0,ZIndex=7,Parent=topbar})
