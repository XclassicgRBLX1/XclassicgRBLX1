--  U T I L I T Y
-- ══════════════════════════════════════════════
local function TweenQ(o,t,p)
    if not o or not o.Parent then return end
    TweenService:Create(o,TweenInfo.new(t or .2,Enum.EasingStyle.Quart,Enum.EasingDirection.Out),p):Play()
end
local function TweenQI(o,t,p)
    if not o or not o.Parent then return end
    TweenService:Create(o,TweenInfo.new(t or .2,Enum.EasingStyle.Quart,Enum.EasingDirection.In),p):Play()
end
local function TweenC(o,t,s,d,p)
    if not o or not o.Parent then return end
    TweenService:Create(o,TweenInfo.new(t,s,d),p):Play()
end
local function TweenSp(o,t,p)
    if not o or not o.Parent then return end
    TweenService:Create(o,TweenInfo.new(t,Enum.EasingStyle.Spring,Enum.EasingDirection.Out),p):Play()
end

local function New(cls, props)
    local o = Instance.new(cls)
    for k,v in pairs(props) do if k~="Parent" then o[k]=v end end
    if props.Parent then o.Parent=props.Parent end
    return o
end

local function RandId(n)
    local c="abcdefghijklmnopqrstuvwxyzABCDEFGHIJKLMNOPQRSTUVWXYZ0123456789"
    local t={}
    for i=1,n or 16 do t[i]=c:sub(math.random(1,#c),math.random(1,#c)) end
    return table.concat(t)
end

local function Lerp(a,b,t) return a+(b-a)*t end
local function Clamp(v,a,b) return math.max(a,math.min(b,v)) end
local function Round(v,s) s=s or 1; return math.floor(v/s+.5)*s end
local function Hex(c) return string.format("%02X%02X%02X",c.R*255,c.G*255,c.B*255) end
local function TSize(txt,sz)
    return TextService:GetTextSize(txt,sz,Enum.Font.Gotham,Vector2.new(9999,9999))
end

-- Ripple effect on a frame
local function Ripple(parent, x, y, color)
    local rip = New("Frame",{
        Size=UDim2.new(0,0,0,0),
        AnchorPoint=Vector2.new(.5,.5),
        Position=UDim2.new(0,x,0,y),
        BackgroundColor3=color or Color3.fromRGB(255,255,255),
        BackgroundTransparency=0.72,
        BorderSizePixel=0,
        ZIndex=parent.ZIndex+10,
        Parent=parent,
        ClipsDescendants=false,
    })
    New("UICorner",{CornerRadius=UDim.new(1,0),Parent=rip})
    local sz = math.max(parent.AbsoluteSize.X, parent.AbsoluteSize.Y)*2.2
    TweenQ(rip,.55,{Size=UDim2.new(0,sz,0,sz),BackgroundTransparency=1})
    task.delay(.58,function() pcall(function() rip:Destroy() end) end)
end

