--  RIPPLE EFFECT
-- ‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź
function CreateRipple(button, color)
    local ripple = N("Frame",{
        Size = UDim2.new(0,0,0,0),
        AnchorPoint = Vector2.new(.5,.5),
        Position = UDim2.new(.5,0,.5,0),
        BackgroundColor3 = color or Color3.fromRGB(255,255,255),
        BackgroundTransparency = 0.5,
        BorderSizePixel = 0,
        ZIndex = 10,
        Parent = button
    })
    N("UICorner",{CornerRadius = UDim.new(1,0), Parent = ripple})
    local maxDiag = math.sqrt(button.AbsoluteSize.X^2 + button.AbsoluteSize.Y^2) * 2
    tw(ripple, 0.4, {Size = UDim2.new(0,maxDiag,0,maxDiag), BackgroundTransparency = 1}, Enum.EasingStyle.Quint, Enum.EasingDirection.Out)
    game:GetService("Debris"):AddItem(ripple, 0.5)
end

