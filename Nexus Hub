    -- ── Keyboard Navigation ───────────────────────────────────────
    local _focusables = {}
    local _focusIdx   = 0
    local _focusRing  = nil

    local function _clearFocus()
        if _focusRing then pcall(function() _focusRing.Transparency = 1 end) end
        _focusRing = nil; _focusIdx = 0
    end
    local function _setFocus(idx)
        _clearFocus()
        local f = _focusables[idx]; if not f then return end
        _focusIdx = idx
        if f.frame and f.frame.Parent then
            local ex = f.frame:FindFirstChild("_NxFR")
            if ex then _focusRing = ex; _focusRing.Transparency = 0
            else
                _focusRing = N("UIStroke",{Name="_NxFR",Color=T.accent,
                    Thickness=2,Transparency=0,Parent=f.frame})
                rT(_focusRing,"Color","accent")
            end
        end
    end
    W._regFocus = function(frame, activateFn)
        table.insert(_focusables, {frame=frame, activate=activateFn})
    end

    table.insert(W._conns, UserInputService.InputBegan:Connect(function(i, gp)
        if gp then return end
        if i.KeyCode == Enum.KeyCode.Tab then
            if #_focusables == 0 then return end
            local shift = UserInputService:IsKeyDown(Enum.KeyCode.LeftShift)
                       or UserInputService:IsKeyDown(Enum.KeyCode.RightShift)
            local next = shift and (_focusIdx-1) or (_focusIdx+1)
            if next < 1 then next = #_focusables elseif next > #_focusables then next = 1 end
            _setFocus(next)
        elseif (i.KeyCode==Enum.KeyCode.Return or i.KeyCode==Enum.KeyCode.Space) and _focusIdx>0 then
            local f = _focusables[_focusIdx]
            if f and f.activate then pcall(f.activate) end
        elseif i.KeyCode == Enum.KeyCode.Escape then
            _clearFocus()
        end
    end))

    -- ── Enhanced Notification System (v7.0) ──────────────────────
    -- Priority queue, action buttons, grouping, Critical no-dismiss
    local _nGroups  = {}   -- [title..type] = {count, badge, lastTime}
    local _nQueue   = {}
    local _nActive  = 0
    local _MAX_N    = 4
    local _PRIO     = {Critical=4,High=3,Normal=2,Low=1}

    local _origNotify = W.Notify
    function W:Notify(o)
        o = o or {}
        local function _spawn()
            _nActive += 1
            local nt    = o.Title   or "Notification"
            local body  = o.Content or o.Body or ""
            local dur   = o.Duration or 4
            local ntype = o.Type    or "Info"
            local prio  = o.Priority or "Normal"
            local acts  = o.Actions or {}
            local tMap  = {Info=T.info,Success=T.success,Warning=T.warning,Error=T.error}
            local syms  = {Info="ℹ",Success="✓",Warning="⚠",Error="✕"}
            local tCol  = tMap[ntype] or T.accent

            -- Grouping: same Title+Type within 3 s
            local gKey = nt..ntype
            local gd   = _nGroups[gKey]
            if gd and (os.clock()-gd.lastTime) < 3 then
                gd.count += 1
                if gd.badge and gd.badge.Parent then
                    gd.badge.Text    = "×"..gd.count
                    gd.badge.Visible = true
                end
                _nActive -= 1; return
            end
            _nGroups[gKey] = {count=1, lastTime=os.clock()}

            local notif = N("Frame",{
                Size=UDim2.new(1,0,0,0), BackgroundColor3=T.topbar,
                BackgroundTransparency=.05, BorderSizePixel=0,
                ClipsDescendants=true, LayoutOrder=_nActive, ZIndex=10, Parent=notifBox})
            N("UICorner",{CornerRadius=UDim.new(0,8),Parent=notif})

            -- Priority border
            local bW = prio=="Critical" and 3 or prio=="High" and 2 or 1
            local bC = prio=="Critical" and T.error or prio=="High" and T.warning or T.border
            N("UIStroke",{Color=bC,Thickness=bW,Transparency=.2,Parent=notif})

            -- Left strip
            local strip = N("Frame",{Size=UDim2.new(0,4,1,0),BackgroundColor3=tCol,BorderSizePixel=0,ZIndex=11,Parent=notif})
            N("UICorner",{CornerRadius=UDim.new(0,3),Parent=strip})

            -- Group badge
            local gBF = N("Frame",{Size=UDim2.new(0,30,0,16),AnchorPoint=Vector2.new(1,0),
                Position=UDim2.new(1,-32,0,6),BackgroundColor3=tCol,BackgroundTransparency=.2,
                BorderSizePixel=0,ZIndex=14,Visible=false,Parent=notif})
            N("UICorner",{CornerRadius=UDim.new(1,0),Parent=gBF})
            local gBL = N("TextLabel",{Size=UDim2.new(1,0,1,0),BackgroundTransparency=1,
                Text="×1",TextColor3=Color3.fromRGB(255,255,255),TextSize=9,
                Font=Enum.Font.GothamBold,ZIndex=15,Parent=gBF})
            _nGroups[gKey].badge = gBL

            -- Icon
            local ic = N("Frame",{Size=UDim2.new(0,24,0,24),AnchorPoint=Vector2.new(0,.5),
                Position=UDim2.new(0,14,0,0),BackgroundColor3=tCol,BackgroundTransparency=.8,
                BorderSizePixel=0,ZIndex=11,Parent=notif})
            N("UICorner",{CornerRadius=UDim.new(1,0),Parent=ic})
            N("TextLabel",{Size=UDim2.new(1,0,1,0),BackgroundTransparency=1,
                Text=syms[ntype] or "•",TextColor3=tCol,TextSize=12,
                Font=Enum.Font.GothamBold,ZIndex=12,Parent=ic})

            local tLbl = N("TextLabel",{Size=UDim2.new(1,-62,0,17),Position=UDim2.new(0,46,0,0),
                BackgroundTransparency=1,Text=nt,TextColor3=T.text,TextSize=12,
                Font=Enum.Font.GothamBold,TextXAlignment=Enum.TextXAlignment.Left,ZIndex=12,Parent=notif})
            local xb = N("TextButton",{Size=UDim2.new(0,16,0,16),AnchorPoint=Vector2.new(1,.5),
                Position=UDim2.new(1,-7,.5,-8),BackgroundTransparency=1,
                Text="✕",TextColor3=T.muted,TextSize=9,Font=Enum.Font.GothamBold,ZIndex=13,Parent=notif})

            local bLbl
            if body ~= "" then
                bLbl = N("TextLabel",{Size=UDim2.new(1,-50,0,0),Position=UDim2.new(0,46,0,0),
                    BackgroundTransparency=1,Text=body,TextColor3=T.sub,TextSize=10,
                    Font=Enum.Font.Gotham,TextXAlignment=Enum.TextXAlignment.Left,
                    TextWrapped=true,ZIndex=12,Parent=notif})
            end

            -- Action buttons
            local aBtns = {}
            for _,act in ipairs(acts) do
                local ab2 = N("TextButton",{Size=UDim2.new(0,0,0,22),
                    AutomaticSize=Enum.AutomaticSize.X,
                    BackgroundColor3=tCol,BackgroundTransparency=.75,
                    Text=act.Label or "Action",TextColor3=tCol,TextSize=10,
                    Font=Enum.Font.GothamBold,AutoButtonColor=false,ZIndex=13,Parent=notif})
                N("UICorner",{CornerRadius=UDim.new(0,5),Parent=ab2})
                N("UIPadding",{PaddingLeft=UDim.new(0,8),PaddingRight=UDim.new(0,8),Parent=ab2})
                ab2.MouseEnter:Connect(function() tw(ab2,.08,{BackgroundTransparency=.4}) end)
                ab2.MouseLeave:Connect(function() tw(ab2,.08,{BackgroundTransparency=.75}) end)
                ab2.MouseButton1Click:Connect(function()
                    if act.Callback then task.spawn(act.Callback) end
                    if act.DismissOnClick ~= false then
                        tw(notif,.15,{BackgroundTransparency=1,Size=UDim2.new(1,0,0,0)})
                        task.delay(.18,function() pcall(function() notif:Destroy() end) end)
                        _nActive = math.max(0,_nActive-1)
                        _nGroups[gKey] = nil
                        if #_nQueue>0 then task.delay(.05,function() W:Notify(table.remove(_nQueue,1)) end) end
                    end
                end)
                table.insert(aBtns, ab2)
            end

            -- Progress drain bar
            local pd = N("Frame",{Size=UDim2.new(1,0,0,2),AnchorPoint=Vector2.new(0,1),
                Position=UDim2.new(0,0,1,0),BackgroundColor3=tCol,BackgroundTransparency=.55,
                BorderSizePixel=0,ZIndex=12,Parent=notif})

            local alive = true
            local function dismiss()
                if not alive then return end; alive = false
                _nActive = math.max(0,_nActive-1); _nGroups[gKey] = nil
                tw(notif,.18,{BackgroundTransparency=1,Size=UDim2.new(1,0,0,0)})
                task.delay(.2,function() pcall(function() notif:Destroy() end) end)
                if #_nQueue>0 then task.delay(.05,function() W:Notify(table.remove(_nQueue,1)) end) end
            end
            xb.MouseButton1Click:Connect(dismiss)

            -- Critical: pulsing border
            local pulseC
            if prio=="Critical" then
                local ns = notif:FindFirstChildWhichIsA("UIStroke")
                if ns then
                    local ph = 0
                    pulseC = RunService.Heartbeat:Connect(function(dt)
                        if not(ns and ns.Parent) then pulseC:Disconnect(); return end
                        ph += dt*3
                        ns.Transparency = lerp(.05,.65,(math.sin(ph)+1)*.5)
                    end)
                end
            end

            task.defer(function()
                local bH  = bLbl and bLbl.TextBounds.Y or 0
                if bLbl then bLbl.Size = UDim2.new(1,-50,0,bH) end
                local aH  = #aBtns > 0 and 30 or 0
                local PAD = 10
                local tot = math.max(42, bH>0 and (32+bH+PAD+aH) or (42+aH))
                local mid = tot/2
                ic.Position  = UDim2.new(0,14,0,mid-12)
                xb.Position  = UDim2.new(1,-7,.5,-8)
                if bH > 0 then
                    tLbl.Position = UDim2.new(0,46,0,PAD/2)
                    if bLbl then bLbl.Position = UDim2.new(0,46,0,PAD/2+18) end
                else
                    tLbl.Position = UDim2.new(0,46,0,mid-8)
                end
                if #aBtns > 0 then
                    local ax = 46
                    for _,btn in ipairs(aBtns) do
                        btn.Position = UDim2.new(0,ax,0,tot-aH+4)
                        task.wait(); ax += btn.AbsoluteSize.X + 6
                    end
                end
                tw(notif,.18,{Size=UDim2.new(1,0,0,tot)})
                if prio ~= "Critical" then
                    twL(pd, dur, {Size=UDim2.new(0,0,0,2)})
                    task.delay(dur, function()
                        dismiss()
                        if pulseC then pcall(function() pulseC:Disconnect() end) end
                    end)
                end
            end)
        end

        if _nActive < _MAX_N then
            _spawn()
        else
            table.insert(_nQueue, o)
            table.sort(_nQueue, function(a,b)
                return (_PRIO[a.Priority or "Normal"] or 2) > (_PRIO[b.Priority or "Normal"] or 2)
            end)
        end
    end

