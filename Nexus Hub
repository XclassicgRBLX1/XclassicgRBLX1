--  GLASSMORPHISM & NEUMORPHISM HELPERS
-- ════════════════════════════════════════════════════════════════
local function applyGlassEffect(frame, theme)
    if not theme.glass then return nil end
    local g = theme.glass
    frame.BackgroundTransparency = g.transparency or 0.15
    local gradient = N("UIGradient", {
        Color = ColorSequence.new{
            ColorSequenceKeypoint.new(0, g.highlightColor or Color3.fromRGB(255, 255, 255)),
            ColorSequenceKeypoint.new(1, g.shadowColor or Color3.fromRGB(0, 0, 0))
        },
        Transparency = NumberSequence.new{
            NumberSequenceKeypoint.new(0, g.highlightTrans or 0.08),
            NumberSequenceKeypoint.new(1, g.shadowTrans or 0.25)
        },
        Rotation = g.gradientAngle or 135,
        Parent = frame
    })
    local stroke = nil
    if g.borderGlow then
        stroke = N("UIStroke", {
            Color = theme.accent,
            Thickness = 1,
            Transparency = 0.4,
            Parent = frame
        })
    end
    return {gradient = gradient, stroke = stroke}
end

local function calculateNeoShadows(baseColor, neo)
    local light = neo.lightAngle or 315
    local rad = math.rad(light)
    local offsetX = math.cos(rad) * (neo.shadowDistance or 6)
    local offsetY = math.sin(rad) * (neo.shadowDistance or 6)
    local highlightMult = neo.highlightMult or 1.15
    local shadowMult = neo.shadowMult or 0.85
    local highlight = neo.shadowLight or
        Color3.new(
            math.min(1, baseColor.R * highlightMult),
            math.min(1, baseColor.G * highlightMult),
            math.min(1, baseColor.B * highlightMult)
        )
    local shadow = neo.shadowDark or
        Color3.new(
            math.max(0, baseColor.R * shadowMult),
            math.max(0, baseColor.G * shadowMult),
            math.max(0, baseColor.B * shadowMult)
        )
    return {
        highlight = highlight,
        shadow = shadow,
        offsetX = offsetX,
        offsetY = offsetY
    }
end

local function applyNeumorphismEffect(frame, theme, isPressed, parentOverride)
    if not theme.neo then return nil end
    local n = theme.neo
    local base = theme.elem or theme.section or theme.bg
    local parent = parentOverride or frame.Parent
    local shadows = calculateNeoShadows(base, n)
    local cornerRadius = n.cornerRadius or 14
    local corner = frame:FindFirstChildOfClass("UICorner")
    if corner then corner.CornerRadius = UDim.new(0, cornerRadius) end
    
    -- Create shadow layers behind frame
    local highlight = N("Frame", {
        Size = UDim2.new(1, n.shadowDistance, 1, n.shadowDistance),
        Position = UDim2.new(0, -n.shadowDistance, 0, -n.shadowDistance),
        BackgroundColor3 = shadows.highlight,
        BorderSizePixel = 0,
        ZIndex = (frame.ZIndex or 1) - 1,
        Parent = parent
    })
    if corner then N("UICorner", {CornerRadius = corner.CornerRadius, Parent = highlight}) end
    
    local shadow = N("Frame", {
        Size = UDim2.new(1, n.shadowDistance, 1, n.shadowDistance),
        Position = UDim2.new(0, n.shadowDistance, 0, n.shadowDistance),
        BackgroundColor3 = shadows.shadow,
        BorderSizePixel = 0,
        ZIndex = (frame.ZIndex or 1) - 1,
        Parent = parent
    })
    if corner then N("UICorner", {CornerRadius = corner.CornerRadius, Parent = shadow}) end
    
    -- Adjust main frame for extrusion effect
    if not isPressed then
        frame.Position = UDim2.new(0, n.shadowDistance, 0, n.shadowDistance)
        frame.Size = UDim2.new(1, -n.shadowDistance * 2, 1, -n.shadowDistance * 2)
    else
        frame.Position = UDim2.new(0, 0, 0, 0)
        frame.Size = UDim2.new(1, 0, 1, 0)
        if n.pressedInset then
            local inner = N("Frame", {
                Size = UDim2.new(1, -4, 1, -4),
                Position = UDim2.new(0, 2, 0, 2),
                BackgroundColor3 = shadows.shadow,
                BackgroundTransparency = 0.15,
                BorderSizePixel = 0,
                ZIndex = (frame.ZIndex or 1) + 1,
                Parent = frame
            })
            if corner then
                N("UICorner", {CornerRadius = UDim.new(0, cornerRadius - 2), Parent = inner})
            end
            return {highlight = highlight, shadow = shadow, inner = inner}
        end
    end
    return {highlight = highlight, shadow = shadow}
end

local function cleanupNeoShadows(frame)
    if not frame or not frame.Parent then return end
    for _, child in ipairs(frame.Parent:GetChildren()) do
        if child:IsA("Frame") and child ~= frame then
            local fz = frame.ZIndex or 1
            local cz = child.ZIndex or 1
            if cz == fz - 1 then child:Destroy() end
        end
    end
end

