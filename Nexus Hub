-- ════════════════════════════════════════════════════════════════
function Nexus:CreateWindow(opts)
    opts = opts or {}
    local title    = opts.Title     or "NexusUI"
    local subtitle = opts.Subtitle  or ""
    local togKey   = opts.ToggleKey or Enum.KeyCode.RightShift
    local tname    = type(opts.Theme)=="string" and opts.Theme or "Dark"
    local T        = (type(opts.Theme)=="table") and opts.Theme
                     or Nexus.Themes[tname] or Nexus.Themes.Dark

    -- ── Responsive window sizing (NO UIScale shrink) ─────────────
    local vp      = getVP()
    local mobile  = vp.X < 860
    local WIN_W   = mobile and math.floor(vp.X*.97) or math.min(opts.Size and opts.Size.X.Offset or 720, vp.X-40)
    local WIN_H   = mobile and math.floor(vp.Y*.90) or math.min(opts.Size and opts.Size.Y.Offset or 520, vp.Y-40)
    local initSz  = UDim2.new(0,WIN_W,0,WIN_H)
    local initPos = opts.Position or UDim2.new(0.5,-WIN_W/2, 0.5,-WIN_H/2)
    local SW       = WIN_W >= 380 and 150 or 0  -- sidebar width
    local TOPH     = 50                          -- topbar height
    -- Element sizing constants
    local EH   = 44   -- element height
    local EHS  = 62   -- element height with subtitle
    local TSZ  = 14   -- main label text size
    local SSZ  = 12   -- sub label text size

    -- ── Theme registry ────────────────────────────────────────────
    local reg = {}
    local function rT(i,p,k) if i and k then table.insert(reg,{i=i,p=p,k=k}) end end
    local function applyTheme(nT)
        T = nT
        for _,r in ipairs(reg) do pcall(function()
            if r.i and r.i.Parent and nT[r.k] then r.i[r.p] = nT[r.k] end
        end) end
    end

    -- ── Undo / redo ───────────────────────────────────────────────
    local uStk, rStk = {}, {}
    local function push(d,u)
        table.insert(uStk,{d=d,u=u}); rStk={}
        if #uStk>60 then table.remove(uStk,1) end
    end

    -- ── Notification layer (own ScreenGui) ───────────────────────
    local notifSG  = mkGui(99900)
    local notifBox = N("Frame",{Size=UDim2.new(0,310,1,0), Position=UDim2.new(1,-318,0,0),
        BackgroundTransparency=1, Parent=notifSG})
    N("UIListLayout",{SortOrder=Enum.SortOrder.LayoutOrder,
        VerticalAlignment=Enum.VerticalAlignment.Top, Padding=UDim.new(0,6), Parent=notifBox})
    N("UIPadding",{PaddingTop=UDim.new(0,16), Parent=notifBox})
    local notifIdx = 0; local notifLog = {}

    -- ── History panel ─────────────────────────────────────────────
    local histSG = mkGui(99800)
    local histPanel = N("Frame",{Size=UDim2.new(0,296,0,0), Position=UDim2.new(1,-304,0,0),
        BackgroundColor3=T.topbar, BorderSizePixel=0, ClipsDescendants=true,
        Visible=false, ZIndex=1, Parent=histSG})
    N("UICorner",{CornerRadius=UDim.new(0,12), Parent=histPanel})
    N("UIStroke",{Color=T.border, Thickness=1, Transparency=.3, Parent=histPanel})
    rT(histPanel,"BackgroundColor3","topbar")
    N("TextLabel",{Size=UDim2.new(1,-24,0,24), Position=UDim2.new(0,14,0,12),
        BackgroundTransparency=1, Text="🔔  Notifications", TextColor3=T.text,
        TextSize=13, Font=Enum.Font.GothamBold, TextXAlignment=Enum.TextXAlignment.Left,
        ZIndex=2, Parent=histPanel})
    local histScroll = N("ScrollingFrame",{Size=UDim2.new(1,-10,1,-44), Position=UDim2.new(0,5,0,42),
        BackgroundTransparency=1, ScrollBarThickness=3, ScrollBarImageColor3=T.scroll,
        ScrollingDirection=Enum.ScrollingDirection.Y, CanvasSize=UDim2.new(0,0,0,0),
        ZIndex=2, Parent=histPanel})
    local histLL = N("UIListLayout",{SortOrder=Enum.SortOrder.LayoutOrder, Padding=UDim.new(0,3), Parent=histScroll})
    histLL:GetPropertyChangedSignal("AbsoluteContentSize"):Connect(function()
        histScroll.CanvasSize = UDim2.new(0,0,0,histLL.AbsoluteContentSize.Y+6)
    end)
    local histOpen = false

    -- ── Tooltip layer ─────────────────────────────────────────────
    local tipSG  = mkGui(99700)
    local tipBox = N("Frame",{Size=UDim2.new(0,10,0,26), BackgroundColor3=T.section,
        BorderSizePixel=0, Visible=false, ZIndex=1, Parent=tipSG})
    N("UICorner",{CornerRadius=UDim.new(0,6), Parent=tipBox})
    N("UIStroke",{Color=T.border, Thickness=1, Parent=tipBox}); rT(tipBox,"BackgroundColor3","section")
    local tipLbl = N("TextLabel",{Size=UDim2.new(1,-14,1,0), Position=UDim2.new(0,7,0,0),
        BackgroundTransparency=1, Text="", TextColor3=T.sub, TextSize=11,
        Font=Enum.Font.Gotham, ZIndex=2, Parent=tipBox}); rT(tipLbl,"TextColor3","sub")
    local tipConn
    local function showTip(txt)
        if not txt or txt=="" then return end
        if tipConn then pcall(function()tipConn:Disconnect()end) end
        tipLbl.Text = txt
        local w = TextService:GetTextSize(txt,11,Enum.Font.Gotham,Vector2.new(9999,9999)).X+16
        tipBox.Size = UDim2.new(0,w,0,26); tipBox.Visible = true
        tipConn = RunService.Heartbeat:Connect(function()
            local mp = UserInputService:GetMouseLocation()
            tipBox.Position = UDim2.new(0,mp.X+16,0,mp.Y+16)
        end)
    end
    local function hideTip()
        tipBox.Visible = false
        if tipConn then pcall(function()tipConn:Disconnect()end); tipConn=nil end
    end

    -- ── Main ScreenGui ────────────────────────────────────────────
    local sg   = mkGui(100)
    local wrap = N("Frame",{Size=initSz, Position=initPos, BackgroundTransparency=1, Parent=sg})
    -- No drop shadow — removed to keep background clean
    local main = N("Frame",{Size=UDim2.new(1,0,1,0), BackgroundColor3=T.bg,
        BorderSizePixel=0, ClipsDescendants=true, ZIndex=1, Parent=wrap})
    N("UICorner",{CornerRadius=UDim.new(0,12), Parent=main}); rT(main,"BackgroundColor3","bg")
    N("UIStroke",{Color=T.border, Thickness=1, Transparency=.08, Parent=main})

    -- ── TOPBAR ────────────────────────────────────────────────────
    local topbar = N("Frame",{Size=UDim2.new(1,0,0,TOPH), BackgroundColor3=T.topbar,
        BorderSizePixel=0, ZIndex=5, Parent=main}); rT(topbar,"BackgroundColor3","topbar")
    N("Frame",{Size=UDim2.new(1,0,0,12), Position=UDim2.new(0,0,1,-12),
        BackgroundColor3=T.topbar, BorderSizePixel=0, ZIndex=5, Parent=topbar})
    local tbR = N("Frame",{Size=UDim2.new(1,0,0,1), Position=UDim2.new(0,0,1,-1),
        BackgroundColor3=T.accent, BackgroundTransparency=.6, BorderSizePixel=0, ZIndex=6, Parent=topbar})
    rT(tbR,"BackgroundColor3","accent")
    local tpill = N("Frame",{Size=UDim2.new(0,3,0,24), Position=UDim2.new(0,12,.5,-12),
