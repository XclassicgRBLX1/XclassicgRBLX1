--  LOADING SCREEN
-- ════════════════════════════════════════════════════════
function Nexus:LoadingScreen(opts)
    opts=opts or{}
    local title=opts.Title or "NexusUI"
    local sub=opts.Subtitle or "Loading..."
    local tasks=opts.Tasks or{}
    local T=(type(opts.Theme)=="table") and opts.Theme or Nexus.Themes[opts.Theme] or Nexus.Themes.Dark
    local sg=mkGui(99999);applyScale(sg)
    local bg=N("Frame",{Size=UDim2.new(1,0,1,0),BackgroundColor3=T.bg,BorderSizePixel=0,ZIndex=1,Parent=sg})
    N("ImageLabel",{Size=UDim2.new(0,580,0,580),Position=UDim2.new(.5,-290,.5,-290),
        BackgroundTransparency=1,Image="rbxassetid://6014261993",
        ImageColor3=T.accent,ImageTransparency=0.89,ZIndex=2,Parent=bg})
    local CARD_H=220+#tasks*22
    local card=N("Frame",{Size=UDim2.new(0,360,0,CARD_H),AnchorPoint=Vector2.new(.5,.5),
        Position=UDim2.new(.5,0,.54,0),BackgroundColor3=T.section,
        BackgroundTransparency=1,BorderSizePixel=0,ZIndex=3,Parent=bg})
    N("UICorner",{CornerRadius=UDim.new(0,14),Parent=card})
    N("UIStroke",{Color=T.accent,Thickness=1,Transparency=0.55,Parent=card})
    tw(card,.45,{BackgroundTransparency=0,Position=UDim2.new(.5,0,.5,0)})
    local y=24
    N("TextLabel",{Size=UDim2.new(1,-28,0,26),Position=UDim2.new(0,14,0,y),
        BackgroundTransparency=1,Text=title,TextColor3=T.text,TextSize=22,
        Font=Enum.Font.GothamBold,ZIndex=4,Parent=card});y=y+30
    local subLbl=N("TextLabel",{Size=UDim2.new(1,-28,0,14),Position=UDim2.new(0,14,0,y),
        BackgroundTransparency=1,Text=sub,TextColor3=T.sub,TextSize=12,
        Font=Enum.Font.Gotham,ZIndex=4,Parent=card});y=y+20
    local checks={}
    for i,tk in ipairs(tasks) do
        local row=N("Frame",{Size=UDim2.new(1,-28,0,19),Position=UDim2.new(0,14,0,y),
            BackgroundTransparency=1,ZIndex=4,Parent=card})
        local dot=N("Frame",{Size=UDim2.new(0,6,0,6),AnchorPoint=Vector2.new(0,.5),
            Position=UDim2.new(0,0,.5,0),BackgroundColor3=T.muted,BorderSizePixel=0,ZIndex=5,Parent=row})
        N("UICorner",{CornerRadius=UDim.new(1,0),Parent=dot})
        local tl=N("TextLabel",{Size=UDim2.new(1,-14,1,0),Position=UDim2.new(0,13,0,0),
            BackgroundTransparency=1,Text=tk.Name or("Task "..i),TextColor3=T.muted,
            TextSize=11,Font=Enum.Font.Gotham,TextXAlignment=Enum.TextXAlignment.Left,
            ZIndex=5,Parent=row})
        checks[i]={dot=dot,lbl=tl};y=y+21
    end
    y=y+8
    local track=N("Frame",{Size=UDim2.new(1,-28,0,4),Position=UDim2.new(0,14,0,y),
        BackgroundColor3=T.border,BorderSizePixel=0,ZIndex=4,Parent=card})
    N("UICorner",{CornerRadius=UDim.new(1,0),Parent=track})
    local barFill=N("Frame",{Size=UDim2.new(0,0,1,0),BackgroundColor3=T.accent,BorderSizePixel=0,ZIndex=5,Parent=track})
    N("UICorner",{CornerRadius=UDim.new(1,0),Parent=barFill})
    y=y+8
    local pctLbl=N("TextLabel",{Size=UDim2.new(.5,0,0,14),Position=UDim2.new(.5,0,0,y),
        BackgroundTransparency=1,Text="0%",TextColor3=T.accent,TextSize=10,
        Font=Enum.Font.GothamBold,TextXAlignment=Enum.TextXAlignment.Right,ZIndex=4,Parent=card})
    local curLbl=N("TextLabel",{Size=UDim2.new(.5,0,0,14),Position=UDim2.new(0,14,0,y),
        BackgroundTransparency=1,Text="",TextColor3=T.sub,TextSize=10,
        Font=Enum.Font.Gotham,TextXAlignment=Enum.TextXAlignment.Left,ZIndex=4,Parent=card});y=y+18
    local dotsF=N("Frame",{Size=UDim2.new(0,54,0,8),AnchorPoint=Vector2.new(.5,0),
        Position=UDim2.new(.5,0,0,y),BackgroundTransparency=1,ZIndex=4,Parent=card})
    local dots={}
    for i=1,4 do
        local d=N("Frame",{Size=UDim2.new(0,7,0,7),Position=UDim2.new(0,(i-1)*14,0,1),
            BackgroundColor3=T.accent,BackgroundTransparency=.7,BorderSizePixel=0,ZIndex=5,Parent=dotsF})
        N("UICorner",{CornerRadius=UDim.new(1,0),Parent=d});dots[i]=d
    end
    N("TextLabel",{Size=UDim2.new(1,-28,0,12),Position=UDim2.new(0,14,1,-18),
        BackgroundTransparency=1,Text="NexusUI v5.1",TextColor3=T.muted,TextSize=9,
        Font=Enum.Font.Gotham,ZIndex=4,Parent=card})
    local phase=0
    local spinConn=RunService.Heartbeat:Connect(function(dt)
        phase=phase+dt*3
        for i,d in ipairs(dots) do
            local t2=(math.sin(phase+(i-1)*1.57)+1)*.5
            d.BackgroundTransparency=lerp(.1,.85,1-t2)
            local s=lerp(4,8,t2);d.Size=UDim2.new(0,s,0,s)
        end
    end)
    local Loader={}
    local function setP(f2,lbl)
        tw(barFill,.3,{Size=UDim2.new(clamp(f2,0,1),0,1,0)})
        pctLbl.Text=math.floor(clamp(f2,0,1)*100).."%"
        if lbl then curLbl.Text=lbl end
    end
    function Loader:Run(cb)
        task.wait(.35)
        local total=math.max(#tasks,1)
        if #tasks==0 then
            for i=0,10 do setP(i/10,"Loading...");task.wait(.07) end
        else
            for i,tk in ipairs(tasks) do
                setP((i-1)/total,tk.Name or "...")
                if checks[i] then
                    tw(checks[i].dot,.2,{BackgroundColor3=T.accent})
                    tw(checks[i].lbl,.2,{TextColor3=T.text})
                end
                task.wait(tk.Duration or .5)
                setP(i/total)
                if checks[i] then
                    checks[i].dot.BackgroundColor3=T.success
                    checks[i].lbl.Text="✓  "..(tk.Name or "")
                    checks[i].lbl.TextColor3=T.sub
                end
            end
        end
        setP(1,"Ready!")
        curLbl.TextColor3=T.success
        task.wait(.45)
        spinConn:Disconnect()
        twI(card,.32,{BackgroundTransparency=1,Position=UDim2.new(.5,0,.45,0)})
        twI(bg,  .42,{BackgroundTransparency=1})
        task.wait(.48)
        pcall(function()sg:Destroy()end)
        if cb then task.spawn(cb) end
    end
    function Loader:SetStatus(t) subLbl.Text=t end
    function Loader:SetTask(t)   curLbl.Text=t end
    function Loader:SetProgress(f2) setP(f2) end
    return Loader
end

