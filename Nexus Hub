        local arrowLbl=N("TextLabel",{Size=UDim2.new(0,16,1,0),Position=UDim2.new(1,-14,0,0),BackgroundTransparency=1,Text="‚Ėľ",TextColor3=T.muted,TextSize=8,Font=Enum.Font.GothamBold,ZIndex=4,Parent=el})
        rT(arrowLbl,"TextColor3","muted")

