    function W:AddTab(topts)
        topts = topts or {}
        local name = topts.Name or "Tab"
        local sym  = topts.Icon or ""

        local tabParent = tabScrollF or pageCon
        local tabBtn = N("TextButton",{Size=UDim2.new(1,0,0,36),BackgroundColor3=T.tabSel,
            BackgroundTransparency=1,Text="",AutoButtonColor=false,ZIndex=6,Parent=tabParent})
        N("UICorner",{CornerRadius=UDim.new(0,CR_EL),Parent=tabBtn})
        rT(tabBtn,"BackgroundColor3","tabSel")

        -- Active indicator (4px, with glow pulse when active)
        local ind = N("Frame",{Size=UDim2.new(0,4,0,16),Position=UDim2.new(0,1,.5,-8),
            BackgroundColor3=T.accent,BackgroundTransparency=1,BorderSizePixel=0,ZIndex=7,Parent=tabBtn})
        N("UICorner",{CornerRadius=UDim.new(0,2),Parent=ind})
        rT(ind,"BackgroundColor3","accent")

        local tabLbl = N("TextLabel",{Size=UDim2.new(1,-28,1,0),Position=UDim2.new(0,14,0,0),
            BackgroundTransparency=1,Text=(sym~="" and sym.."  " or "")..name,
            TextColor3=T.sub,TextSize=12,Font=Enum.Font.Gotham,
            TextXAlignment=Enum.TextXAlignment.Left,ZIndex=7,Parent=tabBtn})
        rT(tabLbl,"TextColor3","sub")

        local badge = N("Frame",{Size=UDim2.new(0,16,0,16),Position=UDim2.new(1,-20,.5,-8),
            BackgroundColor3=T.error,BorderSizePixel=0,Visible=false,ZIndex=8,Parent=tabBtn})
        N("UICorner",{CornerRadius=UDim.new(1,0),Parent=badge})
        rT(badge,"BackgroundColor3","error")
        local badgeLbl = N("TextLabel",{Size=UDim2.new(1,0,1,0),BackgroundTransparency=1,
            Text="0",TextColor3=Color3.fromRGB(255,255,255),TextSize=8,
            Font=Enum.Font.GothamBold,ZIndex=9,Parent=badge})

        local pageOuter = N("Frame",{Size=UDim2.new(1,0,1,0),BackgroundTransparency=1,
            Visible=false,ZIndex=3,Parent=pageCon})

        -- In-page search
        local psBg = N("Frame",{Size=UDim2.new(1,-22,0,30),Position=UDim2.new(0,11,0,7),
            BackgroundColor3=T.input,BackgroundTransparency=.35,BorderSizePixel=0,ZIndex=4,Parent=pageOuter})
        N("UICorner",{CornerRadius=UDim.new(0,CR_EL+1),Parent=psBg})
        N("UIStroke",{Color=T.border,Thickness=1,Parent=psBg}); rT(psBg,"BackgroundColor3","input")
        N("TextLabel",{Size=UDim2.new(0,18,1,0),Position=UDim2.new(0,8,0,0),BackgroundTransparency=1,
            Text="‚Ćē",TextColor3=T.muted,TextSize=14,Font=Enum.Font.GothamBold,ZIndex=5,Parent=psBg})
        local psBox = N("TextBox",{Size=UDim2.new(1,-28,1,0),Position=UDim2.new(0,25,0,0),
            BackgroundTransparency=1,Text="",PlaceholderText="Search elements...",
            PlaceholderColor3=T.muted,TextColor3=T.text,TextSize=11,Font=Enum.Font.Gotham,
            TextXAlignment=Enum.TextXAlignment.Left,ClearTextOnFocus=false,ZIndex=5,Parent=psBg})
        rT(psBox,"TextColor3","text")

        local page = N("ScrollingFrame",{
            Size=UDim2.new(1,0,1,-46), Position=UDim2.new(0,0,0,46),
            BackgroundTransparency=1, ScrollBarThickness=4,
            ScrollBarImageColor3=T.scroll, ScrollingDirection=Enum.ScrollingDirection.Y,
            CanvasSize=UDim2.new(0,0,0,0), BorderSizePixel=0, ZIndex=3, Parent=pageOuter})
        rT(page,"ScrollBarImageColor3","scroll")
        local pageLL = N("UIListLayout",{SortOrder=Enum.SortOrder.LayoutOrder,Padding=UDim.new(0,8),Parent=page})
        N("UIPadding",{PaddingTop=UDim.new(0,10),PaddingLeft=UDim.new(0,10),PaddingRight=UDim.new(0,12),PaddingBottom=UDim.new(0,14),Parent=page})

        local function syncCanvas()
            page.CanvasSize=UDim2.new(0,0,0,pageLL.AbsoluteContentSize.Y+26)
        end
        pageLL:GetPropertyChangedSignal("AbsoluteContentSize"):Connect(syncCanvas)
        pageOuter:GetPropertyChangedSignal("Visible"):Connect(function()
            if pageOuter.Visible then task.defer(syncCanvas) end
        end)

        local pageSections = {}
        psBox:GetPropertyChangedSignal("Text"):Connect(function()
            local q=psBox.Text:lower()
            for _,sec in ipairs(pageSections) do for _,el in ipairs(sec._elems) do
                if el._frame and el._sn then el._frame.Visible=q=="" or el._sn:lower():find(q,1,true)~=nil end
            end end
        end)

        local Tab={Btn=tabBtn,Page=page,PageOuter=pageOuter,Lbl=tabLbl,Ind=ind,_name=name}
        table.insert(W.Tabs,Tab)

        function Tab:SetBadge(n)
            if n and n>0 then badgeLbl.Text=tostring(n>99 and "99+" or n);badge.Visible=true
            else badge.Visible=false end
        end

        local indPulse
        local function SelTab()
            if W.ActiveTab and W.ActiveTab~=Tab then
                if indPulse then indPulse:Disconnect(); indPulse=nil end
                tw(W.ActiveTab.Btn,.14,{BackgroundTransparency=1})
                tw(W.ActiveTab.Lbl,.14,{TextColor3=T.sub})
                tw(W.ActiveTab.Ind,.14,{BackgroundTransparency=1})
                W.ActiveTab.Lbl.Font=Enum.Font.Gotham
                W.ActiveTab.PageOuter.Visible=false
            end
            W.ActiveTab=Tab
            tw(tabBtn,.14,{BackgroundTransparency=.5})
            tw(tabLbl,.14,{TextColor3=T.text})
            tw(ind,.14,{BackgroundTransparency=0})
            tabLbl.Font=Enum.Font.GothamSemibold
            pageOuter.Visible=true
            Tab:SetBadge(0)
            task.defer(syncCanvas)
            -- Pulse glow on active indicator
            local pulsing=true
            indPulse=RunService.Heartbeat:Connect(function()
                if not ind.Parent then pulsing=false;return end
                -- gentle opacity pulse via tweens handled by loop
            end)
            local function pulse()
                if not pulsing or not ind.Parent then if indPulse then indPulse:Disconnect() end; return end
                tw(ind,.5,{BackgroundTransparency=.5}); task.delay(.5,function()
                    tw(ind,.5,{BackgroundTransparency=0}); task.delay(.55,pulse)
                end)
            end
            if indPulse then indPulse:Disconnect(); indPulse=nil end
            pulse()
        end
        tabBtn.MouseButton1Click:Connect(SelTab)
        tabBtn.MouseEnter:Connect(function()if W.ActiveTab~=Tab then tw(tabBtn,.1,{BackgroundTransparency=.7})end end)
        tabBtn.MouseLeave:Connect(function()if W.ActiveTab~=Tab then tw(tabBtn,.1,{BackgroundTransparency=1})end end)
        if #W.Tabs==1 then SelTab() end

        -- ‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź
        --  ADD SECTION
        -- ‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź
        function Tab:AddSection(sopts)
            sopts   = sopts or {}
            local sname     = sopts.Name      or ""
            local sicon     = sopts.Icon      or ""
            local collapsed = sopts.Collapsed == true

            local secFrame = N("Frame",{
                Size=UDim2.new(1,0,0,sname~="" and 34 or 6),
                BackgroundColor3=T.section, BorderSizePixel=0,
                ClipsDescendants=false, ZIndex=4, Parent=page})
            N("UICorner",{CornerRadius=UDim.new(0,CR_SEC),Parent=secFrame})
            N("UIStroke",{Color=T.border,Thickness=1,Transparency=.28,Parent=secFrame})
            rT(secFrame,"BackgroundColor3","section")

            local HDR=0
            local secContent -- forward declare
            if sname~="" then
                HDR=34
                local hdrBtn=N("TextButton",{Size=UDim2.new(1,0,0,34),BackgroundTransparency=1,Text="",ZIndex=6,Parent=secFrame})
                local chipW=TextService:GetTextSize((sicon~="" and sicon.." " or "")..sname:upper(),9,Enum.Font.GothamBold,Vector2.new(9999,9999)).X+24
                local chip=N("Frame",{Size=UDim2.new(0,chipW,0,19),AnchorPoint=Vector2.new(0,.5),
                    Position=UDim2.new(0,10,.5,0),BackgroundColor3=T.accent,BackgroundTransparency=.88,
                    BorderSizePixel=0,ZIndex=7,Parent=hdrBtn})
                N("UICorner",{CornerRadius=UDim.new(1,0),Parent=chip})
                N("UIStroke",{Color=T.accent,Thickness=1,Transparency=.5,Parent=chip})
                rT(chip,"BackgroundColor3","accent")
                local hLbl=N("TextLabel",{Size=UDim2.new(1,-8,1,0),Position=UDim2.new(0,7,0,0),
                    BackgroundTransparency=1,Text=(sicon~="" and sicon.." " or "")..sname:upper(),
                    TextColor3=T.accent,TextSize=9,Font=Enum.Font.GothamBold,
                    TextXAlignment=Enum.TextXAlignment.Left,ZIndex=8,Parent=chip})
                rT(hLbl,"TextColor3","accent")
                local chev=N("TextLabel",{Size=UDim2.new(0,14,1,0),Position=UDim2.new(1,-17,0,0),
                    BackgroundTransparency=1,Text=collapsed and "‚Ėł" or "‚Ėĺ",TextColor3=T.muted,
                    TextSize=10,Font=Enum.Font.GothamBold,ZIndex=7,Parent=hdrBtn})
                rT(chev,"TextColor3","muted")
                local isCol=collapsed
                hdrBtn.MouseButton1Click:Connect(function()
                    isCol=not isCol; chev.Text=isCol and "‚Ėł" or "‚Ėĺ"
                    secContent.Visible=not isCol
                    if isCol then secFrame.Size=UDim2.new(1,0,0,HDR)
                    else
                        local h=secFrame:FindFirstChildWhichIsA("UIListLayout") and secFrame:FindFirstChildWhichIsA("UIListLayout").AbsoluteContentSize.Y or 0
                        secFrame.Size=UDim2.new(1,0,0,HDR+h+18)
                    end
                    task.defer(syncCanvas)
                end)
            end

            secContent = N("Frame",{Size=UDim2.new(1,0,0,0),Position=UDim2.new(0,0,0,HDR),
                BackgroundTransparency=1,ZIndex=4,Parent=secFrame,Visible=not collapsed})
            local secLL = N("UIListLayout",{SortOrder=Enum.SortOrder.LayoutOrder,Padding=UDim.new(0,5),Parent=secContent})
            N("UIPadding",{PaddingLeft=UDim.new(0,8),PaddingRight=UDim.new(0,8),
                PaddingTop=UDim.new(0,sname~="" and 7 or 9),PaddingBottom=UDim.new(0,9),Parent=secContent})

            local BASE = sname~="" and 34 or 6
            secLL:GetPropertyChangedSignal("AbsoluteContentSize"):Connect(function()
                if not secContent.Visible then return end
                local h=secLL.AbsoluteContentSize.Y
                secContent.Size=UDim2.new(1,0,0,h+18)
                secFrame.Size=UDim2.new(1,0,0,BASE+h+18)
                task.defer(syncCanvas)
            end)

            local Sec={Frame=secFrame,Content=secContent,_elems={}}
            table.insert(pageSections,Sec)

            -- ‚ĒÄ‚ĒÄ Element factories ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ
            local function ef(h)
                local f=N("Frame",{Size=UDim2.new(1,0,0,h or EH),
                    BackgroundColor3=T.elem,BackgroundTransparency=.44,
                    BorderSizePixel=0,ClipsDescendants=true,ZIndex=5,Parent=secContent})
                N("UICorner",{CornerRadius=UDim.new(0,CR_EL),Parent=f})
                rT(f,"BackgroundColor3","elem")
                return f
            end
            local function hfx(f)
                f.MouseEnter:Connect(function()tw(f,.1,{BackgroundTransparency=.12,BackgroundColor3=T.elemHov})end)
                f.MouseLeave:Connect(function()tw(f,.1,{BackgroundTransparency=.44,BackgroundColor3=T.elem})end)
            end
            local function mL(p,txt,y)
                local l=N("TextLabel",{Size=UDim2.new(1,-96,0,17),Position=UDim2.new(0,12,0,y),
                    BackgroundTransparency=1,Text=txt,TextColor3=T.text,TextSize=TSZ,
                    Font=Enum.Font.GothamSemibold,TextXAlignment=Enum.TextXAlignment.Left,
                    TextTruncate=Enum.TextTruncate.AtEnd,ZIndex=7,Parent=p})
                rT(l,"TextColor3","text"); return l
            end
            local function sL(p,txt,y)
                local l=N("TextLabel",{Size=UDim2.new(1,-96,0,13),Position=UDim2.new(0,12,0,y),
                    BackgroundTransparency=1,Text=txt,TextColor3=T.sub,TextSize=SSZ,
                    Font=Enum.Font.Gotham,TextXAlignment=Enum.TextXAlignment.Left,ZIndex=7,Parent=p})
                rT(l,"TextColor3","sub"); return l
            end
            local function addTip(f,text)
                if not text or text=="" then return end
                f.MouseEnter:Connect(function()showTip(text)end)
                f.MouseLeave:Connect(hideTip)
            end
            local function depFn(obj,other,cond)
                local function chk()
                    local ok=cond and cond(other:Get()) or other:Get()==true
                    obj._frame.Visible=ok
                end; chk()
                table.insert(W._conns,RunService.Heartbeat:Connect(function()pcall(chk)end))
            end
            local function regE(id,obj,sn,frame)
                if id then W._elems[id]=obj; obj._id=id end
                obj._sn=sn; obj._frame=frame
                table.insert(Sec._elems,obj)
                return obj
            end

            -- ‚ēź‚ēź BUTTON (+ ripple) ‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź
            function Sec:AddButton(o)
                o=o or{}
                local desc=o.Description or ""
                local f=ef(desc~="" and EHS or EH); hfx(f)
                mL(f,o.Name or "Button",desc~="" and 8 or 12)
                if desc~="" then sL(f,desc,26) end
                addTip(f,o.Tooltip)
                local arr=N("TextLabel",{Size=UDim2.new(0,22,1,0),Position=UDim2.new(1,-26,0,0),
                    BackgroundTransparency=1,Text="‚Äļ",TextColor3=T.accent,TextSize=24,
                    Font=Enum.Font.GothamBold,ZIndex=7,Parent=f})
                rT(arr,"TextColor3","accent")
                local btn=N("TextButton",{Size=UDim2.new(1,0,1,0),BackgroundTransparency=1,Text="",AutoButtonColor=false,ZIndex=9,Parent=f})
                btn.MouseButton1Down:Connect(function(x,y)
                    tw(f,.06,{BackgroundTransparency=0,BackgroundColor3=T.elemAct})
                    mkRipple(f,x-f.AbsolutePosition.X,y-f.AbsolutePosition.Y,T.accent)
                end)
                btn.MouseButton1Up:Connect(function()
                    tw(f,.14,{BackgroundTransparency=.44,BackgroundColor3=T.elem})
                    if o.Callback then task.spawn(o.Callback) end
                end)
                local Obj={_frame=f}
                function Obj:SetVisible(v)f.Visible=v end; function Obj:Get()return nil end; function Obj:Set()end
                function Obj:DependsOn(other,cond)depFn(self,other,cond)end
                return regE(o.Id,Obj,o.Name,f)
            end

            -- ‚ēź‚ēź TOGGLE (spring knob) ‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź
            function Sec:AddToggle(o)
                o=o or{}
                local desc=o.Description or ""
                local f=ef(desc~="" and EHS or EH); hfx(f)
                local val=o.Default==true
                mL(f,o.Name or "Toggle",desc~="" and 8 or 12)
                if desc~="" then sL(f,desc,28) end
                addTip(f,o.Tooltip)
                local track=N("Frame",{Size=UDim2.new(0,46,0,25),Position=UDim2.new(1,-54,.5,-12),
                    BackgroundColor3=val and T.accent or T.muted,BorderSizePixel=0,ZIndex=7,Parent=f})
                N("UICorner",{CornerRadius=UDim.new(1,0),Parent=track})
                local trkStroke=N("UIStroke",{Color=T.accent,Thickness=2,Transparency=val and .5 or 1,Parent=track})
                rT(trkStroke,"Color","accent")
                local knob=N("Frame",{Size=UDim2.new(0,19,0,19),
                    Position=val and UDim2.new(1,-22,.5,-9) or UDim2.new(0,3,.5,-9),
                    BackgroundColor3=Color3.fromRGB(255,255,255),BorderSizePixel=0,ZIndex=8,Parent=track})
                N("UICorner",{CornerRadius=UDim.new(1,0),Parent=knob})
                local function setV(v,fire)
                    local prev=val; val=v
                    tw(track,.22,{BackgroundColor3=v and T.accent or T.muted})
                    tw(trkStroke,.22,{Transparency=v and .5 or 1})
                    twSpring(knob,.3,{Position=v and UDim2.new(1,-22,.5,-9) or UDim2.new(0,3,.5,-9)})
                    if fire~=false then
                        if o.Id then push(function()setV(v,true)end,function()setV(prev,true)end) end
                        if o.Callback then task.spawn(o.Callback,v) end
                    end
                end
                N("TextButton",{Size=UDim2.new(1,0,1,0),BackgroundTransparency=1,Text="",ZIndex=9,Parent=f})
                    .MouseButton1Click:Connect(function()setV(not val)end)
                local Obj={Value=val,_frame=f}
                function Obj:Set(v,s)setV(v,s~=false);self.Value=v end
                function Obj:Get()return val end; function Obj:SetVisible(v)f.Visible=v end
                function Obj:DependsOn(other,cond)depFn(self,other,cond)end
                return regE(o.Id,Obj,o.Name,f)
            end

            -- ‚ēź‚ēź SLIDER (accent pill value) ‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź
            function Sec:AddSlider(o)
                o=o or{}
                local mn=o.Min or 0; local mx=o.Max or 100
                local suf=o.Suffix or ""; local step=o.Step
                local val=clamp(o.Default or mn,mn,mx)
                local f=ef(56)
                mL(f,o.Name or "Slider",9); addTip(f,o.Tooltip)
                local valPill=N("Frame",{Size=UDim2.new(0,58,0,21),Position=UDim2.new(1,-64,0,7),
