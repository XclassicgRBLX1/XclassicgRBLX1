        local function toggle()
            isCollapsed=not isCollapsed
            if isCollapsed then
                tw(content,.18,{Size=UDim2.new(1,0,0,0)})
                tw(arrow,.15,{Rotation=0})
            else
                tw(arrow,.15,{Rotation=180})
                task.defer(function()
                    local h=cLL.AbsoluteContentSize.Y+10
                    tw(content,.18,{Size=UDim2.new(1,0,0,h)})
                end)
            end
        end

        if collapsed then
            isCollapsed=true
            arrow.Rotation=0
        else
            arrow.Rotation=180
        end

        hdr.InputBegan:Connect(function(i)
            if i.UserInputType==Enum.UserInputType.MouseButton1 or i.UserInputType==Enum.UserInputType.Touch then toggle() end
        end)

        -- Size tracking
        cLL:GetPropertyChangedSignal("AbsoluteContentSize"):Connect(function()
            if not isCollapsed then
                local h=cLL.AbsoluteContentSize.Y+10
                tw(sec,.15,{Size=UDim2.new(1,0,0,h+28)})
            end
        end)

        local Section={_content=content,_layout=cLL,_frame=sec}
        function Section:AddElement(el)
            if el and el.Parent then el.Parent=content end
        end
        function Section:Toggle() toggle() end
        function Section:SetCollapsed(v)
            if v and not isCollapsed then toggle()
            elseif not v and isCollapsed then toggle() end
        end

        return Section
    end

