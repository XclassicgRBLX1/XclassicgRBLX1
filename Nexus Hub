    -- ‚ĒÄ‚ĒÄ Registry & undo stack
    local reg, uStk, rStk = {}, {}, {}
    local function rT(inst, prop, key)
        table.insert(reg, {i=inst, p=prop, k=key})
        if inst and inst.Parent then inst[prop] = T[key] end
    end
    local function push(doFn, undoFn)
        table.insert(uStk, {d=doFn, u=undoFn})
        rStk = {}
        if #uStk > 60 then table.remove(uStk, 1) end
    end
    local function applyTheme(nT)
        T = nT
        for _, r in ipairs(reg) do
            pcall(function() if r.i and r.i.Parent then r.i[r.p] = nT[r.k] end end)
        end
