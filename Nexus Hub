    function W:CreateWatermark(o)
        o=o or {}
        local text=o.Text or title
        local wmF=New("Frame",{
            Size=UDim2.new(0,10,0,28),Position=o.Position or UDim2.new(0,10,0,10),
            BackgroundColor3=T.TopBar,BackgroundTransparency=0.08,
            BorderSizePixel=0,ZIndex=500,Parent=sg
        })
        New("UICorner",{CornerRadius=UDim.new(0,7),Parent=wmF})
        New("UIStroke",{Color=T.Border,Thickness=1,Transparency=0.3,Parent=wmF})
        New("Frame",{
            Size=UDim2.new(0,3,1,-8),Position=UDim2.new(0,5,.5,0),AnchorPoint=Vector2.new(0,.5),
            BackgroundColor3=T.Accent,BorderSizePixel=0,ZIndex=501,Parent=wmF
        })
        local wmLbl=New("TextLabel",{
            Size=UDim2.new(1,-18,1,0),Position=UDim2.new(0,14,0,0),
            BackgroundTransparency=1,Text=text,
            TextColor3=T.Text,TextSize=12,Font=Enum.Font.GothamBold,
            TextXAlignment=Enum.TextXAlignment.Left,ZIndex=502,Parent=wmF
        })
        local function Rsz()
            local tw=TSize(wmLbl.Text,12).X
            TweenQ(wmF,.2,{Size=UDim2.new(0,tw+26,0,28)})
        end
        wmLbl:GetPropertyChangedSignal("Text"):Connect(Rsz); task.defer(Rsz)
        local wmd,wmds,wmws
        wmF.InputBegan:Connect(function(i)
            if i.UserInputType==Enum.UserInputType.MouseButton1 then wmd=true;wmds=i.Position;wmws=wmF.Position end
        end)
        table.insert(W._conns,UserInputService.InputChanged:Connect(function(i)
            if wmd and i.UserInputType==Enum.UserInputType.MouseMovement then
                local d=i.Position-wmds
                wmF.Position=UDim2.new(wmws.X.Scale,wmws.X.Offset+d.X,wmws.Y.Scale,wmws.Y.Offset+d.Y)
            end
        end))
        table.insert(W._conns,UserInputService.InputEnded:Connect(function(i)
            if i.UserInputType==Enum.UserInputType.MouseButton1 then wmd=false end
        end))
        local WM={}
        function WM:SetText(t) wmLbl.Text=t end
        function WM:SetVisible(v) wmF.Visible=v end
        return WM
    end

    -- ══════════════════════════════════════════
    --  C O N F I G
    -- ══════════════════════════════════════════
    function W:SaveConfig(name,data)
        if not writefile then return false end
        return pcall(writefile,(name or "nexus")..".json",HttpService:JSONEncode(data or {}))
    end
    function W:LoadConfig(name)
        if not readfile then return nil end
        local ok,raw=pcall(readfile,(name or "nexus")..".json")
        if not ok then return nil end
        local ok2,t=pcall(function() return HttpService:JSONDecode(raw) end)
        return ok2 and t or nil
    end

    -- ══════════════════════════════════════════
    --  K E Y B I N D S   T A B
    -- ══════════════════════════════════════════
    function W:AddBindsTab()
        local bt=self:AddTab({Name="Keybinds",Icon="⌨"})
        local bs=bt:AddSection({Name="REGISTERED KEYBINDS"})
        if #W._keybinds==0 then
            bs:AddLabel({Text="No keybinds registered.",Color=T.Muted})
        else
            for _,b in ipairs(W._keybinds) do
                bs:AddLabel({Text="  ›  "..b.Name.."  —  "..(b.Ref.key==Enum.KeyCode.Unknown and "None" or b.Ref.key.Name),Color=T.SubText})
            end
        end
        bs:AddDivider("Window")
        bs:AddLabel({Text="  ›  Toggle UI  —  "..toggleKey.Name,Color=T.Muted})
        return bt
    end

    -- ══════════════════════════════════════════
    --  U T I L S
    -- ══════════════════════════════════════════
    function W:Toggle() W.Visible=not W.Visible; wrap.Visible=W.Visible end
    function W:SetTitle(t) titleLbl2.Text=t end
    function W:Destroy()
        for _,c in ipairs(W._conns) do pcall(function() c:Disconnect() end) end
        if blur then TweenQ(blur,.3,{Size=0}); task.delay(.3,function() pcall(function() blur:Destroy() end) end) end
        pcall(function() sg:Destroy() end)
    end

    return W
end

return Nexus
