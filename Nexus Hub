            taskChecks[i] = {dot=dot, lbl=rowLbl, done=false}
        end
        -- small spacer
        New("Frame",{Size=UDim2.new(1,0,0,10),BackgroundTransparency=1,LayoutOrder=5,Parent=card})
    end

    -- Progress bar section
    local barSection = New("Frame",{
        Size=UDim2.new(1,0,0,46),BackgroundTransparency=1,
        LayoutOrder=6,ZIndex=4,Parent=card
