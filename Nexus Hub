    local fpsA, fpsT = 60, 0
    table.insert(W._conns, RunService.Heartbeat:Connect(function(dt)
        fpsT = fpsT + dt
        if fpsT >= 1 then
            fpsA = math.floor(1/dt)
            local ping = math.floor((Stats.Network and Stats.Network.ServerStatsItem and
                Stats.Network.ServerStatsItem["Data Ping"] and
                Stats.Network.ServerStatsItem["Data Ping"].Value) or 0)
            local mem  = math.floor(Stats:GetTotalMemoryUsageMb and Stats:GetTotalMemoryUsageMb() or 0)
            fpslbl.Text = fpsA.."fps  "..ping.."ms  "..mem.."mb"
            fpsT = 0
        end
    end))

    -- ‚ĒÄ‚ĒÄ Live theme switch
    function W:SetTheme(name)
        local nT = (type(name)=="table") and name or Nexus.Themes[name]
        if not nT then return end
        tname = type(name)=="string" and name or "Custom"
        applyTheme(nT)
    end
    function W:SetAccent(color3)
        T.accent = color3
        for _, r in ipairs(reg) do
            if r.k=="accent" then pcall(function()
                if r.i and r.i.Parent then r.i[r.p]=color3 end end) end
        end
    end
    function W:SetGradientAccent(c1, c2)
        -- Apply gradient to topstripe and active indicators via UIGradient
        local g = topStripe:FindFirstChildWhichIsA("UIGradient")
        if not g then g = Instance.new("UIGradient"); g.Parent = topStripe end
        g.Color = ColorSequence.new({
            ColorSequenceKeypoint.new(0, c1),
            ColorSequenceKeypoint.new(1, c2)
        })
        T.accent = c1
    end
    function W:SetSubtitle(text)
        subtitleLbl.Text = text
        titleLbl.Size = UDim2.new(1,-200,0,text~="" and 16 or 22)
        titleLbl.Position = UDim2.new(0,hasSB and 16 or 14,0,text~="" and 6 or 12)
    end
    function W:SetStatusBar(text, statusType)
        local cols = {Ready=T.success,Warning=T.warning,Error=T.error,Info=T.info}
        statLbl.Text = text or ""
        local c = cols[statusType or "Ready"] or T.success
        tw(statDot,.2,{BackgroundColor3=c})
    end
    function W:FlashElement(id)
        local el = self._elems[id]
        if not el or not el._frame then return end
        local f = el._frame
        tw(f,.1,{BackgroundTransparency=0, BackgroundColor3=T.accent})
        task.delay(.14,function() tw(f,.3,{BackgroundTransparency=.42, BackgroundColor3=T.elem}) end)
    end

    -- ‚ĒÄ‚ĒÄ Confetti
    function W:Confetti()
        local colors = {T.accent, T.success, T.warning, T.error, T.info, T.accentH}
        for i=1,50 do
            task.delay(i*.03, function()
                local vp2 = getVP()
                local p = N("Frame", {
                    Size=UDim2.new(0,6,0,6),
                    Position=UDim2.new(0,math.random(20,vp2.X-20),0,-10),
                    BackgroundColor3=colors[math.random(#colors)],
                    BorderSizePixel=0, ZIndex=1000, Parent=sg})
                N("UICorner",{CornerRadius=UDim.new(1,0),Parent=p})
                local ty = math.random(vp2.Y//3, vp2.Y+50)
                tw(p, math.random(8,16)*.1, {Position=UDim2.new(0,p.Position.X.Offset+math.random(-80,80),0,ty),
                    BackgroundTransparency=1}, Enum.EasingStyle.Cubic, Enum.EasingDirection.In)
                task.delay(1.8,function() pcall(function()p:Destroy()end) end)
            end)
        end
    end

