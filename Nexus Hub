    local wrap=N("Frame",{Size=winSz,Position=winPos,BackgroundTransparency=1,Parent=sg})
    -- shadow
    N("ImageLabel",{Size=UDim2.new(1,50,1,50),Position=UDim2.new(0,-25,0,-25),BackgroundTransparency=1,
        Image="rbxassetid://6014261993",ImageColor3=Color3.fromRGB(0,0,0),ImageTransparency=.6,
