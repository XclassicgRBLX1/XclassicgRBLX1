    New("Frame",{Size=UDim2.new(1,0,0,12),BackgroundTransparency=1,LayoutOrder=7,Parent=card})
    local footF = New("Frame",{
        Size=UDim2.new(1,0,0,12),BackgroundTransparency=1,
        LayoutOrder=8,ZIndex=4,Parent=card
    })
    New("TextLabel",{
        Size=UDim2.new(.5,0,1,0),BackgroundTransparency=1,
        Text="v4.0  •  NexusUI",
        TextColor3=T.Muted,TextSize=10,Font=Enum.Font.Gotham,
        TextXAlignment=Enum.TextXAlignment.Left,
        ZIndex=5,Parent=footF
    })
    New("TextLabel",{
        Size=UDim2.new(.5,0,1,0),Position=UDim2.new(.5,0,0,0),
        BackgroundTransparency=1,
        Text="github.com/your/repo",
        TextColor3=T.Muted,TextSize=10,Font=Enum.Font.Gotham,
        TextXAlignment=Enum.TextXAlignment.Right,
        ZIndex=5,Parent=footF
    })

    -- ── Animations ─────────────────────────────
    -- Resize card once layout settles
    task.defer(function()
        local h=cardLayout.AbsoluteContentSize.Y+52
        card.Size=UDim2.new(0,cardW,0,0)
        TweenQ(card,.5,{Size=UDim2.new(0,cardW,0,h)})
        task.wait(.3)
        TweenQ(titleLbl,.4,{TextTransparency=0})
        TweenQ(subLbl,.4,{TextTransparency=0})
    end)

    -- Grid dots pulse
    local dotPhase = 0
    local spinConn = RunService.Heartbeat:Connect(function(dt)
        dotPhase = dotPhase + dt*2.5
        for i,d in ipairs(dots) do
            local ph = dotPhase+(i-1)*(math.pi*.45)
            local t2 = (math.sin(ph)+1)*.5
            d.BackgroundTransparency = Lerp(.1,.85,1-t2)
            local s=Lerp(4,8,t2); d.Size=UDim2.new(0,s,0,s)
        end
        for i,gd in ipairs(gridDots) do
            local ph2 = dotPhase*(0.3+i*.008)+(i*.22)
            gd.BackgroundTransparency = Lerp(0.88,0.97,(math.sin(ph2)+1)*.5)
        end
        local sp=(dotPhase%(math.pi*2))/(math.pi*2)
        shimmer.Position=UDim2.new(sp*1.3-.15,0,0,0)
    end)

    -- ── Loader API ─────────────────────────────
    local Loader = {}
    local function SetProg(frac,label)
        local pct=math.floor(Clamp(frac,0,1)*100)
        TweenQ(barFill,.35,{Size=UDim2.new(Clamp(frac,0,1),0,1,0)})
        pctRLbl.Text=pct.."%"
        if label then taskActiveLbl.Text=label end
    end

    function Loader:Run(onComplete)
        task.wait(.6)  -- let intro animate
        local total=math.max(#tasks,1)
        if #tasks==0 then
            for i=0,10 do SetProg(i/10,"Loading..."); task.wait(.07) end
        else
            for i,tk in ipairs(tasks) do
                SetProg((i-1)/total, "▶  "..(tk.Name or "..."))
                -- dim previous check
                if taskChecks[i] then
                    TweenQ(taskChecks[i].dot,.2,{BackgroundColor3=T.Accent})
                    TweenQ(taskChecks[i].lbl,.2,{TextColor3=T.Text})
                end
                task.wait(tk.Duration or 0.55)
                SetProg(i/total, tk.Name)
                if taskChecks[i] then
                    taskChecks[i].dot.BackgroundColor3=T.Success
                    taskChecks[i].lbl.TextColor3=T.SubText
                    taskChecks[i].lbl.Text="✓  "..(tk.Name or "")
                    TweenQ(taskChecks[i].dot,.2,{BackgroundColor3=T.Success})
                end
            end
        end
        SetProg(1,"Ready!")
        taskActiveLbl.TextColor3=T.Success
        task.wait(.5)
        spinConn:Disconnect()
        TweenQI(card,.38,{BackgroundTransparency=1,Size=UDim2.new(0,cardW,0,card.AbsoluteSize.Y-20)})
        TweenQI(bg,  .5,{BackgroundTransparency=1})
        task.wait(.52)
        pcall(function() sg:Destroy() end)
        if onComplete then task.spawn(onComplete) end
    end

    function Loader:SetStatus(t)  subLbl.Text=t end
    function Loader:SetTask(t)    taskActiveLbl.Text=t end
    function Loader:SetProgress(f) SetProg(f) end
    function Loader:Finish(cb)
        spinConn:Disconnect(); SetProg(1)
        task.wait(.3)
        TweenQI(card,.38,{BackgroundTransparency=1})
        TweenQI(bg,  .5, {BackgroundTransparency=1})
        task.wait(.52)
        pcall(function() sg:Destroy() end)
        if cb then task.spawn(cb) end
    end

    return Loader
end

