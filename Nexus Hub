                local Obj={Value=val,_frame=f}
                function Obj:Set(v)sv(v);self.Value=val end; function Obj:Get()return val end
                function Obj:SetVisible(v)f.Visible=v end
                function Obj:DependsOn(other,cond)depFn(self,other,cond)end
                return regE(o.Id,Obj,o.Name,f)
            end

            -- ‚ēź‚ēź‚ēź DROPDOWN ‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź
            function Sec:AddDropdown(o)
                o=o or{}
                local items=o.Items or{}; local multi=o.Multi==true
                local sel=multi and{} or (o.Default or (items[1] or "Select..."))
                local IH=30; local MV=5
                local LH=math.min(#items,MV)*IH+38
                local CLOSED=EH
                local f=ef(CLOSED); f.ClipsDescendants=true
                mL(f,o.Name or "Dropdown",12); addTip(f,o.Tooltip)
                local selBg=N("Frame",{Size=UDim2.new(0,160,0,28),Position=UDim2.new(1,-168,.5,-14),
