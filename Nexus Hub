    -- ════════════════════════════════════════════
    --  CONSOLE LOG TAB
    -- ════════════════════════════════════════════
    function W:AddConsoleTab()
        local tab=self:AddTab({Name="Console",Icon=">"})
        local sec=tab:AddSection({Name="LOG OUTPUT"})
        local logLbls={}
        local function addLog(msg,col)
            local lbl=sec:AddLabel({Text=msg,Color=col or T.sub})
            table.insert(logLbls,lbl)
            -- keep only last 50
            if #logLbls>50 then
                logLbls[1]:SetVisible(false)
                table.remove(logLbls,1)
            end
        end
        -- hook print
        local oldPrint=print
        print=function(...)
            oldPrint(...)
            local args={...}
            local parts={}
            for _,v in ipairs(args) do table.insert(parts,tostring(v)) end
            pcall(function()addLog("› "..table.concat(parts,"  "),T.sub)end)
        end
        local clrSec=tab:AddSection({})
        clrSec:AddButtonRow({Buttons={
            {Name="Clear",Callback=function()
                for _,l in ipairs(logLbls) do l:SetVisible(false) end
                logLbls={}
            end},
            {Name="Test Print",Callback=function()
                print("Hello from console test!","value=",math.random(100))
            end},
        }})
        table.insert(consoleLogs,{tab=tab,addLog=addLog})
        return tab
    end

    -- ════════════════════════════════════════════
    --  KEYBINDS TAB
    -- ════════════════════════════════════════════
    function W:AddBindsTab()
        local bt=self:AddTab({Name="Keybinds",Icon="⌨"})
        local bs=bt:AddSection({Name="REGISTERED KEYBINDS"})
        if #W._keybinds==0 then bs:AddLabel({Text="No keybinds registered yet.",Color=T.muted})
        else
            for _,b in ipairs(W._keybinds) do
                bs:AddLabel({Text="  ›  "..b.Name.."  —  "..(b.Ref.key==Enum.KeyCode.Unknown and "None" or b.Ref.key.Name),Color=T.sub})
            end
        end
        bs:AddDivider("Window")
        bs:AddLabel({Text="  ›  Toggle UI  —  "..toggleKey.Name,Color=T.muted})
        bs:AddLabel({Text="  ›  Ctrl+Z  —  Undo last change",Color=T.muted})
        bs:AddLabel({Text="  ›  Ctrl+Y  —  Redo",Color=T.muted})
        bs:AddButton({Name="Show Keybind Overlay",Callback=function()W:ShowBinds()end})
        return bt
    end

    return W
