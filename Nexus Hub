        dbgL[i] = N("TextLabel",{Size=UDim2.new(1,-12,0,17),
            Position=UDim2.new(0,6,0,(i-1)*18+5),BackgroundTransparency=1,Text="",
            TextColor3=Color3.fromRGB(0,220,120),TextSize=10,Font=Enum.Font.Code,
            TextXAlignment=Enum.TextXAlignment.Left,ZIndex=1000,Parent=dbgOv})
    end
    local _dbgHB; local _dbgFPS=0; local _dbgF=0
    local function startDbg()
        if _dbgHB then return end
        _dbgHB = RunService.Heartbeat:Connect(function(dt)
            _dbgFPS = lerp(_dbgFPS,1/dt,.1); _dbgF+=1
            if _dbgF%12==0 then
                local ps=""
                for k,p in pairs(_sharedPools) do ps=ps..k:sub(1,2).."="..#p._free.." " end
                dbgL[1].Text = "FPS    "..math.floor(_dbgFPS)
                dbgL[2].Text = "Focus  ".._focusIdx.."/"..#_focusables
                dbgL[3].Text = "Pool   "..ps
                dbgL[4].Text = "Theme  "..tname
            end
        end)
    end
    local function stopDbg()
        if _dbgHB then _dbgHB:Disconnect(); _dbgHB=nil end
    end
    -- Wrap Destroy to stop debug loop
    local _origDest = W.Destroy
    function W:Destroy() stopDbg(); _origDest(self) end

    -- ── Developer Tab ─────────────────────────────────────────────
    function W:AddDevTab()
        local dt = self:AddTab({Name="⚙ Dev", Icon="◎"})

        -- Debug overlay
        local s1 = dt:AddSection({Name="DEBUG OVERLAY"})
        s1:AddToggle({Name="Show Overlay",Default=false,
            Description="FPS · Focus · Pool counts · Active theme",
            Callback=function(v)
                dbgOv.Visible=v
                if v then startDbg() else stopDbg() end
            end})
        s1:AddButtonRow({Buttons={
            {Name="Flush Pools",Callback=function()
                for _,p in pairs(_sharedPools) do p:flush() end
                W:Notify({Title="Dev",Content="Pools flushed.",Type="Info",Duration=2})
            end},
            {Name="Clear Log",Callback=function()
                _errLog={}
                W:Notify({Title="Dev",Content="Error log cleared.",Type="Info",Duration=2})
            end},
        }})

        -- Error log
        local s2 = dt:AddSection({Name="ERROR LOG",Collapsed=true})
        s2:AddLabel({Text="Call W:Debug(msg, level) to push entries.",Color=T.muted})
        local logLbls={}
        for i=1,8 do table.insert(logLbls, s2:AddLabel({Text="",Color=T.sub})) end
        s2:AddButton({Name="Refresh Log",Callback=function()
            for i=1,8 do
                local e=_errLog[i]
                if e and logLbls[i] then
                    local cm={info=T.sub,warn=T.warning,error=T.error}
                    logLbls[i]:Set("["..e.level:upper().."] "..e.msg, cm[e.level] or T.sub)
                end
            end
        end})

        -- Pool stats
        local s3 = dt:AddSection({Name="POOL STATS",Collapsed=true})
        local pTbl = s3:AddTable({Columns={"Class","Free","Created","Recycled"},Rows={}})
        s3:AddButton({Name="Refresh",Callback=function()
            local rows={}
            for k,p in pairs(_sharedPools) do
                local st=p:stats()
                table.insert(rows,{k,tostring(#p._free),tostring(st.created),tostring(st.recycled)})
            end
            pTbl:Update(rows)
        end})

        -- Theme preview
        local s4 = dt:AddSection({Name="THEME PREVIEW"})
        s4:AddParagraph({Title="All Themes",
            Body="v7.0 adds Glassmorphism (frosted white glass) and "..
                 "Neumorphism (soft clay). Select below to preview live."})
        local tNames={}
        for k in pairs(Nexus.Themes) do table.insert(tNames,k) end
        table.sort(tNames)
        s4:AddDropdown({Name="Preview Theme",Items=tNames,Default=tname,
            Callback=function(v) W:SetTheme(v) end})
        s4:AddButtonRow({Buttons={
            {Name="Reset BlackModern",Callback=function() W:SetTheme("BlackModern") end},
        }})

        -- Spring / Sequence tester
        local s5 = dt:AddSection({Name="ANIMATION TESTER",Collapsed=true})
        s5:AddParagraph({Title="Spring Physics",
            Body="Nexus:Spring(obj, {prop=target}, cfg) — mass-spring damper on any numeric property."})
        s5:AddButtonRow({Buttons={
            {Name="▶ Spring",Callback=function()
                local h = Nexus:Spring(main,{BackgroundTransparency=.25},{k=280,d=20,
                    onSettle=function() tw(main,.3,{BackgroundTransparency=0}) end})
                W:Notify({Title="Spring",Content="Spring fired on main frame.",Type="Info",Duration=2})
            end},
            {Name="▶ Sequence",Callback=function()
                W:Sequence({
                    {obj=main,time=.12,props={BackgroundTransparency=.3}},
                    {obj=main,time=.12,props={BackgroundTransparency=0}},
                    {obj=main,time=.10,props={BackgroundTransparency=.15}},
                    {obj=main,time=.16,props={BackgroundTransparency=0}},
                },function()
                    W:Notify({Title="Sequence",Content="Flash sequence complete.",Type="Success",Duration=2})
                end)
            end},
        }})

        -- Notify tester
        local s6 = dt:AddSection({Name="NOTIFY TESTER",Collapsed=true})
        s6:AddButtonRow({Buttons={
            {Name="Normal",  Callback=function()
                W:Notify({Title="Normal",Content="Standard dismiss.",Type="Info",Priority="Normal",Duration=4}) end},
            {Name="High",    Callback=function()
                W:Notify({Title="High",Content="High priority.",Type="Warning",Priority="High",Duration=4}) end},
        }})
        s6:AddButtonRow({Buttons={
            {Name="Critical",Callback=function()
                W:Notify({Title="Critical",Content="No auto-dismiss. X to close.",Type="Error",Priority="Critical"}) end},
            {Name="Actions", Callback=function()
                W:Notify({Title="With Actions",Content="Choose an action below.",Type="Success",Priority="Normal",Duration=8,
                    Actions={
                        {Label="✓ Accept",Callback=function() W:Debug("Action: Accept","info") end},
                        {Label="✕ Deny",  Callback=function() W:Debug("Action: Deny","warn") end, DismissOnClick=false},
                    }}) end},
        }})

        -- Graph demo
        local s7 = dt:AddSection({Name="GRAPH DEMO",Collapsed=true})
        s7:AddParagraph({Title="AddGraph",Body="sec:AddGraph() — ring-buffer line/bar chart with pooled frames."})
        local gDemo = s7:AddGraph({Name="Live FPS",Type="Line",Height=60,Max=120,Min=0,MaxPoints=30})
        local gBar  = s7:AddGraph({Name="Random Bars",Type="Bar",Height=50,Max=100,Min=0,MaxPoints=10})
        s7:AddButtonRow({Buttons={
            {Name="Push Random",Callback=function()
                gDemo:Push(math.random(40,120))
                gBar:Push(math.random(10,100))
            end},
            {Name="Clear",Callback=function() gDemo:Clear(); gBar:Clear() end},
        }})

        -- List demo
        local s8 = dt:AddSection({Name="LIST DEMO",Collapsed=true})
        s8:AddParagraph({Title="AddList",Body="sec:AddList() — virtualized scrolling list with search filter and object pooling."})
        local items={}; for i=1,40 do table.insert(items,"Item "..i) end
        s8:AddList({Name="Virtualized (40 items)",Items=items,MaxVisible=5,
            Callback=function(v) W:Debug("List selected: "..tostring(v),"info") end})

        return dt
    end

    return W
end

return Nexus
