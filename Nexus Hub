    -- ══════════════════════════════════════════════
    --  AUTO-SAVE CONFIG
    -- ══════════════════════════════════════════════
    function W:EnableAutoSave(interval, name)
        interval=interval or 30
        name=name or "autosave"
        if W._autoSaveConn then W._autoSaveConn:Disconnect() end
        local elapsed=0
        W._autoSaveConn=RunService.Heartbeat:Connect(function(dt)
            elapsed=elapsed+dt
            if elapsed>=interval then
                elapsed=0
                W:SaveConfig(name)
            end
        end)
        return W._autoSaveConn
    end

    -- ══════════════════════════════════════════════
    --  CONFIG SYSTEM (saves ALL elements + theme)
    -- ══════════════════════════════════════════════
    function W:SaveConfig(name, extra)
        name=name or "nexus"
        local data={_theme=themeName,_extra=extra or{},_elems={}}
        for id,elem in pairs(W._elems) do
            pcall(function()
                data._elems[id]=elem:Get()
            end)
        end
        if not writefile then return false,"writefile not available" end
        local ok,err=pcall(writefile,name..".json",HttpService:JSONEncode(data))
        return ok,err
    end

    function W:LoadConfig(name)
        name=name or "nexus"
        if not readfile then return nil,"readfile not available" end
        local ok,raw=pcall(readfile,name..".json")
        if not ok then return nil,"file not found" end
        local ok2,data=pcall(function()return HttpService:JSONDecode(raw)end)
        if not ok2 or not data then return nil,"invalid JSON" end
        -- apply theme
        if data._theme and Nexus.Themes[data._theme] then
            W:SetTheme(data._theme)
        end
        -- apply elements
        if data._elems then
            for id,val in pairs(data._elems) do
                if W._elems[id] then
                    pcall(function() W._elems[id]:Set(val) end)
                end
            end
        end
        return data,nil
    end

    -- Profile management
    function W:SaveProfile(profileName)
        local ok,err=W:SaveConfig("profile_"..profileName)
        return ok,err
    end
    function W:LoadProfile(profileName)
        return W:LoadConfig("profile_"..profileName)
    end

