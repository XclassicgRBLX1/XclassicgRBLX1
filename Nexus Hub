    function W:CreateTab(opts)
        opts=opts or {}
        local label=opts.Title or "Tab"
        local icon=opts.Icon or ""
        local badge=opts.Badge or 0

        local page=N("Frame",{Size=UDim2.new(1,0,1,0),BackgroundTransparency=1,Visible=false,ZIndex=2,Parent=pageCon})
        local pageScroll=N("ScrollingFrame",{Size=UDim2.new(1,0,1,0),BackgroundTransparency=1,ScrollBarThickness=2,ScrollBarImageColor3=T.scroll,ScrollingDirection=Enum.ScrollingDirection.Y,CanvasSize=UDim2.new(0,0,0,0),ZIndex=3,Parent=page})
        rT(pageScroll,"ScrollBarImageColor3","scroll")
        local pageLL=N("UIListLayout",{SortOrder=Enum.SortOrder.LayoutOrder,Padding=UDim.new(0,4),Parent=pageScroll})
        N("UIPadding",{PaddingLeft=UDim.new(0,10),PaddingRight=UDim.new(0,10),PaddingTop=UDim.new(0,8),PaddingBottom=UDim.new(0,10),Parent=pageScroll})
        pageLL:GetPropertyChangedSignal("AbsoluteContentSize"):Connect(function()
            pageScroll.CanvasSize=UDim2.new(0,0,0,pageLL.AbsoluteContentSize.Y+16)
        end)

        -- Slide transition container
        local slideC=N("Frame",{Size=UDim2.new(1,0,1,0),BackgroundTransparency=1,ClipsDescendants=true,ZIndex=1,Parent=page})
        local slideL=N("Frame",{Size=UDim2.new(1,0,1,0),BackgroundTransparency=1,ClipsDescendants=true,ZIndex=2,Parent=slideC})

        -- Move scroll into slide
        pageScroll.Parent=slideL

        local tabBtn
        if SW>0 and sidebar then
            tabBtn=N("TextButton",{Size=UDim2.new(1,-8,0,32),BackgroundColor3=Color3.fromRGB(0,0,0),BackgroundTransparency=1,Text=(icon~="" and icon.."  " or "")..label,TextColor3=T.sub,TextSize=10,Font=Enum.Font.Gotham,TextXAlignment=Enum.TextXAlignment.Left,AutoButtonColor=false,LayoutOrder=#W.Tabs+1,ZIndex=6,Parent=tabScrollF})
            rT(tabBtn,"TextColor3","sub")
            -- Active indicator
            local actInd=N("Frame",{Size=UDim2.new(0,0,0,16),AnchorPoint=Vector2.new(0,.5),Position=UDim2.new(0,0,.5,0),BackgroundColor3=T.accent,BorderSizePixel=0,BackgroundTransparency=1,ZIndex=7,Parent=tabBtn})
            N("UICorner",{CornerRadius=UDim.new(0,2),Parent=actInd})
            rT(actInd,"BackgroundColor3","accent")
            -- Badge
            local badgeF
            if badge>0 then
                badgeF=N("Frame",{Size=UDim2.new(0,16,0,14),AnchorPoint=Vector2.new(1,.5),Position=UDim2.new(1,-2,.5,0),BackgroundColor3=T.accent,BorderSizePixel=0,ZIndex=8,Parent=tabBtn})
                N("UICorner",{CornerRadius=UDim.new(1,0),Parent=badgeF})
                rT(badgeF,"BackgroundColor3","accent")
                N("TextLabel",{Size=UDim2.new(1,0,1,0),BackgroundTransparency=1,Text=tostring(badge),TextColor3=Color3.fromRGB(0,0,0),TextSize=8,Font=Enum.Font.GothamBold,ZIndex=9,Parent=badgeF})
            end

            tabBtn.MouseEnter:Connect(function()
                if W.ActiveTab~=Tab then tw(tabBtn,.1,{BackgroundTransparency=.7,BackgroundColor3=T.elem}) end
            end)
            tabBtn.MouseLeave:Connect(function()
                if W.ActiveTab~=Tab then tw(tabBtn,.1,{BackgroundTransparency=1,BackgroundColor3=Color3.fromRGB(0,0,0)}) end
            end)

            table.insert(W._tabObjs,{btn=tabBtn,label=label})

            local function selectTab()
                if W.ActiveTab==Tab then return end
                local oldTab=W.ActiveTab
                W.ActiveTab=Tab
                -- Reset old tab button
                for _,to in ipairs(W._tabObjs) do
                    if to.btn then
                        tw(to.btn,.12,{BackgroundTransparency=1,BackgroundColor3=Color3.fromRGB(0,0,0),TextColor3=T.sub})
                        local ind=to.btn:FindFirstChildOfClass("Frame")
                        if ind then tw(ind,.12,{Size=UDim2.new(0,0,0,16),BackgroundTransparency=1}) end
                    end
                end
                -- Activate this tab button
                tw(tabBtn,.12,{BackgroundTransparency=.5,BackgroundColor3=T.tabSel,TextColor3=T.text})
                tw(actInd,.12,{Size=UDim2.new(0,3,0,16),BackgroundTransparency=0})

                -- Page transition
                if oldTab and oldTab._page then
                    oldTab._page.Visible=false
                end
                slideC.Position=UDim2.new(0,.03,0,0)
                slideC.BackgroundTransparency=0
                page.Visible=true
                tw(slideC,.2,{Position=UDim2.new(0,0,0,0),BackgroundTransparency=1},Enum.EasingStyle.Quart,Enum.EasingDirection.Out)
            end

            tabBtn.MouseButton1Click:Connect(selectTab)

            local Tab={
                _page=page,_scroll=pageScroll,_layout=pageLL,_slide=slideC,
                SetBadge=function(n)
                    if badgeF then
                        if n and n>0 then
                            badgeF.Visible=true
                            badgeF:FindFirstChildOfClass("TextLabel").Text=tostring(n)
                        else
                            twI(badgeF,.1,{Size=UDim2.new(0,0,0,0)})
                            task.delay(.12,function() badgeF.Visible=false end)
                        end
                    end
                end,
                Select=selectTab,
            }
            W.Tabs[label]=Tab
            if #W.Tabs==1 then task.defer(selectTab) end
            return Tab
        else
            -- No sidebar - return tab directly
            local Tab={_page=page,_scroll=pageScroll,_layout=pageLL,_slide=nil,SetBadge=function() end,Select=function() page.Visible=true end}
            W.Tabs[label]=Tab
            if #W.Tabs==1 then page.Visible=true end
            return Tab
        end
    end

