        local ov=New("Frame",{Size=UDim2.new(1,0,1,0),BackgroundColor3=Color3.fromRGB(0,0,0),BackgroundTransparency=0.55,BorderSizePixel=0,ZIndex=8000,Parent=sg})
        local card2=New("Frame",{Size=UDim2.new(0,330,0,0),AnchorPoint=Vector2.new(.5,.5),Position=UDim2.new(.5,0,.5,.03),BackgroundColor3=T.Section,BorderSizePixel=0,ZIndex=8001,Parent=ov})
        New("UICorner",{CornerRadius=UDim.new(0,11),Parent=card2})
        New("UIStroke",{Color=T.BorderLt,Thickness=1,Parent=card2})
        -- Accent top line
        New("Frame",{Size=UDim2.new(1,0,0,2),BackgroundColor3=T.Accent,BackgroundTransparency=0.5,BorderSizePixel=0,ZIndex=8002,Parent=card2})
        New("TextLabel",{Size=UDim2.new(1,-24,0,22),Position=UDim2.new(0,14,0,14),BackgroundTransparency=1,Text=o.Title or "Confirm",TextColor3=T.Text,TextSize=15,Font=Enum.Font.GothamBold,TextXAlignment=Enum.TextXAlignment.Left,ZIndex=8002,Parent=card2})
        local bl2=New("TextLabel",{Size=UDim2.new(1,-24,0,0),Position=UDim2.new(0,14,0,40),BackgroundTransparency=1,Text=o.Body or "Are you sure?",TextColor3=T.SubText,TextSize=12,Font=Enum.Font.Gotham,TextXAlignment=Enum.TextXAlignment.Left,TextWrapped=true,ZIndex=8002,Parent=card2})
        local function Close2()
            TweenQI(ov,.2,{BackgroundTransparency=1})
            task.delay(.22,function() pcall(function() ov:Destroy() end) end)
        end
        task.defer(function()
            bl2.Size=UDim2.new(1,-24,0,bl2.TextBounds.Y)
            local bH=bl2.TextBounds.Y; local totalH=bH+112
            TweenSp(card2,.35,{Size=UDim2.new(0,330,0,totalH),Position=UDim2.new(.5,0,.5,0)})
            local btnY=bH+58
            local cxBtn=New("TextButton",{Size=UDim2.new(0,135,0,34),Position=UDim2.new(0,14,0,btnY),BackgroundColor3=T.Element,BackgroundTransparency=0.3,Text=o.Cancel or "Cancel",TextColor3=T.SubText,TextSize=12,Font=Enum.Font.GothamSemibold,AutoButtonColor=false,ZIndex=8003,Parent=card2})
            New("UICorner",{CornerRadius=UDim.new(0,7),Parent=cxBtn})
            local cfBtn=New("TextButton",{Size=UDim2.new(0,135,0,34),Position=UDim2.new(1,-149,0,btnY),BackgroundColor3=T.Accent,BackgroundTransparency=0,Text=o.Confirm or "Confirm",TextColor3=Color3.fromRGB(255,255,255),TextSize=12,Font=Enum.Font.GothamSemibold,AutoButtonColor=false,ZIndex=8003,Parent=card2})
            New("UICorner",{CornerRadius=UDim.new(0,7),Parent=cfBtn})
            cxBtn.MouseButton1Click:Connect(function() Close2(); if o.OnCancel  then task.spawn(o.OnCancel)  end end)
            cfBtn.MouseButton1Click:Connect(function()
                Close2(); if o.OnConfirm then task.spawn(o.OnConfirm) end
                Ripple(cfBtn,cfBtn.AbsoluteSize.X*.5,cfBtn.AbsoluteSize.Y*.5,T.AccentGlow)
            end)
        end)
    end

