                        Position=UDim2.new(.5,0,.5,0),
                        BackgroundColor3=Color3.fromRGB(255,255,255),
                        BackgroundTransparency=val2==selected and 0 or 1,
                        BorderSizePixel=0,ZIndex=8,Parent=outer
                    })
                    New("UICorner",{CornerRadius=UDim.new(1,0),Parent=inner})
                    New("TextLabel",{
                        Size=UDim2.new(1,-26,1,0),Position=UDim2.new(0,24,0,0),
