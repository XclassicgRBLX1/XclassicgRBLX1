                f.MouseEnter:Connect(function()
                    TweenQ(f,.12,{BackgroundTransparency=0.12,BackgroundColor3=T.ElemHov})
                end)
                f.MouseLeave:Connect(function()
                    TweenQ(f,.12,{BackgroundTransparency=0.42,BackgroundColor3=T.Element})
                end)
            end
            local function NL(par,txt,y,sub)
                return New("TextLabel",{
