                N("UIStroke",{Color=T.accent, Thickness=1, Transparency=.55, Parent=chip})
                rT(chip,"BackgroundColor3","accent")
                local hLbl=N("TextLabel",{Size=UDim2.new(1,-8,1,0), Position=UDim2.new(0,6,0,0),
                    BackgroundTransparency=1,
                    Text=(sicon~="" and sicon.." " or "")..sname:upper(),
                    TextColor3=T.accent, TextSize=9,
