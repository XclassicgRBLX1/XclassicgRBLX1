                    Text="0%",TextColor3=T.accent,TextSize=10,Font=Enum.Font.GothamBold,TextXAlignment=Enum.TextXAlignment.Right,ZIndex=7,Parent=f})
                regT(pL,"TextColor3","accent")
                local rail=N("Frame",{Size=UDim2.new(1,-16,0,6),Position=UDim2.new(0,8,1,-14),BackgroundColor3=T.border,BorderSizePixel=0,ZIndex=7,Parent=f})
                N("UICorner",{CornerRadius=UDim.new(1,0),Parent=rail})
                local fill=N("Frame",{Size=UDim2.new(0,0,1,0),BackgroundColor3=o.Color or T.accent,BorderSizePixel=0,ZIndex=8,Parent=rail})
                N("UICorner",{CornerRadius=UDim.new(1,0),Parent=fill})
                local val=o.Default or 0
                local Obj={Value=val,_frame=f}
                function Obj:Set(v,anim)
                    val=clamp(v,0,1)
                    if anim~=false then tw(fill,.36,{Size=UDim2.new(val,0,1,0)}) else fill.Size=UDim2.new(val,0,1,0) end
                    pL.Text=math.floor(val*100).."%";self.Value=val
                end
                function Obj:Get() return val end
                function Obj:SetVisible(v) f.Visible=v end
                Obj:Set(val,false)
                return regE(o.Id,Obj,o.Name,f)
            end

            -- ══ RADIO GROUP ══
            function Sec:AddRadioGroup(o)
                o=o or{}
                local cb=o.Callback or function()end;local options=o.Options or{}
                local selected=o.Default or (options[1] and(type(options[1])=="table" and options[1].Value or options[1]))
                local f=ef(12+#options*28)
                mL(f,o.Name or "Options",7)
                local knobs={}
                local function updSel(val)
                    selected=val
                    for v,kn in pairs(knobs) do
                        tw(kn.o,.16,{BackgroundColor3=v==val and T.accent or T.muted})
                        tw(kn.i,.16,{BackgroundTransparency=v==val and 0 or 1})
                    end
                    task.spawn(cb,val)
                end
                for i,opt in ipairs(options) do
                    local val2=type(opt)=="table" and opt.Value or opt
                    local lbl2=type(opt)=="table" and opt.Label or opt
                    local row=N("Frame",{Size=UDim2.new(1,-12,0,22),Position=UDim2.new(0,6,0,16+(i-1)*26),BackgroundTransparency=1,ZIndex=6,Parent=f})
                    local outer=N("Frame",{Size=UDim2.new(0,14,0,14),AnchorPoint=Vector2.new(0,.5),Position=UDim2.new(0,0,.5,0),
                        BackgroundColor3=val2==selected and T.accent or T.muted,BorderSizePixel=0,ZIndex=7,Parent=row})
                    N("UICorner",{CornerRadius=UDim.new(1,0),Parent=outer})
                    local inner=N("Frame",{Size=UDim2.new(0,6,0,6),AnchorPoint=Vector2.new(.5,.5),Position=UDim2.new(.5,0,.5,0),
                        BackgroundColor3=Color3.fromRGB(255,255,255),BackgroundTransparency=val2==selected and 0 or 1,BorderSizePixel=0,ZIndex=8,Parent=outer})
                    N("UICorner",{CornerRadius=UDim.new(1,0),Parent=inner})
                    local ll=N("TextLabel",{Size=UDim2.new(1,-22,1,0),Position=UDim2.new(0,20,0,0),BackgroundTransparency=1,
                        Text=lbl2,TextColor3=T.text,TextSize=11,Font=Enum.Font.Gotham,TextXAlignment=Enum.TextXAlignment.Left,ZIndex=7,Parent=row})
                    regT(ll,"TextColor3","text")
                    knobs[val2]={o=outer,i=inner}
                    N("TextButton",{Size=UDim2.new(1,0,1,0),BackgroundTransparency=1,Text="",ZIndex=9,Parent=row}).MouseButton1Click:Connect(function()updSel(val2)end)
                end
                local Obj={Value=selected,_frame=f}
                function Obj:Set(v) updSel(v);self.Value=v end
                function Obj:Get() return selected end
                function Obj:SetVisible(v) f.Visible=v end
                return regE(o.Id,Obj,o.Name,f)
            end

            -- ══ BUTTON ROW ══
            function Sec:AddButtonRow(o)
                o=o or{};local btns=o.Buttons or{}
                local f=ef(34);local n=#btns;if n==0 then return{} end
                for i,btn in ipairs(btns) do
                    local b=N("TextButton",{Size=UDim2.new(1/n,i<n and -3 or 0,1,0),Position=UDim2.new((i-1)/n,0,0,0),
                        BackgroundColor3=T.elem,BackgroundTransparency=.2,Text=btn.Name or("Btn"..i),
                        TextColor3=T.sub,TextSize=10,Font=Enum.Font.GothamSemibold,AutoButtonColor=false,ZIndex=6,Parent=f})
                    N("UICorner",{CornerRadius=UDim.new(0,5),Parent=b});regT(b,"BackgroundColor3","elem")
                    b.MouseEnter:Connect(function()tw(b,.08,{BackgroundTransparency=0,BackgroundColor3=T.elemHov,TextColor3=T.text})end)
                    b.MouseLeave:Connect(function()tw(b,.08,{BackgroundTransparency=.2,BackgroundColor3=T.elem,TextColor3=T.sub})end)
                    b.MouseButton1Down:Connect(function()tw(b,.06,{BackgroundColor3=T.elemAct})end)
                    b.MouseButton1Up:Connect(function()tw(b,.1,{BackgroundColor3=T.elemHov});if btn.Callback then task.spawn(btn.Callback) end end)
                end
                local Obj={_frame=f}
                function Obj:SetVisible(v) f.Visible=v end
                function Obj:Get() return nil end;function Obj:Set() end
                return Obj
            end

            -- ══ TABLE ══
            function Sec:AddTable(o)
                o=o or{}
                local cols=o.Columns or{"Key","Value"};local rows=o.Rows or{}
                local rH=22;local h=math.min(#rows,6)*rH+rH+6
                local f=ef(h)
                local hdBg=N("Frame",{Size=UDim2.new(1,0,0,rH),BackgroundColor3=T.tabSel,BackgroundTransparency=.25,BorderSizePixel=0,ZIndex=7,Parent=f})
                N("UICorner",{CornerRadius=UDim.new(0,5),Parent=hdBg});regT(hdBg,"BackgroundColor3","tabSel")
                for i,col in ipairs(cols) do
                    N("TextLabel",{Size=UDim2.new(1/#cols,0,1,0),Position=UDim2.new((i-1)/#cols,0,0,0),BackgroundTransparency=1,
                        Text=col,TextColor3=T.accent,TextSize=9,Font=Enum.Font.GothamBold,ZIndex=8,Parent=hdBg})
                end
                local sc=N("ScrollingFrame",{Size=UDim2.new(1,0,1,-rH),Position=UDim2.new(0,0,0,rH),BackgroundTransparency=1,
                    ScrollBarThickness=2,ScrollBarImageColor3=T.scroll,ScrollingDirection=Enum.ScrollingDirection.Y,
                    CanvasSize=UDim2.new(0,0,0,0),ZIndex=7,Parent=f})
                local tLL=N("UIListLayout",{SortOrder=Enum.SortOrder.LayoutOrder,Padding=UDim.new(0,1),Parent=sc})
                tLL:GetPropertyChangedSignal("AbsoluteContentSize"):Connect(function()sc.CanvasSize=UDim2.new(0,0,0,tLL.AbsoluteContentSize.Y+4)end)
                local rowInsts={}
                local function buildRows()
                    for _,r in ipairs(rowInsts) do r:Destroy() end;rowInsts={}
                    for ri,row in ipairs(rows) do
                        local rb=N("Frame",{Size=UDim2.new(1,0,0,rH),BackgroundColor3=T.elem,
                            BackgroundTransparency=ri%2==0 and .6 or .44,BorderSizePixel=0,ZIndex=8,Parent=sc})
                        regT(rb,"BackgroundColor3","elem")
                        for ci,cell in ipairs(cols) do
                            N("TextLabel",{Size=UDim2.new(1/#cols,0,1,0),Position=UDim2.new((ci-1)/#cols,0,0,0),BackgroundTransparency=1,
                                Text=tostring(row[ci] or row[cell] or ""),TextColor3=T.sub,TextSize=10,Font=Enum.Font.Gotham,ZIndex=9,Parent=rb})
                        end
                        table.insert(rowInsts,rb)
                    end
                end
                buildRows()
                local Obj={_frame=f}
                function Obj:Update(nr) rows=nr;buildRows() end
                function Obj:Set(v) rows=v;buildRows() end
                function Obj:Get() return rows end
                function Obj:SetVisible(v) f.Visible=v end
                return regE(o.Id,Obj,o.Name,f)
            end

            -- ══ LABEL ══
            function Sec:AddLabel(o)
                o=o or{}
                local f=N("Frame",{Size=UDim2.new(1,0,0,24),BackgroundTransparency=1,ZIndex=5,Parent=secContent})
                local lbl=N("TextLabel",{Size=UDim2.new(1,-12,1,0),Position=UDim2.new(0,8,0,0),BackgroundTransparency=1,
                    Text=o.Text or "Label",TextColor3=o.Color or T.sub,TextSize=11,Font=Enum.Font.Gotham,
                    TextXAlignment=Enum.TextXAlignment.Left,TextWrapped=true,ZIndex=7,Parent=f})
                regT(lbl,"TextColor3","sub")
                local Obj={_frame=f}
                function Obj:Set(t,c) lbl.Text=t or lbl.Text;if c then lbl.TextColor3=c end end
                function Obj:Get() return lbl.Text end
                function Obj:SetVisible(v) f.Visible=v end
                return regE(o.Id,Obj,o.Name or o.Text,f)
            end

            -- ══ PARAGRAPH ══
            function Sec:AddParagraph(o)
                o=o or{}
                local f=N("Frame",{Size=UDim2.new(1,0,0,8),BackgroundTransparency=1,ZIndex=5,Parent=secContent})
                local fl=N("UIListLayout",{SortOrder=Enum.SortOrder.LayoutOrder,Padding=UDim.new(0,3),Parent=f})
                local te,be
                if(o.Title or "")~="" then
                    te=N("TextLabel",{Size=UDim2.new(1,-12,0,17),BackgroundTransparency=1,Text=o.Title,
                        TextColor3=T.text,TextSize=12,Font=Enum.Font.GothamSemibold,TextXAlignment=Enum.TextXAlignment.Left,TextWrapped=true,ZIndex=7,Parent=f})
                    regT(te,"TextColor3","text")
                end
                if(o.Body or "")~="" then
                    be=N("TextLabel",{Size=UDim2.new(1,-12,0,0),BackgroundTransparency=1,Text=o.Body,
                        TextColor3=T.sub,TextSize=10,Font=Enum.Font.Gotham,TextXAlignment=Enum.TextXAlignment.Left,TextWrapped=true,ZIndex=7,Parent=f})
                    regT(be,"TextColor3","sub")
                    local function rs() be.Size=UDim2.new(1,-12,0,be.TextBounds.Y);f.Size=UDim2.new(1,0,0,fl.AbsoluteContentSize.Y+4) end
                    be:GetPropertyChangedSignal("TextBounds"):Connect(rs);task.defer(rs)
                end
                fl:GetPropertyChangedSignal("AbsoluteContentSize"):Connect(function() f.Size=UDim2.new(1,0,0,fl.AbsoluteContentSize.Y+4) end)
                local Obj={_frame=f}
                function Obj:SetTitle(t) if te then te.Text=t end end
                function Obj:SetBody(b) if be then be.Text=b end end
                function Obj:SetVisible(v) f.Visible=v end
                function Obj:Get() return nil end;function Obj:Set() end
                return Obj
            end

            -- ══ DIVIDER ══
            function Sec:AddDivider(label)
                local f=N("Frame",{Size=UDim2.new(1,-12,0,label and 14 or 1),BackgroundTransparency=1,ZIndex=5,Parent=secContent})
                N("Frame",{Size=UDim2.new(1,0,0,1),Position=UDim2.new(0,0,.5,0),BackgroundColor3=T.border,BackgroundTransparency=.28,BorderSizePixel=0,ZIndex=6,Parent=f})
                if label then
                    local tw2=tsize(label,9).X+10
                    local bg2=N("Frame",{Size=UDim2.new(0,tw2,1,0),AnchorPoint=Vector2.new(.5,.5),Position=UDim2.new(.5,0,.5,0),BackgroundColor3=T.section,BorderSizePixel=0,ZIndex=7,Parent=f})
                    regT(bg2,"BackgroundColor3","section")
                    N("TextLabel",{Size=UDim2.new(1,0,1,0),BackgroundTransparency=1,Text=label,TextColor3=T.muted,TextSize=9,Font=Enum.Font.GothamBold,ZIndex=8,Parent=bg2})
                end
            end

            -- ══ EXECUTOR ══
            function Sec:AddExecutor(o)
                o=o or{}
                local f=ef(136)
                mL(f,o.Name or "Script Executor",7)
                local edBg=N("Frame",{Size=UDim2.new(1,-12,0,88),Position=UDim2.new(0,6,0,26),
                    BackgroundColor3=T.input,BorderSizePixel=0,ZIndex=7,Parent=f})
                N("UICorner",{CornerRadius=UDim.new(0,5),Parent=edBg});regT(edBg,"BackgroundColor3","input")
                N("UIStroke",{Color=T.border,Thickness=1,Parent=edBg})
                local edTb=N("TextBox",{Size=UDim2.new(1,-6,1,-4),Position=UDim2.new(0,3,0,2),BackgroundTransparency=1,
                    Text=o.Default or "print('Hello from NexusUI!')",PlaceholderText="Enter script...",PlaceholderColor3=T.muted,
                    TextColor3=T.text,TextSize=10,Font=Enum.Font.Code,TextXAlignment=Enum.TextXAlignment.Left,TextYAlignment=Enum.TextYAlignment.Top,
                    MultiLine=true,ClearTextOnFocus=false,ZIndex=8,Parent=edBg})
                regT(edTb,"TextColor3","text")
                local runBtn=N("TextButton",{Size=UDim2.new(1,-12,0,20),Position=UDim2.new(0,6,1,-26),
                    BackgroundColor3=T.accent,Text="▶  Execute",TextColor3=Color3.fromRGB(255,255,255),
                    TextSize=11,Font=Enum.Font.GothamSemibold,AutoButtonColor=false,ZIndex=7,Parent=f})
                N("UICorner",{CornerRadius=UDim.new(0,5),Parent=runBtn});regT(runBtn,"BackgroundColor3","accent")
                runBtn.MouseEnter:Connect(function()tw(runBtn,.1,{BackgroundColor3=T.accentH})end)
                runBtn.MouseLeave:Connect(function()tw(runBtn,.1,{BackgroundColor3=T.accent})end)
                runBtn.MouseButton1Click:Connect(function()
                    local code=edTb.Text
                    if o.Callback then task.spawn(o.Callback,code);return end
                    local fn,err=loadstring(code)
                    if fn then task.spawn(fn)
                    else W:Notify({Title="Execute Error",Content=tostring(err),Type="Error",Duration=4}) end
                end)
                local Obj={_frame=f}
                function Obj:Set(v) edTb.Text=v end
                function Obj:Get() return edTb.Text end
                function Obj:SetVisible(v) f.Visible=v end
                return regE(o.Id,Obj,o.Name,f)
            end

            return Sec
        end -- AddSection

        return Tab
    end -- AddTab

    -- ── CONSOLE TAB ──
    function W:AddConsoleTab()
        local tab=self:AddTab({Name="Console",Icon=">"})
        local sec=tab:AddSection({Name="LOG OUTPUT"})
        local logs={}
        local function addLog(msg,col)
            local lbl=sec:AddLabel({Text=msg,Color=col or T.sub})
            table.insert(logs,lbl)
            if #logs>50 then logs[1]:SetVisible(false);table.remove(logs,1) end
        end
        local oldP=print
        print=function(...)
            oldP(...)
            local parts={};for _,v in ipairs({...}) do table.insert(parts,tostring(v)) end
            pcall(function()addLog("› "..table.concat(parts,"  "),T.sub)end)
        end
        local cs=tab:AddSection({})
        cs:AddButtonRow({Buttons={
            {Name="Clear",Callback=function()for _,l in ipairs(logs) do l:SetVisible(false) end;logs={} end},
            {Name="Test",Callback=function()print("Test",math.random(100))end},
        }})
        return tab
    end

    -- ── BINDS TAB ──
    function W:AddBindsTab()
        local bt=self:AddTab({Name="Keybinds",Icon="⌨"})
        local bs=bt:AddSection({Name="REGISTERED KEYBINDS"})
        if #W._keybinds==0 then bs:AddLabel({Text="No keybinds registered yet.",Color=T.muted})
        else for _,b in ipairs(W._keybinds) do bs:AddLabel({Text="› "..b.Name.." — "..(b.Ref.key==Enum.KeyCode.Unknown and "None" or b.Ref.key.Name),Color=T.sub}) end end
        bs:AddDivider("Window")
        bs:AddLabel({Text="› Toggle UI — "..toggleKey.Name,Color=T.muted})
        bs:AddLabel({Text="› Ctrl+Z — Undo  ·  Ctrl+Y — Redo",Color=T.muted})
        bs:AddButton({Name="Show Keybind Overlay",Callback=function()W:ShowBinds()end})
        return bt
    end

    -- ── AUTO-SAVE ──
    function W:EnableAutoSave(interval,name)
        interval=interval or 30;name=name or "autosave"
        if W._autoSaveConn then W._autoSaveConn:Disconnect() end
        local e=0
        W._autoSaveConn=RunService.Heartbeat:Connect(function(dt)e=e+dt;if e>=interval then e=0;W:SaveConfig(name) end end)
    end

    return W
end

return Nexus
