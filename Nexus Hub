                     or Nexus.Themes[tname] or Nexus.Themes.BlackModern

    -- ── Sizing ────────────────────────────────────────────────────
    local vp      = getVP()
    local mobile  = vp.X < 860
    local WIN_W   = mobile and math.floor(vp.X*.97) or math.min(opts.Size and opts.Size.X.Offset or 720, vp.X-40)
    local WIN_H   = mobile and math.floor(vp.Y*.90) or math.min(opts.Size and opts.Size.Y.Offset or 520, vp.Y-40)
    local initSz  = UDim2.new(0,WIN_W,0,WIN_H)
    local initPos = opts.Position or UDim2.new(0.5,-WIN_W/2, 0.5,-WIN_H/2)
    local SW      = WIN_W >= 380 and 148 or 0
    local TOPH    = 44       -- slimmed (was 50)

    -- v7.0: glass / neumorphism flags (read from theme)
    local isGlass  = T._glass == true
    local isNeu    = T._neu   == true
    local glassBG  = T._glassBG  or .28
    local glassSec = T._glassSec or .38
    local glassEl  = T._glassElem or .48

    -- Design constants — sharper radius values
    local CR_WIN  = 10       -- window corner radius (was 16)
    local CR_SEC  = 8        -- section corner radius (was 10)
    local CR_EL   = 6        -- element corner radius (was 8)
    local EH      = 42       -- element height (was 44)
    local EHS     = 60       -- element height with subtitle (was 62)
