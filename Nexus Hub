        local optCon=N("Frame",{Size=UDim2.new(1,0,0,0),Position=UDim2.new(0,0,1,0),BackgroundColor3=T.section,BorderSizePixel=0,ClipsDescendants=true,ZIndex=5,Parent=el})
        N("UICorner",{CornerRadius=UDim.new(0,CR_E),Parent=optCon})
        N("UIStroke",{Color=T.border,Thickness=1,Transparency=.15,Parent=optCon})
        rT(optCon,"BackgroundColor3","section")

        -- Search in dropdown
        local ddSearchBg=N("Frame",{Size=UDim2.new(1,-8,0,22),Position=UDim2.new(0,4,0,4),BackgroundColor3=T.input,BorderSizePixel=0,ZIndex=6,Parent=optCon})
        N("UICorner",{CornerRadius=UDim.new(0,4),Parent=ddSearchBg})
        rT(ddSearchBg,"BackgroundColor3","input")
        local ddSearch=N("TextBox",{Size=UDim2.new(1,-8,1,0),Position=UDim2.new(0,4,0,0),BackgroundTransparency=1,Text="",PlaceholderText="Filter...",PlaceholderColor3=T.muted,TextColor3=T.text,TextSize=9,Font=Enum.Font.Gotham,ClearTextOnFocus=false,ZIndex=7,Parent=ddSearchBg})
        rT(ddSearch,"TextColor3","text")

        local optList=N("Frame",{Size=UDim2.new(1,-8,0,0),Position=UDim2.new(0,4,0,30),BackgroundColorTransparency=1,ClipsDescendants=true,ZIndex=6,Parent=optCon})
        local optLL=N("UIListLayout",{SortOrder=Enum.SortOrder.LayoutOrder,Padding=UDim.new(0,1),Parent=optList})

        local isOpen=false
        local selected={}
        local optFrames={}

        local function buildOpts(filter)
            for _,f in ipairs(optFrames) do pcall(function() f:Destroy() end) end
            optFrames={}
            local flt=(filter or ""):lower()
            for i,v in ipairs(list) do
                if flt=="" or tostring(v):lower():find(flt) then
                    local row=N("TextButton",{Size=UDim2.new(1,0,0,22),BackgroundColor3=Color3.fromRGB(0,0,0),BackgroundTransparency=1,Text="  "..tostring(v),TextColor3=T.sub,TextSize=10,Font=Enum.Font.Gotham,TextXAlignment=Enum.TextXAlignment.Left,AutoButtonColor=false,LayoutOrder=i,ZIndex=7,Parent=optList})
                    rT(row,"TextColor3","sub")
                    -- Check mark if selected
                    if selected[tostring(v)] then
                        row.Text="  ‚úď  "..tostring(v)
                        row.TextColor3=T.accent
                    end
                    row.MouseEnter:Connect(function() tw(row,.06,{BackgroundTransparency=.6,BackgroundColor3=T.elemHov}) end)
                    row.MouseLeave:Connect(function() tw(row,.06,{BackgroundTransparency=1}) end)
                    row.MouseButton1Click:Connect(function()
                        if multi then
                            selected[tostring(v)]=not selected[tostring(v)]
                        else
                            selected={}
                            selected[tostring(v)]=true
                            isOpen=false
                            tw(el,.15,{Size=UDim2.new(1,0,0,EH)})
                            tw(arrowLbl,.15,{Rotation=0})
                            local selText=tostring(v)
                            el:FindFirstChildOfClass("TextLabel").Text=label..":  "..selText
                        end
                        cb(selected)
                        buildOpts(ddSearch.Text)
                    end)
                    table.insert(optFrames,row)
                end
            end
            task.defer(function()
                local h=optLL.AbsoluteContentSize.Y+4
                optList.Size=UDim2.new(1,0,0,h)
                local totalH2=h+36
                optCon.Size=UDim2.new(1,0,0,totalH2)
            end)
        end

        ddSearch:GetPropertyChangedSignal("Text"):Connect(function() buildOpts(ddSearch.Text) end)

        el.InputBegan:Connect(function(i)
            if i.UserInputType==Enum.UserInputType.MouseButton1 or i.UserInputType==Enum.UserInputType.Touch then
                isOpen=not isOpen
                if isOpen then
                    tw(el,.15,{Size=UDim2.new(1,0,0,EH+180)})
                    tw(arrowLbl,.15,{Rotation=180})
                    ddSearch.Text=""
                    buildOpts("")
                    task.defer(function() ddSearch:CaptureFocus() end)
                else
                    tw(el,.15,{Size=UDim2.new(1,0,0,EH)})
                    tw(arrowLbl,.15,{Rotation=0})
                end
            end
        end)

        el.MouseEnter:Connect(function() tw(el,.08,{BackgroundColor3=T.elemHov}) end)
        el.MouseLeave:Connect(function() tw(el,.08,{BackgroundColor3=T.elem}) end)
        if tip then el.MouseEnter:Connect(function() showTip(tip) end); el.MouseLeave:Connect(hideTip) end

        if def then selected[tostring(def)]=true end

        return {Set=function(v) if type(v)=="table" then selected=v else selected={[tostring(v)]=true} end; cb(selected) end,Get=function() return selected end,Refresh=function(newList) list=newList or list; buildOpts("") end,Frame=el}
    end

