-- ════════════════════════════════════════════════════════════════
--  OBJECT POOL  — recycle any Instance class to cut GC pressure
--  local p = Nexus.Pool.new("Frame")
--  local f = p:get({Size=...,Parent=...})   -- reuse or create
--  p:release(f)                             -- return to pool
--  p:flush()                                -- destroy all free
--  p:stats()  →  {created, recycled}
-- ════════════════════════════════════════════════════════════════
Nexus.Pool = {}
local PoolMeta = {__index = Nexus.Pool}
function Nexus.Pool.new(className, defaults)
    return setmetatable({
        _class = className, _defaults = defaults or {},
        _free  = {}, _stats = {created=0, recycled=0},
    }, PoolMeta)
end
function Nexus.Pool:get(props)
    local obj
    if #self._free > 0 then
        obj = table.remove(self._free); self._stats.recycled += 1
    else
        obj = Instance.new(self._class); self._stats.created += 1
    end
    for k,v in pairs(self._defaults) do pcall(function() obj[k]=v end) end
    if props then
        for k,v in pairs(props) do
            if k ~= "Parent" then pcall(function() obj[k]=v end) end
        end
    end
    if props and props.Parent then obj.Parent = props.Parent end
    return obj
end
function Nexus.Pool:release(obj)
    if not obj then return end
    pcall(function() obj.Parent = nil end)
    table.insert(self._free, obj)
end
function Nexus.Pool:flush()
    for _,o in ipairs(self._free) do pcall(function() o:Destroy() end) end
    self._free = {}
end
function Nexus.Pool:stats() return self._stats end

-- Shared pools (used by VirtualList internally)
local _sharedPools = {}
local function sharedPool(cls)
    if not _sharedPools[cls] then _sharedPools[cls] = Nexus.Pool.new(cls) end
    return _sharedPools[cls]
end

