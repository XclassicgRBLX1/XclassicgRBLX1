                if(o.Body or "")~="" then
                    be=N("TextLabel",{Size=UDim2.new(1,-14,0,0),BackgroundTransparency=1,Text=o.Body,
                        TextColor3=T.sub,TextSize=12,Font=Enum.Font.Gotham,
                        TextXAlignment=Enum.TextXAlignment.Left,TextWrapped=true,ZIndex=7,Parent=f}); rT(be,"TextColor3","sub")
                    local function rs() be.Size=UDim2.new(1,-14,0,be.TextBounds.Y); f.Size=UDim2.new(1,0,0,fl.AbsoluteContentSize.Y+6) end
                    be:GetPropertyChangedSignal("TextBounds"):Connect(rs); task.defer(rs)
                end
                fl:GetPropertyChangedSignal("AbsoluteContentSize"):Connect(function()f.Size=UDim2.new(1,0,0,fl.AbsoluteContentSize.Y+6)end)
                local Obj={_frame=f}
                function Obj:SetTitle(t) if te then te.Text=t end end; function Obj:SetBody(b) if be then be.Text=b end end
                function Obj:SetVisible(v) f.Visible=v end; function Obj:Get() return nil end; function Obj:Set() end
                return Obj
            end

            -- ═══ DIVIDER ══════════════════════════════════════════
            function Sec:AddDivider(label)
                local f=N("Frame",{Size=UDim2.new(1,-14,0,label and 18 or 1),BackgroundTransparency=1,ZIndex=5,Parent=secContent})
                N("Frame",{Size=UDim2.new(1,0,0,1),Position=UDim2.new(0,0,.5,0),BackgroundColor3=T.border,BackgroundTransparency=.28,BorderSizePixel=0,ZIndex=6,Parent=f})
                if label then
                    local w2=TextService:GetTextSize(label,10,Enum.Font.Gotham,Vector2.new(9999,9999)).X+12
                    local bg2=N("Frame",{Size=UDim2.new(0,w2,1,0),AnchorPoint=Vector2.new(.5,.5),Position=UDim2.new(.5,0,.5,0),BackgroundColor3=T.section,BorderSizePixel=0,ZIndex=7,Parent=f})
                    rT(bg2,"BackgroundColor3","section")
                    N("TextLabel",{Size=UDim2.new(1,0,1,0),BackgroundTransparency=1,Text=label,TextColor3=T.muted,TextSize=10,Font=Enum.Font.GothamBold,ZIndex=8,Parent=bg2})
                end
            end

            -- ═══ EXECUTOR ═════════════════════════════════════════
            function Sec:AddExecutor(o)
                o=o or{}
                local f=ef(152)
                mL(f, o.Name or "Script Executor", 9)
                local edBg=N("Frame",{Size=UDim2.new(1,-14,0,100),Position=UDim2.new(0,7,0,32),
                    BackgroundColor3=T.input,BorderSizePixel=0,ZIndex=7,Parent=f})
                N("UICorner",{CornerRadius=UDim.new(0,7),Parent=edBg})
                N("UIStroke",{Color=T.border,Thickness=1,Parent=edBg}); rT(edBg,"BackgroundColor3","input")
                local edTb=N("TextBox",{Size=UDim2.new(1,-8,1,-6),Position=UDim2.new(0,4,0,3),BackgroundTransparency=1,
                    Text=o.Default or "print('Hello from NexusUI v6!')",PlaceholderText="Enter script...",
                    PlaceholderColor3=T.muted,TextColor3=T.text,TextSize=11,Font=Enum.Font.Code,
                    TextXAlignment=Enum.TextXAlignment.Left,TextYAlignment=Enum.TextYAlignment.Top,
                    MultiLine=true,ClearTextOnFocus=false,ZIndex=8,Parent=edBg}); rT(edTb,"TextColor3","text")
                local runBtn=N("TextButton",{Size=UDim2.new(1,-14,0,28),Position=UDim2.new(0,7,1,-34),
                    BackgroundColor3=T.accent,Text="▶  Execute",TextColor3=Color3.fromRGB(255,255,255),
                    TextSize=13,Font=Enum.Font.GothamSemibold,AutoButtonColor=false,ZIndex=7,Parent=f})
                N("UICorner",{CornerRadius=UDim.new(0,7),Parent=runBtn}); rT(runBtn,"BackgroundColor3","accent")
                runBtn.MouseEnter:Connect(function()tw(runBtn,.1,{BackgroundColor3=T.accentH})end)
                runBtn.MouseLeave:Connect(function()tw(runBtn,.1,{BackgroundColor3=T.accent})end)
                runBtn.MouseButton1Click:Connect(function()
                    local code=edTb.Text
                    if o.Callback then task.spawn(o.Callback,code); return end
                    local fn,err=loadstring(code)
                    if fn then task.spawn(fn)
                    else W:Notify({Title="Execute Error",Content=tostring(err),Type="Error",Duration=5}) end
                end)
                local Obj={_frame=f}
                function Obj:Set(v) edTb.Text=v end; function Obj:Get() return edTb.Text end
                function Obj:SetVisible(v) f.Visible=v end
                return regE(o.Id,Obj,o.Name,f)
            end

            -- Section lock
            function Sec:Lock(message)
                local lock=N("Frame",{Size=UDim2.new(1,0,1,0),BackgroundColor3=Color3.fromRGB(0,0,0),
                    BackgroundTransparency=.5,BorderSizePixel=0,ZIndex=50,Parent=secContent})
                N("TextLabel",{Size=UDim2.new(1,0,1,0),BackgroundTransparency=1,
                    Text="🔒  "..(message or "Locked"),TextColor3=Color3.fromRGB(255,255,255),
                    TextSize=14,Font=Enum.Font.GothamBold,ZIndex=51,Parent=lock})
                local Unlock=function()pcall(function()lock:Destroy()end)end
                return Unlock
            end

            return Sec
        end -- AddSection

        return Tab
    end -- AddTab

    -- ── Console tab ───────────────────────────────────────────────
    function W:AddConsoleTab()
        local tab=self:AddTab({Name="Console",Icon=">"})
        local sec=tab:AddSection({Name="LOG OUTPUT"})
        local logs={}
        local function addLog(msg,col)
            local lbl=sec:AddLabel({Text=msg,Color=col or T.sub})
            table.insert(logs,lbl)
            if #logs>50 then logs[1]:SetVisible(false); table.remove(logs,1) end
        end
        local old=print
        print=function(...)
            old(...)
            local parts={}; for _,v in ipairs({...}) do table.insert(parts,tostring(v)) end
            pcall(function()addLog("› "..table.concat(parts,"  "),T.sub)end)
        end
        local cs=tab:AddSection({})
        cs:AddButtonRow({Buttons={
            {Name="Clear",Callback=function()for _,l in ipairs(logs)do l:SetVisible(false)end;logs={}end},
            {Name="Test",Callback=function()print("NexusUI v6",math.random(1000))end},
        }})
        return tab
    end

    -- ── Binds tab ─────────────────────────────────────────────────
    function W:AddBindsTab()
        local bt=self:AddTab({Name="Keybinds",Icon="⌨"})
        local bs=bt:AddSection({Name="KEYBINDS"})
        if #W._keybinds==0 then bs:AddLabel({Text="No keybinds registered.",Color=T.muted})
        else for _,b in ipairs(W._keybinds) do bs:AddLabel({Text="›  "..b.Name.."  —  "..(b.Ref.key==Enum.KeyCode.Unknown and "None" or b.Ref.key.Name),Color=T.sub})end end
        bs:AddDivider("Window")
        bs:AddLabel({Text="›  Toggle UI  —  "..togKey.Name,Color=T.muted})
        bs:AddLabel({Text="›  Ctrl+Z — Undo  ·  Ctrl+Y — Redo",Color=T.muted})
        bs:AddButton({Name="Show Keybind Overlay",Callback=function()W:ShowBinds()end})
        return bt
    end

    return W
end

return Nexus
