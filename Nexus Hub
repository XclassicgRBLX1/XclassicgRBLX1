                N("UICorner",{CornerRadius=UDim.new(0,CR_EL),Parent=runBtn}); rT(runBtn,"BackgroundColor3","accent")
                runBtn.MouseEnter:Connect(function()tw(runBtn,.1,{BackgroundColor3=T.accentH})end)
