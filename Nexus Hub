        local togGlow=N("ImageLabel",{Size=UDim2.new(0,46,0,26),AnchorPoint=Vector2.new(1,.5),Position=UDim2.new(1,-6,.5,0),BackgroundTransparency=1,Image="rbxassetid://317956639",ImageColor3=T.accent,ImageTransparency=1,ZIndex=3,Parent=el})
