            -- ══════════════════════════════════════
            --  SLIDER
            -- ══════════════════════════════════════
            function Sec:AddSlider(o)
                o=o or {}
                local cb=o.Callback or function()end
                local mn=o.Min or 0; local mx=o.Max or 100
                local suf=o.Suffix or ""; local step=o.Step
                local f=EF(50)
                AddTip(f,o.Tooltip)
                NL(f,o.Name or "Slider",7)
                local vLbl=New("TextLabel",{
                    Size=UDim2.new(0,64,0,16),Position=UDim2.new(1,-70,0,7),
                    BackgroundTransparency=1,Text=tostring(o.Default or mn)..suf,
                    TextColor3=T.Accent,TextSize=12,Font=Enum.Font.GothamBold,
                    TextXAlignment=Enum.TextXAlignment.Right,ZIndex=7,Parent=f
                })
                local rail=New("Frame",{
                    Size=UDim2.new(1,-20,0,6),Position=UDim2.new(0,10,1,-16),
                    BackgroundColor3=T.SliderTr,BorderSizePixel=0,ZIndex=7,Parent=f
                })
                New("UICorner",{CornerRadius=UDim.new(1,0),Parent=rail})
                local val=Clamp(o.Default or mn,mn,mx)
                local pct=(val-mn)/(mx-mn)
                local fill=New("Frame",{
                    Size=UDim2.new(pct,0,1,0),BackgroundColor3=T.SliderFl,
                    BorderSizePixel=0,ZIndex=8,Parent=rail
                })
                New("UICorner",{CornerRadius=UDim.new(1,0),Parent=fill})
                local dot=New("Frame",{
                    Size=UDim2.new(0,14,0,14),AnchorPoint=Vector2.new(.5,.5),
                    Position=UDim2.new(pct,0,.5,0),
                    BackgroundColor3=Color3.fromRGB(255,255,255),
                    BorderSizePixel=0,ZIndex=9,Parent=rail
                })
                New("UICorner",{CornerRadius=UDim.new(1,0),Parent=dot})
                New("UIStroke",{Color=T.Accent,Thickness=2,Parent=dot})
                local drg=false
                local function Apply(i)
                    local ap=rail.AbsolutePosition; local as2=rail.AbsoluteSize
                    local r=Clamp((i.Position.X-ap.X)/as2.X,0,1)
                    local nv=Lerp(mn,mx,r)
                    nv=step and Round(nv,step) or math.floor(nv+.5)
                    nv=Clamp(nv,mn,mx); val=nv
                    local np=(nv-mn)/(mx-mn)
                    TweenQ(fill,.05,{Size=UDim2.new(np,0,1,0)})
                    TweenQ(dot,.05,{Position=UDim2.new(np,0,.5,0)})
                    vLbl.Text=tostring(nv)..suf; task.spawn(cb,nv)
                end
                rail.InputBegan:Connect(function(i)
                    if i.UserInputType==Enum.UserInputType.MouseButton1
                      or i.UserInputType==Enum.UserInputType.Touch then drg=true;Apply(i) end
                end)
                local c1=UserInputService.InputChanged:Connect(function(i)
                    if drg and (i.UserInputType==Enum.UserInputType.MouseMovement
                      or i.UserInputType==Enum.UserInputType.Touch) then Apply(i) end
                end)
                local c2=UserInputService.InputEnded:Connect(function(i)
                    if i.UserInputType==Enum.UserInputType.MouseButton1
                      or i.UserInputType==Enum.UserInputType.Touch then drg=false end
                end)
                table.insert(W._conns,c1); table.insert(W._conns,c2)
                local lockOv
                local Obj={Value=val}
                function Obj:Set(v)
                    val=Clamp(v,mn,mx); local np=(val-mn)/(mx-mn)
                    fill.Size=UDim2.new(np,0,1,0)
                    dot.Position=UDim2.new(np,0,.5,0)
                    vLbl.Text=tostring(val)..suf; self.Value=val
                end
                function Obj:Get() return val end
                function Obj:SetVisible(v) f.Visible=v end
                function Obj:Lock()   if not lockOv then lockOv=LockOverlay(f) end end
                function Obj:Unlock() if lockOv then lockOv:Destroy();lockOv=nil end end
                return Obj
            end

