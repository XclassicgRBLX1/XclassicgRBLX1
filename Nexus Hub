local TextService      = game:GetService("TextService")
local LP               = Players.LocalPlayer

local function tw(o,t,p,s,d)
    if not(o and o.Parent) then return end
    TweenService:Create(o,TweenInfo.new(t or .18,s or Enum.EasingStyle.Quart,d or Enum.EasingDirection.Out),p):Play()
end
local function twI(o,t,p) tw(o,t,p,Enum.EasingStyle.Quart,Enum.EasingDirection.In) end
local function twL(o,t,p) tw(o,t,p,Enum.EasingStyle.Linear) end
local function N(cls,props)
    local o=Instance.new(cls)
    for k,v in pairs(props) do if k~="Parent" then o[k]=v end end
    if props.Parent then o.Parent=props.Parent end
    return o
end
local function clamp(v,a,b) return math.max(a,math.min(b,v)) end
local function lerp(a,b,t) return a+(b-a)*t end
local function round(v,s) s=s or 1;return math.floor(v/s+.5)*s end
local function tsize(t,s) return TextService:GetTextSize(t,s or 12,Enum.Font.Gotham,Vector2.new(9999,9999)) end

local function mkGui(order)
    local sg=Instance.new("ScreenGui")
    sg.Name="_nx"..tostring(math.random(1e5,9e5))
    sg.ResetOnSpawn=false;sg.ZIndexBehavior=Enum.ZIndexBehavior.Sibling
    sg.DisplayOrder=order or 100;sg.IgnoreGuiInset=true
    local ok=pcall(function()
        if syn and syn.protect_gui then syn.protect_gui(sg) end
        if gethui then sg.Parent=gethui();return end
        if get_hidden_gui then sg.Parent=get_hidden_gui();return end
        sg.Parent=CoreGui
    end)
    if not ok or not sg.Parent then sg.Parent=LP:WaitForChild("PlayerGui") end
    return sg
end

local function applyScale(sg)
    local sc=N("UIScale",{Scale=1,Parent=sg})
    local conn
    local function upd()
        local cam=workspace.CurrentCamera
        local vp=(cam and cam.ViewportSize) or Vector2.new(1280,720)
        sc.Scale=clamp(math.min(vp.X/1280,vp.Y/720),.45,1)
    end
    local function watch()
        if conn then pcall(function()conn:Disconnect()end) end
        if workspace.CurrentCamera then
            conn=workspace.CurrentCamera:GetPropertyChangedSignal("ViewportSize"):Connect(upd)
        end
    end
    watch();upd()
    workspace:GetPropertyChangedSignal("CurrentCamera"):Connect(function()watch();upd()end)
end

