            function Sec:AddDropdown(o)
                o=o or {}
                local cb=o.Callback or function()end
                local items=o.Items or {}; local multi=o.Multi==true
                local f=EF(36); HE(f)
                AddTip(f,o.Tooltip)
                NL(f,o.Name or "Dropdown",10)
                local sel=multi and {} or (o.Default or items[1] or "Select...")
                local open=false

                local pill2=New("TextButton",{
                    Size=UDim2.new(0,142,0,26),Position=UDim2.new(1,-150,.5,-13),
                    BackgroundColor3=T.Input,BorderSizePixel=0,
                    Text="",AutoButtonColor=false,ZIndex=7,Parent=f
                })
                New("UICorner",{CornerRadius=UDim.new(0,6),Parent=pill2})
                New("UIStroke",{Color=T.Border,Thickness=1,Parent=pill2})
                local selLbl=New("TextLabel",{
                    Size=UDim2.new(1,-24,1,0),Position=UDim2.new(0,8,0,0),
                    BackgroundTransparency=1,
                    Text=multi and "None" or (o.Default or items[1] or "Select..."),
                    TextColor3=T.Text,TextSize=11,Font=Enum.Font.Gotham,
                    TextXAlignment=Enum.TextXAlignment.Left,
                    TextTruncate=Enum.TextTruncate.AtEnd,ZIndex=8,Parent=pill2
                })
                local arrow=New("TextLabel",{
                    Size=UDim2.new(0,18,1,0),Position=UDim2.new(1,-20,0,0),
                    BackgroundTransparency=1,Text="⌄",
                    TextColor3=T.SubText,TextSize=13,Font=Enum.Font.GothamBold,
                    ZIndex=8,Parent=pill2
                })

                local popup=New("Frame",{
                    Size=UDim2.new(0,142,0,0),BackgroundColor3=T.Sidebar,
                    BorderSizePixel=0,ClipsDescendants=true,Visible=false,ZIndex=5000,Parent=sg
                })
                New("UICorner",{CornerRadius=UDim.new(0,8),Parent=popup})
                New("UIStroke",{Color=T.BorderLt,Thickness=1,Parent=popup})
                local pScroll=New("ScrollingFrame",{
                    Size=UDim2.new(1,0,1,0),BackgroundTransparency=1,
                    ScrollBarThickness=2,ScrollBarImageColor3=T.Scroll,ZIndex=5001,Parent=popup
                })
                local pList=New("UIListLayout",{
                    SortOrder=Enum.SortOrder.LayoutOrder,
                    Padding=UDim.new(0,2),Parent=pScroll
                })
                New("UIPadding",{
                    PaddingTop=UDim.new(0,4),PaddingBottom=UDim.new(0,4),
                    PaddingLeft=UDim.new(0,4),PaddingRight=UDim.new(0,4),Parent=pScroll
                })
                local function RebuildPop()
                    for _,c in ipairs(pScroll:GetChildren()) do
                        if c:IsA("TextButton") then c:Destroy() end
                    end
                    for _,item in ipairs(items) do
                        local isSel=multi and table.find(sel,item)~=nil or sel==item
                        local ib=New("TextButton",{
                            Size=UDim2.new(1,0,0,28),
                            BackgroundColor3=isSel and T.AccentDim or T.Element,
                            BackgroundTransparency=isSel and 0 or 0.6,
                            Text="",AutoButtonColor=false,ZIndex=5002,Parent=pScroll
                        })
                        New("UICorner",{CornerRadius=UDim.new(0,5),Parent=ib})
                        if isSel then
                            New("TextLabel",{
                                Size=UDim2.new(0,16,1,0),Position=UDim2.new(0,4,0,0),
                                BackgroundTransparency=1,Text="✓",
                                TextColor3=T.Accent,TextSize=10,Font=Enum.Font.GothamBold,
                                ZIndex=5003,Parent=ib
                            })
                        end
                        New("TextLabel",{
                            Size=UDim2.new(1,isSel and -20 or -8,1,0),
                            Position=UDim2.new(0,isSel and 20 or 8,0,0),
                            BackgroundTransparency=1,Text=item,
                            TextColor3=isSel and T.Text or T.SubText,
                            TextSize=12,Font=isSel and Enum.Font.GothamSemibold or Enum.Font.Gotham,
                            TextXAlignment=Enum.TextXAlignment.Left,ZIndex=5003,Parent=ib
                        })
                        ib.MouseEnter:Connect(function()
                            if not isSel then TweenQ(ib,.1,{BackgroundTransparency=0.35}) end
                        end)
                        ib.MouseLeave:Connect(function()
                            TweenQ(ib,.1,{BackgroundTransparency=isSel and 0 or 0.6})
                        end)
                        ib.MouseButton1Click:Connect(function()
                            if multi then
                                local idx=table.find(sel,item)
                                if idx then table.remove(sel,idx) else table.insert(sel,item) end
                                selLbl.Text=#sel>0 and table.concat(sel,", ") or "None"
                                RebuildPop(); task.spawn(cb,sel)
                            else
                                sel=item; selLbl.Text=item; RebuildPop()
                                task.spawn(cb,item)
                                open=false
                                TweenQ(popup,.18,{Size=UDim2.new(0,142,0,0)})
                                TweenQ(arrow,.18,{Rotation=0})
                                task.delay(.2,function() if not open then popup.Visible=false end end)
                            end
                        end)
                    end
                    pScroll.CanvasSize=UDim2.new(0,0,0,pList.AbsoluteContentSize.Y+8)
                    return math.min(#items*30+8,160)
                end
                pill2.MouseButton1Click:Connect(function()
                    open=not open
                    if open then
                        local ap=pill2.AbsolutePosition; local as2=pill2.AbsoluteSize
                        popup.Position=UDim2.new(0,ap.X,0,ap.Y+as2.Y+4)
                        popup.Size=UDim2.new(0,as2.X,0,0)
                        local ph=RebuildPop()
                        popup.Visible=true
                        TweenQ(popup,.2,{Size=UDim2.new(0,as2.X,0,ph)})
                        TweenQ(arrow,.2,{Rotation=180})
                    else
                        TweenQ(popup,.18,{Size=UDim2.new(0,142,0,0)})
                        TweenQ(arrow,.18,{Rotation=0})
                        task.delay(.2,function() if not open then popup.Visible=false end end)
                    end
                end)
                local Obj={Value=sel}
                function Obj:Set(v)
                    if multi then sel=type(v)=="table" and v or {v}
                        selLbl.Text=#sel>0 and table.concat(sel,", ") or "None"
                    else sel=v; selLbl.Text=v end
                    self.Value=sel; RebuildPop()
                end
                function Obj:Refresh(ni) items=ni; RebuildPop() end
                function Obj:Get() return sel end
                function Obj:SetVisible(v) f.Visible=v end
                return Obj
            end

