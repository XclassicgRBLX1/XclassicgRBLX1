                        TextColor3=T.Text,TextSize=12,Font=Enum.Font.Gotham,
                        TextXAlignment=Enum.TextXAlignment.Left,ZIndex=7,Parent=row
                    })
                    dots2[val2]={outer=outer,inner=inner}
                    local rb=New("TextButton",{
                        Size=UDim2.new(1,0,1,0),BackgroundTransparency=1,
                        Text="",ZIndex=9,Parent=row
