--  CREATE WINDOW
-- ‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź
function Nexus:CreateWindow(opts)
    opts = opts or {}
    local title = opts.Title or "NexusUI"
    local subtitle = opts.Subtitle or ""
    local togKey = opts.ToggleKey or Enum.KeyCode.RightShift
    local tname = type(opts.Theme)=="string" and opts.Theme or "BlackModern"
    local T = (type(opts.Theme)=="table") and opts.Theme or Nexus.Themes[tname] or Nexus.Themes.BlackModern

    local vp = getVP()
    local mobile = vp.X < 860
    local WIN_W = mobile and math.floor(vp.X*.97) or math.min(opts.Size and opts.Size.X.Offset or 720, vp.X-40)
    local WIN_H = mobile and math.floor(vp.Y*.90) or math.min(opts.Size and opts.Size.Y.Offset or 520, vp.Y-40)
    local initSz = UDim2.new(0,WIN_W,0,WIN_H)
    local initPos = opts.Position or UDim2.new(0.5,-WIN_W/2, 0.5,-WIN_H/2)
    local SW = WIN_W >= 380 and 148 or 0
    local TOPH = 46
    local CR_WIN = 14
    local CR_SEC = 10
    local CR_EL = 8
    local EH = 44
    local EHS = 62
    local TSZ = 14
    local SSZ = 12

    -- Theme registry
    local reg = {}
    local function rT(i,p,k) if i and k then table.insert(reg,{i=i,p=p,k=k}) end end
    local function applyTheme(nT)
        T=nT
        for _,r in ipairs(reg) do pcall(function()
            if r.i and r.i.Parent and nT[r.k] then r.i[r.p]=nT[r.k] end
        end) end
    end

    local uStk,rStk={},{}
    local function push(d,u)
        table.insert(uStk,{d=d,u=u}); rStk={}
        if #uStk>60 then table.remove(uStk,1) end
    end

    -- Notification system
    local notifSG = mkGui(99900)
    local notifBox = N("Frame",{Size=UDim2.new(0,320,1,0), Position=UDim2.new(1,-328,0,0),
        BackgroundTransparency=1, Parent=notifSG})
    N("UIListLayout",{SortOrder=Enum.SortOrder.LayoutOrder,
        VerticalAlignment=Enum.VerticalAlignment.Top, Padding=UDim.new(0,6), Parent=notifBox})
    N("UIPadding",{PaddingTop=UDim.new(0,16), Parent=notifBox})
    local notifIdx=0; local notifLog={}

    -- Tooltip system
    local tipSG = mkGui(99700)
    local tipBox = N("Frame",{Size=UDim2.new(0,10,0,26), BackgroundColor3=T.glassBg,
        BackgroundTransparency=0.08, BorderSizePixel=0, Visible=false, ZIndex=1, Parent=tipSG})
    N("UICorner",{CornerRadius=UDim.new(0,8), Parent=tipBox})
    N("UIStroke",{Color=T.accent, Thickness=1, Transparency=.5, Parent=tipBox})
    rT(tipBox,"BackgroundColor3","glassBg")
    local tipLbl = N("TextLabel",{Size=UDim2.new(1,-14,1,0), Position=UDim2.new(0,7,0,0),
        BackgroundTransparency=1, Text="", TextColor3=T.sub, TextSize=11,
        Font=Enum.Font.Gotham, ZIndex=2, Parent=tipBox}); rT(tipLbl,"TextColor3","sub")
    local tipConn
    local function showTip(txt)
        if not txt or txt=="" then return end
        if tipConn then pcall(function()tipConn:Disconnect()end) end
        tipLbl.Text=txt
        local w=TextService:GetTextSize(txt,11,Enum.Font.Gotham,Vector2.new(9999,9999)).X+18
        tipBox.Size=UDim2.new(0,w,0,26); tipBox.Visible=true
        SoundManager:Play("Hover")
        tipConn=RunService.Heartbeat:Connect(function()
            local mp=UserInputService:GetMouseLocation()
            tipBox.Position=UDim2.new(0,mp.X+16,0,mp.Y+16)
        end)
    end
    local function hideTip()
        tipBox.Visible=false
        if tipConn then pcall(function()tipConn:Disconnect()end); tipConn=nil end
    end

    -- Main window frame
    local sg = mkGui(100)
    local wrap = N("Frame",{Size=initSz, Position=initPos, BackgroundTransparency=1, Parent=sg})
    
    -- Shadow
    local shadow = N("Frame",{Size=UDim2.new(1,16,1,16), Position=UDim2.new(0,8,0,8),
        BackgroundColor3=Color3.fromRGB(0,0,0), BackgroundTransparency=0.75, BorderSizePixel=0, ZIndex=0, Parent=wrap})
    N("UICorner",{CornerRadius=UDim.new(0,CR_WIN), Parent=shadow})
    
    local main = N("Frame",{Size=UDim2.new(1,0,1,0), BackgroundColor3=T.glassBg,
        BackgroundTransparency=0.1, BorderSizePixel=0, ClipsDescendants=true, ZIndex=1, Parent=wrap})
    N("UICorner",{CornerRadius=UDim.new(0,CR_WIN), Parent=main}); rT(main,"BackgroundColor3","glassBg")
    N("UIStroke",{Color=T.border, Thickness=1.2, Transparency=.2, Parent=main})

    -- Accent stripe at top
    local winStripe = N("Frame",{Size=UDim2.new(1,0,0,3), BackgroundColor3=T.accent,
        BorderSizePixel=0, ZIndex=8, Parent=main})
    rT(winStripe,"BackgroundColor3","accent")

    -- TOPBAR
    local topbar = N("Frame",{Size=UDim2.new(1,0,0,TOPH), Position=UDim2.new(0,0,0,3),
        BackgroundColor3=T.topbar, BackgroundTransparency=.25, BorderSizePixel=0, ZIndex=5, Parent=main})
    rT(topbar,"BackgroundColor3","topbar")
    N("Frame",{Size=UDim2.new(1,0,0,CR_WIN), Position=UDim2.new(0,0,0,0),
        BackgroundColor3=T.topbar, BackgroundTransparency=.25, BorderSizePixel=0, ZIndex=4, Parent=topbar})
    N("Frame",{Size=UDim2.new(1,0,0,1), Position=UDim2.new(0,0,1,-1),
        BackgroundColor3=T.border, BackgroundTransparency=.3, BorderSizePixel=0, ZIndex=6, Parent=topbar})

    -- Title with accent pill
    local tpill = N("Frame",{Size=UDim2.new(0,4,0,20), Position=UDim2.new(0,14,.5,-10),
        BackgroundColor3=T.accent, BorderSizePixel=0, ZIndex=7, Parent=topbar})
    N("UICorner",{CornerRadius=UDim.new(0,2), Parent=tpill}); rT(tpill,"BackgroundColor3","accent")

    local tY = subtitle~="" and 7 or 0
    local tH = subtitle~="" and 18 or TOPH
    local titleLbl = N("TextLabel",{Size=UDim2.new(0,280,0,tH), Position=UDim2.new(0,24,0,tY),
        BackgroundTransparency=1, Text=title, TextColor3=T.text, TextSize=15,
        Font=Enum.Font.GothamBold, TextXAlignment=Enum.TextXAlignment.Left, ZIndex=7, Parent=topbar}); rT(titleLbl,"TextColor3","text")
    if subtitle~="" then
        local sl=N("TextLabel",{Size=UDim2.new(0,280,0,12), Position=UDim2.new(0,24,0,27),
            BackgroundTransparency=1, Text=subtitle, TextColor3=T.sub, TextSize=10,
            Font=Enum.Font.Gotham, TextXAlignment=Enum.TextXAlignment.Left, ZIndex=7, Parent=topbar})
        rT(sl,"TextColor3","sub")
    end

    -- Control buttons
    local function ctrlBtn(xOff,bg_,sym,sz,ttip)
        local b=N("TextButton",{Size=UDim2.new(0,28,0,26), Position=UDim2.new(1,xOff,0,TOPH/2-13),
            BackgroundColor3=bg_, BackgroundTransparency=.55, Text=sym,
            TextColor3=Color3.fromRGB(200,200,200), TextSize=sz or 10,
            Font=Enum.Font.GothamBold, AutoButtonColor=false, ZIndex=20, Parent=wrap})
        N("UICorner",{CornerRadius=UDim.new(0,6), Parent=b})
        b.MouseEnter:Connect(function()
            tw(b,.1,{BackgroundTransparency=0,TextColor3=Color3.fromRGB(255,255,255)})
            if ttip then showTip(ttip) end
            SoundManager:Play("Hover")
        end)
        b.MouseLeave:Connect(function()
            tw(b,.1,{BackgroundTransparency=.55,TextColor3=Color3.fromRGB(200,200,200)})
            hideTip()
        end)
        b.MouseButton1Click:Connect(function() SoundManager:Play("Click") end)
        return b
    end
    local btnClose = ctrlBtn(-34,Color3.fromRGB(200,44,44),"‚úē",11,"Close")
    local btnMin = ctrlBtn(-66,Color3.fromRGB(38,38,48),"‚ĒÄ",14,"Minimize")
    local btnIcon = ctrlBtn(-98,Color3.fromRGB(38,38,48),"‚õ∂",9,"Iconify")
    local bellBtn = ctrlBtn(-130,Color3.fromRGB(38,38,48),"ūüĒĒ",12,"Notifications")
    local bellBdg = N("Frame",{Size=UDim2.new(0,10,0,10), Position=UDim2.new(1,-3,0,-2),
        BackgroundColor3=T.error, BorderSizePixel=0, Visible=false, ZIndex=21, Parent=bellBtn})
    N("UICorner",{CornerRadius=UDim.new(1,0), Parent=bellBdg})

    -- SIDEBAR
    local sidebar,tabScrollF,tabLLF,sbSearch
    if SW>0 then
        sidebar=N("Frame",{Size=UDim2.new(0,SW,1,-TOPH-3), Position=UDim2.new(0,0,0,TOPH+3),
            BackgroundColor3=T.sidebar, BackgroundTransparency=.15, BorderSizePixel=0, ZIndex=4, Parent=main})
        rT(sidebar,"BackgroundColor3","sidebar")
        N("Frame",{Size=UDim2.new(0,1,1,0), Position=UDim2.new(1,0,0,0),
            BackgroundColor3=T.border, BackgroundTransparency=.25, BorderSizePixel=0, ZIndex=5, Parent=sidebar})
        
        local sBg=N("Frame",{Size=UDim2.new(1,-14,0,28), Position=UDim2.new(0,7,0,8),
            BackgroundColor3=T.input, BackgroundTransparency=.25, BorderSizePixel=0, ZIndex=6, Parent=sidebar})
        N("UICorner",{CornerRadius=UDim.new(0,CR_EL), Parent=sBg})
        N("UIStroke",{Color=T.border, Thickness=1, Transparency=.4, Parent=sBg}); rT(sBg,"BackgroundColor3","input")
        N("TextLabel",{Size=UDim2.new(0,16,1,0), Position=UDim2.new(0,7,0,0), BackgroundTransparency=1,
            Text="‚Ćē", TextColor3=T.muted, TextSize=13, Font=Enum.Font.GothamBold, ZIndex=7, Parent=sBg})
        sbSearch=N("TextBox",{Size=UDim2.new(1,-24,1,0), Position=UDim2.new(0,22,0,0),
            BackgroundTransparency=1, Text="", PlaceholderText="Search...",
            PlaceholderColor3=T.muted, TextColor3=T.text, TextSize=11, Font=Enum.Font.Gotham,
            TextXAlignment=Enum.TextXAlignment.Left, ClearTextOnFocus=false, ZIndex=7, Parent=sBg})
        rT(sbSearch,"TextColor3","text")
        
        tabScrollF=N("ScrollingFrame",{Size=UDim2.new(1,0,1,-44), Position=UDim2.new(0,0,0,42),
            BackgroundTransparency=1, ScrollBarThickness=0, ScrollingDirection=Enum.ScrollingDirection.Y,
            CanvasSize=UDim2.new(0,0,0,0), ZIndex=5, Parent=sidebar})
        tabLLF=N("UIListLayout",{SortOrder=Enum.SortOrder.LayoutOrder, Padding=UDim.new(0,2), Parent=tabScrollF})
        N("UIPadding",{PaddingLeft=UDim.new(0,6), PaddingRight=UDim.new(0,6), PaddingTop=UDim.new(0,4), Parent=tabScrollF})
        tabLLF:GetPropertyChangedSignal("AbsoluteContentSize"):Connect(function()
            tabScrollF.CanvasSize=UDim2.new(0,0,0,tabLLF.AbsoluteContentSize.Y+8)
        end)
    end

    -- Page container
    local pcX = SW>0 and SW+1 or 0
    local pageCon = N("Frame",{Size=UDim2.new(1,-pcX,1,-TOPH-3), Position=UDim2.new(0,pcX,0,TOPH+3),
        BackgroundTransparency=1, ClipsDescendants=true, ZIndex=3, Parent=main})

