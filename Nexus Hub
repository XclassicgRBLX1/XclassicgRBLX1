                if not knob:FindFirstChildOfClass("UIStroke") then
                    local s=N("UIStroke",{Color=T.accent,Thickness=1.5,Transparency=.3,Parent=knob})
                end
            else
                tw(track,.2,{BackgroundColor3=T.border})
                tw(knob,.2,{Position=UDim2.new(0,2,.5,0),BackgroundColor3=Color3.fromRGB(180,180,180)})
                tw(togGlow,.2,{ImageTransparency=1})
                local s=knob:FindFirstChildOfClass("UIStroke")
                if s then s:Destroy() end
            end
        end
        update(def)

        el.InputBegan:Connect(function(i)
            if i.UserInputType==Enum.UserInputType.MouseButton1 or i.UserInputType==Enum.UserInputType.Touch then
                local newVal=not state
                update(newVal)
                push(state,function(d) update(d) end)
                cb(newVal)
            end
        end)

        el.MouseEnter:Connect(function() tw(el,.08,{BackgroundColor3=T.elemHov}) end)
        el.MouseLeave:Connect(function() tw(el,.08,{BackgroundColor3=T.elem}) end)
        if tip then el.MouseEnter:Connect(function() showTip(tip) end); el.MouseLeave:Connect(hideTip) end

        return {Set=function(v) update(v);cb(v) end,Get=function() return state end,Frame=el}
