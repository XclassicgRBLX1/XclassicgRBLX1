            BackgroundTransparency=1, Text="", PlaceholderText="Search elements...",
            PlaceholderColor3=T.muted, TextColor3=T.text, TextSize=12, Font=Enum.Font.Gotham,
            TextXAlignment=Enum.TextXAlignment.Left, ClearTextOnFocus=false, ZIndex=5, Parent=psBg})
        rT(psBox,"TextColor3","text")

        -- ════════════════════════════════════════════════════════
        --  THE SCROLL FRAME — this is what makes tabs scrollable
        --  Sits below the 50px search bar, fills remaining height
        -- ════════════════════════════════════════════════════════
        local page = N("ScrollingFrame",{
            Size                 = UDim2.new(1,0,1,-50),
            Position             = UDim2.new(0,0,0,50),
            BackgroundTransparency = 1,
            ScrollBarThickness   = 5,
            ScrollBarImageColor3 = T.scroll,
            ScrollingDirection   = Enum.ScrollingDirection.Y,
            CanvasSize           = UDim2.new(0,0,0,0),
