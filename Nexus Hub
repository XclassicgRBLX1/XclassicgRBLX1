    -- ══════════════════════════════════════════════
    --  DRAG + RESIZE + MINIMIZE-TO-ICON + MAXIMIZE
    -- ══════════════════════════════════════════════
    do
        local drag,ds,ws
        topbar.InputBegan:Connect(function(i)
            if i.UserInputType==Enum.UserInputType.MouseButton1 or
               i.UserInputType==Enum.UserInputType.Touch then
                drag=true;ds=i.Position;ws=wrap.Position
            end
        end)
        table.insert(W._conns,UserInputService.InputChanged:Connect(function(i)
            if not drag then return end
            if i.UserInputType==Enum.UserInputType.MouseMovement or
               i.UserInputType==Enum.UserInputType.Touch then
                local d=i.Position-ds
                wrap.Position=UDim2.new(ws.X.Scale,ws.X.Offset+d.X,ws.Y.Scale,ws.Y.Offset+d.Y)
            end
        end))
        table.insert(W._conns,UserInputService.InputEnded:Connect(function(i)
            if i.UserInputType==Enum.UserInputType.MouseButton1 or
               i.UserInputType==Enum.UserInputType.Touch then drag=false end
        end))
        -- icon pill drag
        local id2,ids,ips
        iconPill.InputBegan:Connect(function(i)
            if i.UserInputType==Enum.UserInputType.MouseButton1 then
                id2=true;ids=i.Position;ips=iconPill.Position
            end
        end)
        table.insert(W._conns,UserInputService.InputChanged:Connect(function(i)
            if id2 and i.UserInputType==Enum.UserInputType.MouseMovement then
                local d=i.Position-ids
                iconPill.Position=UDim2.new(ips.X.Scale,ips.X.Offset+d.X,ips.Y.Scale,ips.Y.Offset+d.Y)
            end
        end))
        table.insert(W._conns,UserInputService.InputEnded:Connect(function(i)
            if i.UserInputType==Enum.UserInputType.MouseButton1 then id2=false end
        end))
    end
    -- Resize
    do
        local rd,rds,rws
        resizeHandle.InputBegan:Connect(function(i)
            if i.UserInputType==Enum.UserInputType.MouseButton1 then
                rd=true;rds=i.Position;rws=wrap.Size
            end
        end)
        table.insert(W._conns,UserInputService.InputChanged:Connect(function(i)
            if rd and i.UserInputType==Enum.UserInputType.MouseMovement then
                local d=i.Position-rds
                local nw=math.max(420,rws.X.Offset+d.X)
                local nh=math.max(300,rws.Y.Offset+d.Y)
                wrap.Size=UDim2.new(0,nw,0,nh)
            end
        end))
        table.insert(W._conns,UserInputService.InputEnded:Connect(function(i)
            if i.UserInputType==Enum.UserInputType.MouseButton1 then rd=false end
        end))
    end
